{"ast":null,"code":"export default {\n  name: 'Footer'\n};","map":{"version":3,"names":["name"],"sources":["src/components/Footer.vue"],"sourcesContent":["<template>\n  <div class=\"footer-container\">\n    <div class=\"footer-content\">\n      <div class=\"footer-section\">\n        <h3 class=\"section-title\">关于平台</h3>\n        <p class=\"section-text\">网格化依法治理平台致力于推进基层社会治理现代化，提升网格员法治素养，构建和谐社区。</p>\n      </div>\n      \n      <div class=\"footer-section\">\n        <h3 class=\"section-title\">快速链接</h3>\n        <div class=\"link-list\">\n          <a href=\"/#/front/home\" class=\"footer-link\">首页</a>\n          <a href=\"/#/front/knowledge\" class=\"footer-link\">治理案例</a>\n          <a href=\"/#/front/activity\" class=\"footer-link\">任务中心</a>\n          <a href=\"/#/front/person\" class=\"footer-link\">个人中心</a>\n        </div>\n      </div>\n      \n      <div class=\"footer-section\">\n        <h3 class=\"section-title\">紧急联系</h3>\n        <div class=\"contact-list\">\n          <p class=\"contact-item\">\n            <i class=\"el-icon-phone\"></i>\n            <span>综治热线：12345</span>\n          </p>\n          <p class=\"contact-item\">\n            <i class=\"el-icon-service\"></i>\n            <span>网格服务：123456</span>\n          </p>\n        </div>\n      </div>\n    </div>\n    \n    <div class=\"footer-bottom\">\n      <p class=\"copyright\">\n        <i class=\"el-icon-info\"></i>\n        Copyright © 2025 网格化依法治理平台 All Rights Reserved\n      </p>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'Footer'\n}\n</script>\n\n<style scoped>\n.footer-container {\n  background: #1d3557;\n  color: #ecf0f1;\n  margin-top: 0;\n  padding: 36px 0 0 0;\n}\n\n.footer-content {\n  width: 80%;\n  max-width: 1200px;\n  margin: 0 auto;\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 40px;\n  padding-bottom: 30px;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.footer-section {\n  padding: 0 20px;\n}\n\n.section-title {\n  font-size: 18px;\n  font-weight: 600;\n  color: #fff;\n  margin: 0 0 20px 0;\n  padding-bottom: 10px;\n  border-bottom: 2px solid #457b9d;\n  display: inline-block;\n}\n\n.section-text {\n  color: #bdc3c7;\n  line-height: 1.8;\n  font-size: 14px;\n  margin: 0;\n}\n\n.link-list {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n\n.footer-link {\n  color: #bdc3c7;\n  text-decoration: none;\n  font-size: 14px;\n  transition: all 0.3s;\n  display: inline-block;\n}\n\n.footer-link:hover {\n  color: #a8dadc;\n  transform: translateX(5px);\n}\n\n.contact-list {\n  display: flex;\n  flex-direction: column;\n  gap: 15px;\n}\n\n.contact-item {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  color: #bdc3c7;\n  font-size: 14px;\n  margin: 0;\n}\n\n.contact-item i {\n  font-size: 16px;\n  color: #a8dadc;\n}\n\n.footer-bottom {\n  padding: 20px 0;\n  text-align: center;\n  background: rgba(0, 0, 0, 0.2);\n}\n\n.copyright {\n  color: #95a5a6;\n  font-size: 13px;\n  margin: 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 8px;\n}\n\n.copyright i {\n  font-size: 14px;\n}\n\n/* 响应式设计 */\n@media (max-width: 1024px) {\n  .footer-content {\n    width: 90%;\n    grid-template-columns: repeat(2, 1fr);\n  }\n  \n  .footer-section:last-child {\n    grid-column: span 2;\n  }\n}\n\n@media (max-width: 768px) {\n  .footer-container {\n    padding: 30px 0 0 0;\n  }\n  \n  .footer-content {\n    width: 100%;\n    grid-template-columns: 1fr;\n    gap: 30px;\n    padding: 0 20px 20px 20px;\n  }\n  \n  .footer-section {\n    padding: 0;\n  }\n  \n  .footer-section:last-child {\n    grid-column: span 1;\n  }\n  \n  .section-title {\n    font-size: 16px;\n  }\n}\n</style>\n"],"mappings":"AA2CA;EACAA,IAAA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}