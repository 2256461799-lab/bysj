{"ast":null,"code":"export default {\n  name: \"ManagerReport\",\n  data() {\n    return {\n      type: '',\n      title: '',\n      status: '',\n      tableData: [],\n      pageNum: 1,\n      pageSize: 10,\n      total: 0,\n      form: {},\n      viewDialogVisible: false,\n      processDialogVisible: false,\n      ids: []\n    };\n  },\n  created() {\n    this.load(1);\n  },\n  methods: {\n    load(pageNum) {\n      if (pageNum) this.pageNum = pageNum;\n      this.$request.get('/report/selectPage', {\n        params: {\n          pageNum: this.pageNum,\n          pageSize: this.pageSize,\n          type: this.type || null,\n          title: this.title || null,\n          status: this.status || null\n        }\n      }).then(res => {\n        this.tableData = res.data?.list || [];\n        this.total = res.data?.total || 0;\n      });\n    },\n    reset() {\n      this.type = '';\n      this.title = '';\n      this.status = '';\n      this.load(1);\n    },\n    handleView(row) {\n      this.form = JSON.parse(JSON.stringify(row));\n      this.viewDialogVisible = true;\n    },\n    // 修复：打开弹窗强制赋值\n    handleProcess(row) {\n      this.form = JSON.parse(JSON.stringify(row));\n      this.form.status = \"已处理\"; // 强制默认已处理\n      if (!this.form.handler) this.form.handler = '';\n      if (!this.form.handleResult) this.form.handleResult = '';\n      this.processDialogVisible = true;\n    },\n    // 修复：提交时强制传值\n    saveProcess() {\n      if (!this.form.handler) return this.$message.warning('请输入处理人');\n      if (!this.form.handleResult) return this.$message.warning('请输入处理结果');\n\n      // 格式化时间\n      const now = new Date();\n      const year = now.getFullYear();\n      const month = String(now.getMonth() + 1).padStart(2, '0');\n      const day = String(now.getDate()).padStart(2, '0');\n      const hours = String(now.getHours()).padStart(2, '0');\n      const minutes = String(now.getMinutes()).padStart(2, '0');\n      const seconds = String(now.getSeconds()).padStart(2, '0');\n      const handleTime = `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;\n\n      // 构造提交对象\n      const submitData = {\n        id: this.form.id,\n        status: \"已处理\",\n        // 强制写死\n        handler: this.form.handler,\n        handleResult: this.form.handleResult,\n        handleTime: handleTime\n      };\n      this.$request.put('/report/update', submitData).then(res => {\n        if (res.code === '200') {\n          this.$message.success('处理成功');\n          this.processDialogVisible = false;\n          this.load(this.pageNum);\n        } else {\n          this.$message.error(res.msg || '处理失败');\n        }\n      });\n    },\n    del(id) {\n      this.$confirm('您确定删除吗？', '确认删除', {\n        type: \"warning\"\n      }).then(() => {\n        this.$request.delete('/report/delete/' + id).then(res => {\n          if (res.code === '200') {\n            this.$message.success('删除成功');\n            this.load(1);\n          } else {\n            this.$message.error(res.msg);\n          }\n        });\n      }).catch(() => {});\n    },\n    handleSelectionChange(rows) {\n      this.ids = rows.map(v => v.id);\n    },\n    delBatch() {\n      if (!this.ids.length) {\n        this.$message.warning('请选择数据');\n        return;\n      }\n      this.$confirm('您确定批量删除这些记录吗？', '确认删除', {\n        type: \"warning\"\n      }).then(() => {\n        this.$request.delete('/report/delete/batch', {\n          data: this.ids\n        }).then(res => {\n          if (res.code === '200') {\n            this.$message.success('删除成功');\n            this.load(1);\n          } else {\n            this.$message.error(res.msg);\n          }\n        });\n      }).catch(() => {});\n    },\n    handleCurrentChange(pageNum) {\n      this.load(pageNum);\n    },\n    previewImage(url) {\n      window.open(url);\n    }\n  }\n};","map":{"version":3,"names":["name","data","type","title","status","tableData","pageNum","pageSize","total","form","viewDialogVisible","processDialogVisible","ids","created","load","methods","$request","get","params","then","res","list","reset","handleView","row","JSON","parse","stringify","handleProcess","handler","handleResult","saveProcess","$message","warning","now","Date","year","getFullYear","month","String","getMonth","padStart","day","getDate","hours","getHours","minutes","getMinutes","seconds","getSeconds","handleTime","submitData","id","put","code","success","error","msg","del","$confirm","delete","catch","handleSelectionChange","rows","map","v","delBatch","length","handleCurrentChange","previewImage","url","window","open"],"sources":["src/views/manager/Report.vue"],"sourcesContent":["<template>\n  <div>\n    <!-- 搜索区域 -->\n    <div style=\"margin: 10px 0\">\n      <el-input v-model=\"type\" placeholder=\"请输入上报类型\" style=\"width: 200px\" clearable></el-input>\n      <el-input v-model=\"title\" placeholder=\"请输入标题\" style=\"width: 200px; margin-left: 5px\" clearable></el-input>\n      <el-select v-model=\"status\" placeholder=\"请选择状态\" style=\"width: 150px; margin-left: 5px\" clearable>\n        <el-option label=\"待处理\" value=\"待处理\"></el-option>\n        <el-option label=\"处理中\" value=\"处理中\"></el-option>\n        <el-option label=\"已处理\" value=\"已处理\"></el-option>\n        <el-option label=\"已关闭\" value=\"已关闭\"></el-option>\n      </el-select>\n      <el-button type=\"primary\" style=\"margin-left: 5px\" @click=\"load(1)\">查询</el-button>\n      <el-button type=\"warning\" style=\"margin-left: 5px\" @click=\"reset\">重置</el-button>\n    </div>\n\n    <!-- 操作按钮区域 -->\n    <div style=\"margin: 10px 0\">\n      <el-button type=\"danger\" @click=\"delBatch\">批量删除</el-button>\n    </div>\n\n    <!-- 表格区域 -->\n    <el-table :data=\"tableData\" stripe @selection-change=\"handleSelectionChange\">\n      <el-table-column type=\"selection\" width=\"55\"></el-table-column>\n      <el-table-column prop=\"id\" label=\"ID\" width=\"60\"></el-table-column>\n      <el-table-column prop=\"type\" label=\"上报类型\" width=\"100\">\n        <template slot-scope=\"scope\">\n          <el-tag v-if=\"scope.row.type === '安全隐患'\" type=\"info\">{{ scope.row.type }}</el-tag>\n          <el-tag v-else type=\"warning\">{{ scope.row.type }}</el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column prop=\"title\" label=\"标题\" width=\"200\" show-overflow-tooltip></el-table-column>\n      <el-table-column prop=\"contactName\" label=\"联系人\" width=\"100\"></el-table-column>\n      <el-table-column prop=\"contactPhone\" label=\"联系电话\" width=\"120\"></el-table-column>\n      <el-table-column prop=\"address\" label=\"详细地址\" width=\"200\" show-overflow-tooltip></el-table-column>\n      <el-table-column prop=\"amount\" label=\"涉及人数\" width=\"100\">\n        <template slot-scope=\"scope\">\n          <span v-if=\"scope.row.amount\" style=\"color: #F56C6C\">{{ scope.row.amount }}人</span>\n          <span v-else>-</span>\n        </template>\n      </el-table-column>\n      <el-table-column prop=\"reportTime\" label=\"上报时间\" width=\"160\"></el-table-column>\n      <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\n        <template slot-scope=\"scope\">\n          <el-tag v-if=\"scope.row.status === '待处理'\" type=\"danger\">{{ scope.row.status }}</el-tag>\n          <el-tag v-else-if=\"scope.row.status === '处理中'\" type=\"warning\">{{ scope.row.status }}</el-tag>\n          <el-tag v-else-if=\"scope.row.status === '已处理'\" type=\"success\">{{ scope.row.status }}</el-tag>\n          <el-tag v-else type=\"info\">{{ scope.row.status }}</el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"操作\" width=\"280\" fixed=\"right\">\n        <template slot-scope=\"scope\">\n          <el-button size=\"mini\" type=\"primary\" @click=\"handleView(scope.row)\">查看</el-button>\n          <el-button size=\"mini\" type=\"success\" @click=\"handleProcess(scope.row)\">处理</el-button>\n          <el-button size=\"mini\" type=\"danger\" @click=\"del(scope.row.id)\">删除</el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n\n    <!-- 分页 -->\n    <div style=\"margin: 10px 0\">\n      <el-pagination\n        @current-change=\"handleCurrentChange\"\n        :current-page=\"pageNum\"\n        :page-size=\"pageSize\"\n        layout=\"total, prev, pager, next\"\n        :total=\"total\">\n      </el-pagination>\n    </div>\n\n    <!-- 查看详情对话框 -->\n    <el-dialog title=\"上报详情\" :visible.sync=\"viewDialogVisible\" width=\"60%\" :close-on-click-modal=\"false\">\n      <el-descriptions :column=\"2\" border>\n        <el-descriptions-item label=\"上报类型\">\n          <el-tag v-if=\"form.type === '安全隐患'\" type=\"info\">{{ form.type }}</el-tag>\n          <el-tag v-else type=\"warning\">{{ form.type }}</el-tag>\n        </el-descriptions-item>\n        <el-descriptions-item label=\"状态\">\n          <el-tag v-if=\"form.status === '待处理'\" type=\"danger\">{{ form.status }}</el-tag>\n          <el-tag v-else-if=\"form.status === '处理中'\" type=\"warning\">{{ form.status }}</el-tag>\n          <el-tag v-else-if=\"form.status === '已处理'\" type=\"success\">{{ form.status }}</el-tag>\n          <el-tag v-else type=\"info\">{{ form.status }}</el-tag>\n        </el-descriptions-item>\n        <el-descriptions-item label=\"上报标题\" :span=\"2\">{{ form.title }}</el-descriptions-item>\n        <el-descriptions-item label=\"详细内容\" :span=\"2\">\n          <div v-html=\"form.content\" style=\"max-height: 300px; overflow-y: auto\"></div>\n        </el-descriptions-item>\n        <el-descriptions-item label=\"联系人\">{{ form.contactName }}</el-descriptions-item>\n        <el-descriptions-item label=\"联系电话\">{{ form.contactPhone }}</el-descriptions-item>\n        <el-descriptions-item label=\"详细地址\" :span=\"2\">{{ form.address || '-' }}</el-descriptions-item>\n        <el-descriptions-item label=\"涉及地点\" :span=\"2\">{{ form.suspectPhone || '-' }}</el-descriptions-item>\n        <el-descriptions-item label=\"所属网格\" :span=\"2\">{{ form.suspectAccount || '-' }}</el-descriptions-item>\n        <el-descriptions-item label=\"关联信息\" :span=\"2\">{{ form.suspectLink || '-' }}</el-descriptions-item>\n        <el-descriptions-item label=\"涉及人数\" :span=\"2\">\n          <span v-if=\"form.amount\" style=\"color: #F56C6C; font-weight: bold\">{{ form.amount }} 人</span>\n          <span v-else>-</span>\n        </el-descriptions-item>\n        <el-descriptions-item label=\"证据材料\" :span=\"2\">\n          <div v-if=\"form.evidence\">\n            <img v-for=\"(img, index) in form.evidence.split(',')\" :key=\"index\" \n                 :src=\"img\" style=\"width: 100px; height: 100px; margin-right: 10px; cursor: pointer\"\n                 @click=\"previewImage(img)\">\n          </div>\n          <span v-else>-</span>\n        </el-descriptions-item>\n        <el-descriptions-item label=\"上报时间\" :span=\"2\">{{ form.reportTime }}</el-descriptions-item>\n        <el-descriptions-item label=\"处理人\">{{ form.handler || '-' }}</el-descriptions-item>\n        <el-descriptions-item label=\"处理时间\">{{ form.handleTime || '-' }}</el-descriptions-item>\n        <el-descriptions-item label=\"处理结果\" :span=\"2\">\n          <div v-html=\"form.handleResult || '-'\" style=\"max-height: 200px; overflow-y: auto\"></div>\n        </el-descriptions-item>\n      </el-descriptions>\n      <div slot=\"footer\">\n        <el-button @click=\"viewDialogVisible = false\">关闭</el-button>\n      </div>\n    </el-dialog>\n\n    <!-- 处理对话框 -->\n    <el-dialog title=\"处理上报\" :visible.sync=\"processDialogVisible\" width=\"50%\" :close-on-click-modal=\"false\">\n      <el-form :model=\"form\" label-width=\"100px\">\n        <el-form-item label=\"上报标题\">\n          <span>{{ form.title }}</span>\n        </el-form-item>\n        <el-form-item label=\"处理状态\">\n          <el-select v-model=\"form.status\" placeholder=\"请选择状态\" style=\"width: 100%\">\n            <el-option label=\"待处理\" value=\"待处理\"></el-option>\n            <el-option label=\"处理中\" value=\"处理中\"></el-option>\n            <el-option label=\"已处理\" value=\"已处理\"></el-option>\n            <el-option label=\"已关闭\" value=\"已关闭\"></el-option>\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"处理人\">\n          <el-input v-model=\"form.handler\" placeholder=\"请输入处理人姓名\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"处理结果\">\n          <el-input type=\"textarea\" v-model=\"form.handleResult\" :rows=\"6\" \n                    placeholder=\"请输入处理结果和反馈意见\"></el-input>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\">\n        <el-button @click=\"processDialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"saveProcess\">保存</el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"ManagerReport\",\n  data() {\n    return {\n      type: '',\n      title: '',\n      status: '',\n      tableData: [],\n      pageNum: 1,\n      pageSize: 10,\n      total: 0,\n      form: {},\n      viewDialogVisible: false,\n      processDialogVisible: false,\n      ids: []\n    }\n  },\n  created() {\n    this.load(1)\n  },\n  methods: {\n    load(pageNum) {\n      if (pageNum) this.pageNum = pageNum\n      this.$request.get('/report/selectPage', {\n        params: {\n          pageNum: this.pageNum,\n          pageSize: this.pageSize,\n          type: this.type || null,\n          title: this.title || null,\n          status: this.status || null\n        }\n      }).then(res => {\n        this.tableData = res.data?.list || []\n        this.total = res.data?.total || 0\n      })\n    },\n    reset() {\n      this.type = ''\n      this.title = ''\n      this.status = ''\n      this.load(1)\n    },\n    handleView(row) {\n      this.form = JSON.parse(JSON.stringify(row))\n      this.viewDialogVisible = true\n    },\n    // 修复：打开弹窗强制赋值\n    handleProcess(row) {\n      this.form = JSON.parse(JSON.stringify(row))\n      this.form.status = \"已处理\" // 强制默认已处理\n      if (!this.form.handler) this.form.handler = ''\n      if (!this.form.handleResult) this.form.handleResult = ''\n      this.processDialogVisible = true\n    },\n    // 修复：提交时强制传值\n    saveProcess() {\n      if (!this.form.handler) return this.$message.warning('请输入处理人')\n      if (!this.form.handleResult) return this.$message.warning('请输入处理结果')\n\n      // 格式化时间\n      const now = new Date()\n      const year = now.getFullYear()\n      const month = String(now.getMonth() + 1).padStart(2, '0')\n      const day = String(now.getDate()).padStart(2, '0')\n      const hours = String(now.getHours()).padStart(2, '0')\n      const minutes = String(now.getMinutes()).padStart(2, '0')\n      const seconds = String(now.getSeconds()).padStart(2, '0')\n      const handleTime = `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`\n\n      // 构造提交对象\n      const submitData = {\n        id: this.form.id,\n        status: \"已处理\", // 强制写死\n        handler: this.form.handler,\n        handleResult: this.form.handleResult,\n        handleTime: handleTime\n      }\n\n      this.$request.put('/report/update', submitData).then(res => {\n        if (res.code === '200') {\n          this.$message.success('处理成功')\n          this.processDialogVisible = false\n          this.load(this.pageNum)\n        } else {\n          this.$message.error(res.msg || '处理失败')\n        }\n      })\n    },\n    del(id) {\n      this.$confirm('您确定删除吗？', '确认删除', {type: \"warning\"}).then(() => {\n        this.$request.delete('/report/delete/' + id).then(res => {\n          if (res.code === '200') {\n            this.$message.success('删除成功')\n            this.load(1)\n          } else {\n            this.$message.error(res.msg)\n          }\n        })\n      }).catch(() => {})\n    },\n    handleSelectionChange(rows) {\n      this.ids = rows.map(v => v.id)\n    },\n    delBatch() {\n      if (!this.ids.length) {\n        this.$message.warning('请选择数据')\n        return\n      }\n      this.$confirm('您确定批量删除这些记录吗？', '确认删除', {type: \"warning\"}).then(() => {\n        this.$request.delete('/report/delete/batch', {data: this.ids}).then(res => {\n          if (res.code === '200') {\n            this.$message.success('删除成功')\n            this.load(1)\n          } else {\n            this.$message.error(res.msg)\n          }\n        })\n      }).catch(() => {})\n    },\n    handleCurrentChange(pageNum) {\n      this.load(pageNum)\n    },\n    previewImage(url) {\n      window.open(url)\n    }\n  }\n}\n</script>\n\n<style scoped>\n</style>"],"mappings":"AAoJA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,IAAA;MACAC,KAAA;MACAC,MAAA;MACAC,SAAA;MACAC,OAAA;MACAC,QAAA;MACAC,KAAA;MACAC,IAAA;MACAC,iBAAA;MACAC,oBAAA;MACAC,GAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,IAAA;EACA;EACAC,OAAA;IACAD,KAAAR,OAAA;MACA,IAAAA,OAAA,OAAAA,OAAA,GAAAA,OAAA;MACA,KAAAU,QAAA,CAAAC,GAAA;QACAC,MAAA;UACAZ,OAAA,OAAAA,OAAA;UACAC,QAAA,OAAAA,QAAA;UACAL,IAAA,OAAAA,IAAA;UACAC,KAAA,OAAAA,KAAA;UACAC,MAAA,OAAAA,MAAA;QACA;MACA,GAAAe,IAAA,CAAAC,GAAA;QACA,KAAAf,SAAA,GAAAe,GAAA,CAAAnB,IAAA,EAAAoB,IAAA;QACA,KAAAb,KAAA,GAAAY,GAAA,CAAAnB,IAAA,EAAAO,KAAA;MACA;IACA;IACAc,MAAA;MACA,KAAApB,IAAA;MACA,KAAAC,KAAA;MACA,KAAAC,MAAA;MACA,KAAAU,IAAA;IACA;IACAS,WAAAC,GAAA;MACA,KAAAf,IAAA,GAAAgB,IAAA,CAAAC,KAAA,CAAAD,IAAA,CAAAE,SAAA,CAAAH,GAAA;MACA,KAAAd,iBAAA;IACA;IACA;IACAkB,cAAAJ,GAAA;MACA,KAAAf,IAAA,GAAAgB,IAAA,CAAAC,KAAA,CAAAD,IAAA,CAAAE,SAAA,CAAAH,GAAA;MACA,KAAAf,IAAA,CAAAL,MAAA;MACA,UAAAK,IAAA,CAAAoB,OAAA,OAAApB,IAAA,CAAAoB,OAAA;MACA,UAAApB,IAAA,CAAAqB,YAAA,OAAArB,IAAA,CAAAqB,YAAA;MACA,KAAAnB,oBAAA;IACA;IACA;IACAoB,YAAA;MACA,UAAAtB,IAAA,CAAAoB,OAAA,cAAAG,QAAA,CAAAC,OAAA;MACA,UAAAxB,IAAA,CAAAqB,YAAA,cAAAE,QAAA,CAAAC,OAAA;;MAEA;MACA,MAAAC,GAAA,OAAAC,IAAA;MACA,MAAAC,IAAA,GAAAF,GAAA,CAAAG,WAAA;MACA,MAAAC,KAAA,GAAAC,MAAA,CAAAL,GAAA,CAAAM,QAAA,QAAAC,QAAA;MACA,MAAAC,GAAA,GAAAH,MAAA,CAAAL,GAAA,CAAAS,OAAA,IAAAF,QAAA;MACA,MAAAG,KAAA,GAAAL,MAAA,CAAAL,GAAA,CAAAW,QAAA,IAAAJ,QAAA;MACA,MAAAK,OAAA,GAAAP,MAAA,CAAAL,GAAA,CAAAa,UAAA,IAAAN,QAAA;MACA,MAAAO,OAAA,GAAAT,MAAA,CAA