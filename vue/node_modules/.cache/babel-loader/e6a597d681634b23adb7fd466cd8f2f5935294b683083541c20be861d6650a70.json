{"ast":null,"code":"export default {\n  name: \"Index\",\n  data() {\n    return {\n      lawList: [],\n      chapterList: []\n    };\n  },\n  created() {\n    this.loadLawList();\n    this.loadChapterList();\n  },\n  methods: {\n    loadLawList() {\n      this.$request.get(\"/law/list\").then(res => {\n        this.lawList = res.data;\n      });\n    },\n    loadChapterList() {\n      this.$request.get(\"/chapter/list\").then(res => {\n        this.chapterList = res.data;\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","lawList","chapterList","created","loadLawList","loadChapterList","methods","$request","get","then","res"],"sources":["src/views/front/Home.vue"],"sourcesContent":["<template>\r\n  <div class=\"home-page\">\r\n    <div class=\"banner\">\r\n      <div class=\"banner-content\">\r\n        <h1>基层依法治理网格化综合服务系统</h1>\r\n        <p>推进基层社会治理现代化 · 构建共建共治共享新格局</p>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 功能模块 -->\r\n    <div class=\"module-container\">\r\n      <div class=\"module-item\" @click=\"$router.push('/front/law')\">\r\n        <div class=\"icon law-icon\"></div>\r\n        <h3>法律法规</h3>\r\n        <p>政策解读与法规动态</p>\r\n      </div>\r\n      <div class=\"module-item\" @click=\"$router.push('/front/knowledge')\">\r\n        <div class=\"icon knowledge-icon\"></div>\r\n        <h3>治理案例库</h3>\r\n        <p>典型案例与治理指南</p>\r\n      </div>\r\n      <div class=\"module-item\" @click=\"$router.push('/front/blog')\">\r\n        <div class=\"icon blog-icon\"></div>\r\n        <h3>工作交流</h3>\r\n        <p>网格员经验分享</p>\r\n      </div>\r\n      <div class=\"module-item\" @click=\"$router.push('/front/activity')\">\r\n        <div class=\"icon activity-icon\"></div>\r\n        <h3>任务中心</h3>\r\n        <p>治理任务与活动</p>\r\n      </div>\r\n      <div class=\"module-item\" @click=\"$router.push('/front/learningClass')\">\r\n        <div class=\"icon class-icon\"></div>\r\n        <h3>法治培训</h3>\r\n        <p>在线学习培训课程</p>\r\n      </div>\r\n      <div class=\"module-item\" @click=\"$router.push('/front/report')\">\r\n        <div class=\"icon report-icon\"></div>\r\n        <h3>事件上报</h3>\r\n        <p>网格事件在线上报</p>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 内容区域 -->\r\n    <div class=\"content-wrapper\">\r\n      <div class=\"content-left\">\r\n        <h2>最新法律法规</h2>\r\n        <div class=\"law-list\">\r\n          <div class=\"law-item\" v-for=\"item in lawList\" :key=\"item.id\" @click=\"$router.push(`/front/lawDetail?id=${item.id}`)\">\r\n            <h4>{{ item.title }}</h4>\r\n            <p class=\"date\">{{ item.publishTime }}</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"content-right\">\r\n        <h2>最新培训课程</h2>\r\n        <div class=\"class-list\">\r\n          <div class=\"class-item\" v-for=\"item in chapterList\" :key=\"item.id\">\r\n            <h4>{{ item.title }}</h4>\r\n            <span>{{ item.lessonCount }}课时</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"Index\",\r\n  data() {\r\n    return {\r\n      lawList: [],\r\n      chapterList: []\r\n    }\r\n  },\r\n  created() {\r\n    this.loadLawList()\r\n    this.loadChapterList()\r\n  },\r\n  methods: {\r\n    loadLawList() {\r\n      this.$request.get(\"/law/list\").then(res => {\r\n        this.lawList = res.data\r\n      })\r\n    },\r\n    loadChapterList() {\r\n      this.$request.get(\"/chapter/list\").then(res => {\r\n        this.chapterList = res.data\r\n      })\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 你最原始的样式，全部还原！ */\r\n.index-page {\r\n  width: 100%;\r\n  min-height: 100%;\r\n  background: #f5f7fa;\r\n}\r\n.banner {\r\n  width: 100%;\r\n  height: 380px;\r\n  background: linear-gradient(135deg, #1f51ff, #3a7cff);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  color: white;\r\n  text-align: center;\r\n}\r\n.banner h1 {\r\n  font-size: 36px;\r\n  margin-bottom: 15px;\r\n}\r\n.banner p {\r\n  font-size: 16px;\r\n  opacity: 0.9;\r\n}\r\n.module-container {\r\n  max-width: 1200px;\r\n  margin: -80px auto 0;\r\n  display: grid;\r\n  grid-template-columns: repeat(3, 1fr);\r\n  gap: 20px;\r\n  padding: 0 20px;\r\n  position: relative;\r\n  z-index: 10;\r\n}\r\n.module-item {\r\n  background: white;\r\n  padding: 30px 20px;\r\n  border-radius: 12px;\r\n  box-shadow: 0 4px 20px rgba(0,0,0,0.08);\r\n  text-align: center;\r\n  cursor: pointer;\r\n  transition: all 0.3s;\r\n}\r\n.module-item:hover {\r\n  transform: translateY(-5px);\r\n}\r\n.icon {\r\n  width: 50px;\r\n  height: 50px;\r\n  margin: 0 auto 15px;\r\n  border-radius: 8px;\r\n}\r\n.law-icon { background: #e6f7ff; }\r\n.blog-icon { background: #f0f7ff; }\r\n.activity-icon { background: #fff7e6; }\r\n.class-icon { background: #f6ffed; }\r\n.report-icon { background: #fff1f0; }\r\n.knowledge-icon { background: #f9f0ff; }\r\n\r\n.content-wrapper {\r\n  max-width: 1200px;\r\n  margin: 60px auto;\r\n  padding: 0 20px;\r\n  display: flex;\r\n  gap: 30px;\r\n}\r\n.content-left {\r\n  flex: 2;\r\n  background: white;\r\n  padding: 25px;\r\n  border-radius: 12px;\r\n  box-shadow: 0 2px 12px rgba(0,0,0,0.05);\r\n}\r\n.content-right {\r\n  flex: 1;\r\n  background: white;\r\n  padding: 25px;\r\n  border-radius: 12px;\r\n  box-shadow: 0 2px 12px rgba(0,0,0,0.05);\r\n}\r\nh2 {\r\n  font-size: 18px;\r\n  margin-bottom: 20px;\r\n  padding-bottom: 10px;\r\n  border-bottom: 2px solid #1f51ff;\r\n}\r\n.law-item, .class-item {\r\n  padding: 12px 0;\r\n  border-bottom: 1px solid #eee;\r\n  cursor: pointer;\r\n}\r\n.law-item h4, .class-item h4 {\r\n  font-size: 15px;\r\n  margin: 0;\r\n  color: #333;\r\n}\r\n.date {\r\n  font-size: 12px;\r\n  color: #999;\r\n  margin-top: 5px;\r\n}\r\n</style>"],"mappings":"AAoEA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,WAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,WAAA;IACA,KAAAC,eAAA;EACA;EACAC,OAAA;IACAF,YAAA;MACA,KAAAG,QAAA,CAAAC,GAAA,cAAAC,