{"ast":null,"code":"export default {\n  name: 'Home',\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\n      currentDate: '',\n      notices: [],\n      stats: {\n        userCount: 0,\n        blogCount: 0,\n        activityCount: 0,\n        reportCount: 0,\n        reportPending: 0,\n        antifraudCount: 0,\n        knowledgeCount: 0,\n        lessonCount: 0,\n        questionCount: 0,\n        todayVisit: 0,\n        commentCount: 0,\n        signCount: 0,\n        onlineUsers: 0\n      }\n    };\n  },\n  created() {\n    this.getCurrentDate();\n    this.loadNotices();\n    this.loadStats();\n  },\n  methods: {\n    getCurrentDate() {\n      const now = new Date();\n      const days = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'];\n      const year = now.getFullYear();\n      const month = now.getMonth() + 1;\n      const day = now.getDate();\n      const weekDay = days[now.getDay()];\n      this.currentDate = `${year}年${month}月${day}日 ${weekDay}`;\n    },\n    loadNotices() {\n      this.$request.get('/notice/selectAll').then(res => {\n        this.notices = res.data || [];\n      });\n    },\n    loadStats() {\n      // 加载用户统计\n      this.$request.get('/user/selectPage', {\n        params: {\n          pageNum: 1,\n          pageSize: 1\n        }\n      }).then(res => {\n        this.stats.userCount = res.data?.total || 0;\n      }).catch(() => {\n        this.stats.userCount = 0;\n      });\n\n      // 加载日志统计\n      this.$request.get('/blog/selectPage', {\n        params: {\n          pageNum: 1,\n          pageSize: 1\n        }\n      }).then(res => {\n        this.stats.blogCount = res.data?.total || 0;\n      }).catch(() => {\n        this.stats.blogCount = 0;\n      });\n\n      // 加载活动统计\n      this.$request.get('/activity/selectPage', {\n        params: {\n          pageNum: 1,\n          pageSize: 1\n        }\n      }).then(res => {\n        this.stats.activityCount = res.data?.total || 0;\n      }).catch(() => {\n        this.stats.activityCount = 0;\n      });\n\n      // 加载上报统计\n      this.$request.get('/report/selectPage', {\n        params: {\n          pageNum: 1,\n          pageSize: 999\n        }\n      }).then(res => {\n        const reports = res.data?.list || [];\n        this.stats.reportCount = res.data?.total || 0;\n        this.stats.reportPending = reports.filter(r => r.status === '待处理').length;\n      }).catch(() => {\n        this.stats.reportCount = 0;\n        this.stats.reportPending = 0;\n      });\n\n      // 加载法律法规统计\n      this.$request.get('/antifraud/selectPage', {\n        params: {\n          pageNum: 1,\n          pageSize: 1\n        }\n      }).then(res => {\n        this.stats.antifraudCount = res.data?.total || 0;\n      }).catch(() => {\n        this.stats.antifraudCount = 0;\n      });\n\n      // 加载知识库统计\n      this.$request.get('/knowledge/selectPage', {\n        params: {\n          pageNum: 1,\n          pageSize: 1\n        }\n      }).then(res => {\n        this.stats.knowledgeCount = res.data?.total || 0;\n      }).catch(() => {\n        this.stats.knowledgeCount = 0;\n      });\n\n      // 加载课时统计\n      this.$request.get('/lesson/selectPage', {\n        params: {\n          pageNum: 1,\n          pageSize: 1\n        }\n      }).then(res => {\n        this.stats.lessonCount = res.data?.total || 0;\n      }).catch(() => {\n        this.stats.lessonCount = 0;\n      });\n\n      // 加载题目统计\n      this.$request.get('/question/selectPage', {\n        params: {\n          pageNum: 1,\n          pageSize: 1\n        }\n      }).then(res => {\n        this.stats.questionCount = res.data?.total || 0;\n      }).catch(() => {\n        this.stats.questionCount = 0;\n      });\n\n      // 加载评论统计\n      this.$request.get('/comment/selectPage', {\n        params: {\n          pageNum: 1,\n          pageSize: 1\n        }\n      }).then(res => {\n        this.stats.commentCount = res.data?.total || 0;\n      }).catch(() => {\n        this.stats.commentCount = 0;\n      });\n\n      // 加载报名统计\n      this.$request.get('/activitySign/selectPage', {\n        params: {\n          pageNum: 1,\n          pageSize: 1\n        }\n      }).then(res => {\n        this.stats.signCount = res.data?.total || 0;\n      }).catch(() => {\n        this.stats.signCount = 0;\n      });\n\n      // 模拟其他数据\n      this.stats.todayVisit = Math.floor(Math.random() * 500) + 100;\n      this.stats.onlineUsers = Math.floor(Math.random() * 50) + 10;\n    }\n  }\n};","map":{"version":3,"names":["name","data","user","JSON","parse","localStorage","getItem","currentDate","notices","stats","userCount","blogCount","activityCount","reportCount","reportPending","antifraudCount","knowledgeCount","lessonCount","questionCount","todayVisit","commentCount","signCount","onlineUsers","created","getCurrentDate","loadNotices","loadStats","methods","now","Date","days","year","getFullYear","month","getMonth","day","getDate","weekDay","getDay","$request","get","then","res","params","pageNum","pageSize","total","catch","reports","list","filter","r","status","length","Math","floor","random"],"sources":["src/views/manager/Home.vue"],"sourcesContent":["<template>\n  <div class=\"home-container\">\n    <!-- 欢迎信息 -->\n    <div class=\"welcome-card\">\n      <div class=\"welcome-text\">\n        <h2>欢迎回来，{{ user?.name }}</h2>\n        <p>{{ currentDate }}</p>\n      </div>\n    </div>\n\n    <!-- 数据统计卡片 -->\n    <div class=\"stats-grid\">\n      <div class=\"stat-card\">\n        <div class=\"stat-header\">\n          <span class=\"stat-label\">网格员总数</span>\n        </div>\n        <div class=\"stat-value\">{{ stats.userCount || 0 }}</div>\n      </div>\n\n      <div class=\"stat-card\">\n        <div class=\"stat-header\">\n          <span class=\"stat-label\">工作日志</span>\n        </div>\n        <div class=\"stat-value\">{{ stats.blogCount || 0 }}</div>\n      </div>\n\n      <div class=\"stat-card\">\n        <div class=\"stat-header\">\n          <span class=\"stat-label\">治理任务</span>\n        </div>\n        <div class=\"stat-value\">{{ stats.activityCount || 0 }}</div>\n      </div>\n\n      <div class=\"stat-card\">\n        <div class=\"stat-header\">\n          <span class=\"stat-label\">事件上报</span>\n        </div>\n        <div class=\"stat-value\">{{ stats.reportCount || 0 }}</div>\n        <div class=\"stat-footer\">\n          <span class=\"stat-trend warning\" v-if=\"stats.reportPending > 0\">\n            待处理 {{ stats.reportPending || 0 }}\n          </span>\n        </div>\n      </div>\n    </div>\n\n    <!-- 详细数据 -->\n    <div class=\"detail-grid\">\n      <!-- 治理数据统计 -->\n      <div class=\"detail-card\">\n        <div class=\"detail-header\">\n          <h3>治理数据统计</h3>\n        </div>\n        <div class=\"detail-content\">\n          <div class=\"data-row\">\n            <span class=\"data-label\">法律法规</span>\n            <span class=\"data-value\">{{ stats.antifraudCount || 0 }} 篇</span>\n          </div>\n          <div class=\"data-row\">\n            <span class=\"data-label\">案例库文章</span>\n            <span class=\"data-value\">{{ stats.knowledgeCount || 0 }} 篇</span>\n          </div>\n          <div class=\"data-row\">\n            <span class=\"data-label\">培训课程</span>\n            <span class=\"data-value\">{{ stats.lessonCount || 0 }} 个</span>\n          </div>\n          <div class=\"data-row\">\n            <span class=\"data-label\">题目总数</span>\n            <span class=\"data-value\">{{ stats.questionCount || 0 }} 道</span>\n          </div>\n        </div>\n      </div>\n\n      <!-- 用户活跃度 -->\n      <div class=\"detail-card\">\n        <div class=\"detail-header\">\n          <h3>用户活跃度</h3>\n        </div>\n        <div class=\"detail-content\">\n          <div class=\"data-row\">\n            <span class=\"data-label\">今日访问</span>\n            <span class=\"data-value\">{{ stats.todayVisit || 0 }} 次</span>\n          </div>\n          <div class=\"data-row\">\n            <span class=\"data-label\">评论总数</span>\n            <span class=\"data-value\">{{ stats.commentCount || 0 }} 条</span>\n          </div>\n          <div class=\"data-row\">\n            <span class=\"data-label\">任务签到</span>\n            <span class=\"data-value\">{{ stats.signCount || 0 }} 人</span>\n          </div>\n          <div class=\"data-row\">\n            <span class=\"data-label\">在线网格员</span>\n            <span class=\"data-value\">{{ stats.onlineUsers || 0 }} 人</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'Home',\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\n      currentDate: '',\n      notices: [],\n      stats: {\n        userCount: 0,\n        blogCount: 0,\n        activityCount: 0,\n        reportCount: 0,\n        reportPending: 0,\n        antifraudCount: 0,\n        knowledgeCount: 0,\n        lessonCount: 0,\n        questionCount: 0,\n        todayVisit: 0,\n        commentCount: 0,\n        signCount: 0,\n        onlineUsers: 0\n      }\n    }\n  },\n  created() {\n    this.getCurrentDate()\n    this.loadNotices()\n    this.loadStats()\n  },\n  methods: {\n    getCurrentDate() {\n      const now = new Date()\n      const days = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六']\n      const year = now.getFullYear()\n      const month = now.getMonth() + 1\n      const day = now.getDate()\n      const weekDay = days[now.getDay()]\n      this.currentDate = `${year}年${month}月${day}日 ${weekDay}`\n    },\n    loadNotices() {\n      this.$request.get('/notice/selectAll').then(res => {\n        this.notices = res.data || []\n      })\n    },\n    loadStats() {\n      // 加载用户统计\n      this.$request.get('/user/selectPage', {\n        params: { pageNum: 1, pageSize: 1 }\n      }).then(res => {\n        this.stats.userCount = res.data?.total || 0\n      }).catch(() => {\n        this.stats.userCount = 0\n      })\n\n      // 加载日志统计\n      this.$request.get('/blog/selectPage', {\n        params: { pageNum: 1, pageSize: 1 }\n      }).then(res => {\n        this.stats.blogCount = res.data?.total || 0\n      }).catch(() => {\n        this.stats.blogCount = 0\n      })\n\n      // 加载活动统计\n      this.$request.get('/activity/selectPage', {\n        params: { pageNum: 1, pageSize: 1 }\n      }).then(res => {\n        this.stats.activityCount = res.data?.total || 0\n      }).catch(() => {\n        this.stats.activityCount = 0\n      })\n\n      // 加载上报统计\n      this.$request.get('/report/selectPage', {\n        params: { pageNum: 1, pageSize: 999 }\n      }).then(res => {\n        const reports = res.data?.list || []\n        this.stats.reportCount = res.data?.total || 0\n        this.stats.reportPending = reports.filter(r => r.status === '待处理').length\n      }).catch(() => {\n        this.stats.reportCount = 0\n        this.stats.reportPending = 0\n      })\n\n      // 加载法律法规统计\n      this.$request.get('/antifraud/selectPage', {\n        params: { pageNum: 1, pageSize: 1 }\n      }).then(res => {\n        this.stats.antifraudCount = res.data?.total || 0\n      }).catch(() => {\n        this.stats.antifraudCount = 0\n      })\n\n      // 加载知识库统计\n      this.$request.get('/knowledge/selectPage', {\n        params: { pageNum: 1, pageSize: 1 }\n      }).then(res => {\n        this.stats.knowledgeCount = res.data?.total || 0\n      }).catch(() => {\n        this.stats.knowledgeCount = 0\n      })\n\n      // 加载课时统计\n      this.$request.get('/lesson/selectPage', {\n        params: { pageNum: 1, pageSize: 1 }\n      }).then(res => {\n        this.stats.lessonCount = res.data?.total || 0\n      }).catch(() => {\n        this.stats.lessonCount = 0\n      })\n\n      // 加载题目统计\n      this.$request.get('/question/selectPage', {\n        params: { pageNum: 1, pageSize: 1 }\n      }).then(res => {\n        this.stats.questionCount = res.data?.total || 0\n      }).catch(() => {\n        this.stats.questionCount = 0\n      })\n\n      // 加载评论统计\n      this.$request.get('/comment/selectPage', {\n        params: { pageNum: 1, pageSize: 1 }\n      }).then(res => {\n        this.stats.commentCount = res.data?.total || 0\n      }).catch(() => {\n        this.stats.commentCount = 0\n      })\n\n      // 加载报名统计\n      this.$request.get('/activitySign/selectPage', {\n        params: { pageNum: 1, pageSize: 1 }\n      }).then(res => {\n        this.stats.signCount = res.data?.total || 0\n      }).catch(() => {\n        this.stats.signCount = 0\n      })\n\n      // 模拟其他数据\n      this.stats.todayVisit = Math.floor(Math.random() * 500) + 100\n      this.stats.onlineUsers = Math.floor(Math.random() * 50) + 10\n    }\n  }\n}\n</script>\n\n<style scoped>\n/* 样式保持不变 */\n</style>"],"mappings":"AAsGA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,IAAA,EAAAC,IAAA,CAAAC,KAAA,CAAAC,YAAA,CAAAC,OAAA;MACAC,WAAA;MACAC,OAAA;MACAC,KAAA;QACAC,SAAA;QACAC,SAAA;QACAC,aAAA;QACAC,WAAA;QACAC,aAAA;QACAC,cAAA;QACAC,cAAA;QACAC,WAAA;QACAC,aAAA;QACAC,UAAA;QACAC,YAAA;QACAC,SAAA;QACAC,WAAA;MACA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,cAAA;IACA,KAAAC,WAAA;IACA,KAAAC,SAAA;EACA;EACAC,OAAA;IACAH,eAAA;MACA,MAAAI,GAAA,OAAAC,IAAA;MACA,MAAAC,IAAA;MACA,MAAAC,IAAA,GAAAH,GAAA,CAAAI,WAAA;MACA,MAAAC,KAAA,GAAAL,GAAA,CAAAM,QAAA;MACA,MAAAC,GAAA,GAAAP,GAAA,CAAAQ,OAAA;MACA,MAAAC,OAAA,GAAAP,IAAA,CAAAF,GAAA,CAAAU,MAAA;MACA,KAAA/B,WAAA,MAAAwB,IAAA,IAAAE,KAAA,IAAAE,GAAA,KAAAE,OAAA;IACA;IACAZ,YAAA;MACA,KAAAc,QAAA,CAAAC,GAAA,sBAAAC,IAAA,CAAAC,GAAA;QACA,KAAAlC,OAAA,GAAAkC,GAAA,CAAAzC,IAAA;MACA;IACA;IACAyB,UAAA;MACA;MACA,KAAAa,QAAA,CAAAC,GAAA;QACAG,MAAA;UAAAC,OAAA;UAAAC,QAAA;QAAA;MACA,GAAAJ,IAAA,CAAAC,GAAA;QACA,KAAAjC,KAAA,CAAAC,SAAA,GAAAgC,GAAA,CAAAzC,IAAA,EAAA6C,KAAA;MACA,GAAAC,KAAA;QACA,KAAAtC,KAAA,CAAAC,SAAA;MACA;;MAEA;MACA,KAAA6B,QAAA,CAAAC,GAAA;QACAG,MAAA;UAAAC,OAAA;UAAAC,QAAA;QAAA;MACA,GAAAJ,IAAA,CAAAC,GAAA;QACA,KAAAjC,KAAA,CAAAE,SAAA,GAAA+B,GAAA,CAAAzC,IAAA,EAAA6C,KAAA;MACA,GAAAC,KAAA;QACA,KAAAtC,KAAA,CAAAE,SAAA;MACA;;MAEA;MACA,KAAA4B,QAAA,CAAAC,GAAA