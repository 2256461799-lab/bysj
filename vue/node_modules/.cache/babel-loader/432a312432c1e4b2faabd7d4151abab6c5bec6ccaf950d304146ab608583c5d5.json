{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'AiAssistant',\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\n      dialogVisible: false,\n      messages: [],\n      userInput: '',\n      isTyping: false,\n      isShaking: false,\n      chatSessionId: null,\n      // 拖拽相关变量\n      ballLeft: 30,\n      // 初始位置（右30px）\n      ballTop: 'auto',\n      // 初始位置（下30px，在样式中设置）\n      ballBottom: 30,\n      isDragging: false,\n      startX: 0,\n      startY: 0,\n      initialLeft: 0,\n      initialTop: 0,\n      windowWidth: 0,\n      windowHeight: 0,\n      ballWidth: 64,\n      ballHeight: 64\n    };\n  },\n  mounted() {\n    // 初始化窗口尺寸\n    this.windowWidth = window.innerWidth;\n    this.windowHeight = window.innerHeight;\n    // 5秒后开始抖动\n    setTimeout(() => {\n      this.isShaking = true;\n    }, 5000);\n    // 监听窗口大小变化\n    window.addEventListener('resize', this.handleResize);\n    // 监听鼠标/触摸移动和松开事件\n    window.addEventListener('mousemove', this.handleDrag);\n    window.addEventListener('mouseup', this.stopDrag);\n    window.addEventListener('touchmove', this.handleDrag);\n    window.addEventListener('touchend', this.stopDrag);\n  },\n  beforeDestroy() {\n    // 移除事件监听\n    window.removeEventListener('resize', this.handleResize);\n    window.removeEventListener('mousemove', this.handleDrag);\n    window.removeEventListener('mouseup', this.stopDrag);\n    window.removeEventListener('touchmove', this.handleDrag);\n    window.removeEventListener('touchend', this.stopDrag);\n  },\n  methods: {\n    generateSessionId(prefix = 'session') {\n      return prefix + '_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);\n    },\n    openDialog() {\n      this.dialogVisible = true;\n      this.isShaking = false;\n      if (!this.chatSessionId) {\n        this.chatSessionId = this.generateSessionId('chat');\n        this.addSystemMessage('您好！我是AI治理助手，您可以向我咨询任何基层治理相关的问题。');\n      }\n    },\n    addSystemMessage(content) {\n      this.messages.push({\n        role: 'system',\n        content: content,\n        time: this.getCurrentTime()\n      });\n      this.$nextTick(() => {\n        this.scrollToBottom();\n      });\n    },\n    sendMessage() {\n      if (!this.userInput.trim() || this.isTyping) return;\n      const userMessage = this.userInput.trim();\n      this.messages.push({\n        role: 'user',\n        content: userMessage,\n        time: this.getCurrentTime()\n      });\n      this.userInput = '';\n      this.isTyping = true;\n      this.$nextTick(() => {\n        this.scrollToBottom();\n      });\n      this.callChatAPI(userMessage);\n    },\n    callChatAPI(message) {\n      const url = `${this.$baseUrl}/ai/chat?sessionId=${this.chatSessionId}&message=${encodeURIComponent(message)}`;\n      this.handleSSE(url);\n    },\n    handleSSE(url) {\n      const eventSource = new EventSource(url);\n      let aiMessage = '';\n      eventSource.onmessage = event => {\n        const data = event.data;\n        if (data === '[START]') return;\n        if (data === '[DONE]') {\n          eventSource.close();\n          this.isTyping = false;\n          return;\n        }\n        aiMessage += data;\n        const lastMessage = this.messages[this.messages.length - 1];\n        if (lastMessage && lastMessage.role === 'assistant') {\n          lastMessage.content = aiMessage;\n        } else {\n          this.messages.push({\n            role: 'assistant',\n            content: aiMessage,\n            time: this.getCurrentTime()\n          });\n        }\n        this.$nextTick(() => this.scrollToBottom());\n      };\n      eventSource.onerror = error => {\n        console.error('SSE Error:', error);\n        eventSource.close();\n        this.isTyping = false;\n        this.$message.error('连接出错，请重试');\n      };\n    },\n    clearChat() {\n      this.$confirm('确定要清空对话吗？', '提示', {\n        type: 'warning'\n      }).then(() => {\n        this.messages = [];\n        this.$request.delete('/ai/clear', {\n          params: {\n            sessionId: this.chatSessionId\n          }\n        });\n        this.addSystemMessage('对话已清空，您可以重新开始提问。');\n      }).catch(() => {});\n    },\n    scrollToBottom() {\n      if (this.$refs.messageList) {\n        this.$refs.messageList.scrollTop = this.$refs.messageList.scrollHeight;\n      }\n    },\n    getCurrentTime() {\n      const now = new Date();\n      return `${now.getHours().toString().padStart(2, '0')}:${now.getMinutes().toString().padStart(2, '0')}`;\n    },\n    // 拖拽功能实现\n    startDrag(e) {\n      e.preventDefault();\n      this.isDragging = true;\n      this.isShaking = false;\n\n      // 获取初始位置\n      const ball = this.$refs.floatBall;\n      this.initialLeft = this.ballLeft;\n      this.initialTop = this.ballTop === 'auto' ? this.windowHeight - this.ballHeight - this.ballBottom : this.ballTop;\n\n      // 获取鼠标/触摸点位置\n      const clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;\n      const clientY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;\n      this.startX = clientX - this.initialLeft;\n      this.startY = clientY - this.initialTop;\n\n      // 拖拽时禁用过渡效果\n      ball.style.transition = 'none';\n    },\n    handleDrag(e) {\n      if (!this.isDragging) return;\n      e.preventDefault();\n\n      // 获取当前鼠标/触摸点位置\n      const clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;\n      const clientY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;\n\n      // 计算新位置\n      let newLeft = clientX - this.startX;\n      let newTop = clientY - this.startY;\n\n      // 边界限制（防止超出屏幕）\n      const minLeft = 0;\n      const maxLeft = this.windowWidth - this.ballWidth;\n      const minTop = 0;\n      const maxTop = this.windowHeight - this.ballHeight;\n      newLeft = Math.max(minLeft, Math.min(newLeft, maxLeft));\n      newTop = Math.max(minTop, Math.min(newTop, maxTop));\n\n      // 更新位置\n      this.ballLeft = newLeft;\n      this.ballTop = newTop;\n      this.ballBottom = 'auto'; // 覆盖bottom样式\n    },\n\n    stopDrag() {\n      if (!this.isDragging) return;\n      this.isDragging = false;\n      const ball = this.$refs.floatBall;\n      // 启用过渡效果，实现平滑吸附\n      ball.style.transition = 'all 0.3s ease';\n\n      // 自动吸附到最近的屏幕边缘\n      const centerX = this.windowWidth / 2;\n      if (this.ballLeft + this.ballWidth / 2 < centerX) {\n        // 吸附到左侧\n        this.ballLeft = 10;\n      } else {\n        // 吸附到右侧\n        this.ballLeft = this.windowWidth - this.ballWidth - 10;\n      }\n    },\n    handleResize() {\n      this.windowWidth = window.innerWidth;\n      this.windowHeight = window.innerHeight;\n      // 窗口大小变化时重新计算位置\n      this.stopDrag();\n    }\n  }\n};","map":{"version":3,"names":["name","data","user","JSON","parse","localStorage","getItem","dialogVisible","messages","userInput","isTyping","isShaking","chatSessionId","ballLeft","ballTop","ballBottom","isDragging","startX","startY","initialLeft","initialTop","windowWidth","windowHeight","ballWidth","ballHeight","mounted","window","innerWidth","innerHeight","setTimeout","addEventListener","handleResize","handleDrag","stopDrag","beforeDestroy","removeEventListener","methods","generateSessionId","prefix","Date","now","Math","random","toString","substr","openDialog","addSystemMessage","content","push","role","time","getCurrentTime","$nextTick","scrollToBottom","sendMessage","trim","userMessage","callChatAPI","message","url","$baseUrl","encodeURIComponent","handleSSE","eventSource","EventSource","aiMessage","onmessage","event","close","lastMessage","length","onerror","error","console","$message","clearChat","$confirm","type","then","$request","delete","params","sessionId","catch","$refs","messageList","scrollTop","scrollHeight","getHours","padStart","getMinutes","startDrag","e","preventDefault","ball","floatBall","clientX","includes","touches","clientY","style","transition","newLeft","newTop","minLeft","maxLeft","minTop","maxTop","max","min","centerX"],"sources":["src/components/AiAssistant.vue"],"sourcesContent":["<template>\n  <div class=\"ai-assistant\">\n    <!-- 悬浮球（支持拖拽滑动） -->\n    <div\n      ref=\"floatBall\"\n      class=\"float-ball\"\n      :class=\"{ shake: isShaking }\"\n      :style=\"{ left: `${ballLeft}px`, top: `${ballTop}px` }\"\n      @mousedown=\"startDrag\"\n      @touchstart=\"startDrag\"\n      @click.stop=\"openDialog\"\n      @mouseenter=\"isShaking = false\"\n    >\n      <div class=\"ball-icon\">\n        <i class=\"el-icon-chat-dot-round\"></i>\n      </div>\n      <div class=\"ball-text\">治理助手</div>\n    </div>\n\n    <!-- 对话窗口 -->\n    <el-dialog\n      title=\"AI智能问答\"\n      :visible.sync=\"dialogVisible\"\n      width=\"40%\"\n      :close-on-click-modal=\"false\"\n      custom-class=\"ai-dialog\"\n      :append-to-body=\"true\"\n    >\n      <div class=\"chat-container\">\n        <div class=\"chat-header\">\n          <el-button @click=\"clearChat\" size=\"small\" icon=\"el-icon-delete\">清空</el-button>\n        </div>\n\n        <div class=\"message-list\" ref=\"messageList\">\n          <div v-for=\"(msg, index) in messages\" :key=\"index\" :class=\"['message-item', msg.role]\">\n            <div class=\"message-avatar\">\n              <img v-if=\"msg.role === 'user' && user.avatar\" :src=\"user.avatar\" class=\"avatar-img\" />\n              <i v-else-if=\"msg.role === 'user'\" class=\"el-icon-user-solid\"></i>\n              <i v-else class=\"el-icon-service\"></i>\n            </div>\n            <div class=\"message-content\">\n              <div class=\"message-text\">{{ msg.content }}</div>\n              <div class=\"message-time\">{{ msg.time }}</div>\n            </div>\n          </div>\n          <div v-if=\"isTyping\" class=\"message-item assistant\">\n            <div class=\"message-avatar\">\n              <i class=\"el-icon-service\"></i>\n            </div>\n            <div class=\"message-content\">\n              <div class=\"typing-indicator\">\n                <span></span>\n                <span></span>\n                <span></span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"input-area\">\n          <el-input\n            v-model=\"userInput\"\n            placeholder=\"输入消息...\"\n            @keyup.enter.native=\"sendMessage\"\n            :disabled=\"isTyping\"\n          >\n            <el-button\n              slot=\"append\"\n              icon=\"el-icon-s-promotion\"\n              @click=\"sendMessage\"\n              :disabled=\"isTyping || !userInput.trim()\"\n            ></el-button>\n          </el-input>\n        </div>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'AiAssistant',\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\n      dialogVisible: false,\n      messages: [],\n      userInput: '',\n      isTyping: false,\n      isShaking: false,\n      chatSessionId: null,\n      // 拖拽相关变量\n      ballLeft: 30, // 初始位置（右30px）\n      ballTop: 'auto', // 初始位置（下30px，在样式中设置）\n      ballBottom: 30,\n      isDragging: false,\n      startX: 0,\n      startY: 0,\n      initialLeft: 0,\n      initialTop: 0,\n      windowWidth: 0,\n      windowHeight: 0,\n      ballWidth: 64,\n      ballHeight: 64\n    }\n  },\n  mounted() {\n    // 初始化窗口尺寸\n    this.windowWidth = window.innerWidth\n    this.windowHeight = window.innerHeight\n    // 5秒后开始抖动\n    setTimeout(() => {\n      this.isShaking = true\n    }, 5000)\n    // 监听窗口大小变化\n    window.addEventListener('resize', this.handleResize)\n    // 监听鼠标/触摸移动和松开事件\n    window.addEventListener('mousemove', this.handleDrag)\n    window.addEventListener('mouseup', this.stopDrag)\n    window.addEventListener('touchmove', this.handleDrag)\n    window.addEventListener('touchend', this.stopDrag)\n  },\n  beforeDestroy() {\n    // 移除事件监听\n    window.removeEventListener('resize', this.handleResize)\n    window.removeEventListener('mousemove', this.handleDrag)\n    window.removeEventListener('mouseup', this.stopDrag)\n    window.removeEventListener('touchmove', this.handleDrag)\n    window.removeEventListener('touchend', this.stopDrag)\n  },\n  methods: {\n    generateSessionId(prefix = 'session') {\n      return prefix + '_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9)\n    },\n    openDialog() {\n      this.dialogVisible = true\n      this.isShaking = false\n      if (!this.chatSessionId) {\n        this.chatSessionId = this.generateSessionId('chat')\n        this.addSystemMessage('您好！我是AI治理助手，您可以向我咨询任何基层治理相关的问题。')\n      }\n    },\n    addSystemMessage(content) {\n      this.messages.push({\n        role: 'system',\n        content: content,\n        time: this.getCurrentTime()\n      })\n      this.$nextTick(() => {\n        this.scrollToBottom()\n      })\n    },\n    sendMessage() {\n      if (!this.userInput.trim() || this.isTyping) return\n      const userMessage = this.userInput.trim()\n      this.messages.push({\n        role: 'user',\n        content: userMessage,\n        time: this.getCurrentTime()\n      })\n      this.userInput = ''\n      this.isTyping = true\n      this.$nextTick(() => {\n        this.scrollToBottom()\n      })\n      this.callChatAPI(userMessage)\n    },\n    callChatAPI(message) {\n      const url = `${this.$baseUrl}/ai/chat?sessionId=${this.chatSessionId}&message=${encodeURIComponent(message)}`\n      this.handleSSE(url)\n    },\n    handleSSE(url) {\n      const eventSource = new EventSource(url)\n      let aiMessage = ''\n      eventSource.onmessage = (event) => {\n        const data = event.data\n        if (data === '[START]') return\n        if (data === '[DONE]') {\n          eventSource.close()\n          this.isTyping = false\n          return\n        }\n        aiMessage += data\n        const lastMessage = this.messages[this.messages.length - 1]\n        if (lastMessage && lastMessage.role === 'assistant') {\n          lastMessage.content = aiMessage\n        } else {\n          this.messages.push({\n            role: 'assistant',\n            content: aiMessage,\n            time: this.getCurrentTime()\n          })\n        }\n        this.$nextTick(() => this.scrollToBottom())\n      }\n      eventSource.onerror = (error) => {\n        console.error('SSE Error:', error)\n        eventSource.close()\n        this.isTyping = false\n        this.$message.error('连接出错，请重试')\n      }\n    },\n    clearChat() {\n      this.$confirm('确定要清空对话吗？', '提示', {\n        type: 'warning'\n      }).then(() => {\n        this.messages = []\n        this.$request.delete('/ai/clear', {\n          params: { sessionId: this.chatSessionId }\n        })\n        this.addSystemMessage('对话已清空，您可以重新开始提问。')\n      }).catch(() => {})\n    },\n    scrollToBottom() {\n      if (this.$refs.messageList) {\n        this.$refs.messageList.scrollTop = this.$refs.messageList.scrollHeight\n      }\n    },\n    getCurrentTime() {\n      const now = new Date()\n      return `${now.getHours().toString().padStart(2, '0')}:${now.getMinutes().toString().padStart(2, '0')}`\n    },\n    // 拖拽功能实现\n    startDrag(e) {\n      e.preventDefault()\n      this.isDragging = true\n      this.isShaking = false\n      \n      // 获取初始位置\n      const ball = this.$refs.floatBall\n      this.initialLeft = this.ballLeft\n      this.initialTop = this.ballTop === 'auto' ? (this.windowHeight - this.ballHeight - this.ballBottom) : this.ballTop\n      \n      // 获取鼠标/触摸点位置\n      const clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX\n      const clientY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY\n      \n      this.startX = clientX - this.initialLeft\n      this.startY = clientY - this.initialTop\n      \n      // 拖拽时禁用过渡效果\n      ball.style.transition = 'none'\n    },\n    handleDrag(e) {\n      if (!this.isDragging) return\n      e.preventDefault()\n      \n      // 获取当前鼠标/触摸点位置\n      const clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX\n      const clientY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY\n      \n      // 计算新位置\n      let newLeft = clientX - this.startX\n      let newTop = clientY - this.startY\n      \n      // 边界限制（防止超出屏幕）\n      const minLeft = 0\n      const maxLeft = this.windowWidth - this.ballWidth\n      const minTop = 0\n      const maxTop = this.windowHeight - this.ballHeight\n      \n      newLeft = Math.max(minLeft, Math.min(newLeft, maxLeft))\n      newTop = Math.max(minTop, Math.min(newTop, maxTop))\n      \n      // 更新位置\n      this.ballLeft = newLeft\n      this.ballTop = newTop\n      this.ballBottom = 'auto' // 覆盖bottom样式\n    },\n    stopDrag() {\n      if (!this.isDragging) return\n      this.isDragging = false\n      \n      const ball = this.$refs.floatBall\n      // 启用过渡效果，实现平滑吸附\n      ball.style.transition = 'all 0.3s ease'\n      \n      // 自动吸附到最近的屏幕边缘\n      const centerX = this.windowWidth / 2\n      if (this.ballLeft + this.ballWidth / 2 < centerX) {\n        // 吸附到左侧\n        this.ballLeft = 10\n      } else {\n        // 吸附到右侧\n        this.ballLeft = this.windowWidth - this.ballWidth - 10\n      }\n    },\n    handleResize() {\n      this.windowWidth = window.innerWidth\n      this.windowHeight = window.innerHeight\n      // 窗口大小变化时重新计算位置\n      this.stopDrag()\n    }\n  }\n}\n</script>\n\n<style scoped>\n/* 悬浮球：支持自由拖拽，层级拉满 */\n.float-ball {\n  position: fixed !important;\n  right: auto !important; /* 改为通过JS控制left属性 */\n  bottom: 30px !important;\n  width: 64px !important;\n  height: 64px !important;\n  background: #1d3557 !important;\n  border-radius: 50% !important;\n  box-shadow: 0 2px 12px rgba(29, 53, 87, 0.4) !important;\n  cursor: move !important; /* 鼠标样式改为移动光标 */\n  display: flex !important;\n  flex-direction: column !important;\n  align-items: center !important;\n  justify-content: center !important;\n  z-index: 999999 !important;\n  visibility: visible !important;\n  opacity: 1 !important;\n  transition: all 0.3s ease !important;\n  touch-action: none !important; /* 防止触摸设备默认行为 */\n}\n.float-ball:hover {\n  background: #264e78 !important;\n  box-shadow: 0 2px 16px rgba(29, 53, 87, 0.5) !important;\n}\n.float-ball.shake {\n  animation: shake 0.5s infinite;\n}\n@keyframes shake {\n  0%, 100% { transform: rotate(0deg); }\n  25% { transform: rotate(-8deg); }\n  75% { transform: rotate(8deg); }\n}\n.ball-icon {\n  font-size: 28px;\n  color: #fff;\n}\n.ball-text {\n  font-size: 11px;\n  color: #fff;\n  margin-top: 2px;\n}\n\n/* 对话框样式：用 ::v-deep 替代 >>>，编辑器零标红 */\n::v-deep .ai-dialog {\n  border-radius: 8px;\n  overflow: hidden;\n  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);\n}\n::v-deep .ai-dialog .el-dialog__header {\n  background: #1d3557;\n  padding: 16px 20px;\n  border-bottom: 1px solid #e8e8e8;\n  margin: 0;\n}\n::v-deep .ai-dialog .el-dialog__title {\n  color: #fff;\n  font-weight: 600;\n  font-size: 16px;\n  line-height: 1.4;\n}\n::v-deep .ai-dialog .el-dialog__headerbtn .el-dialog__close {\n  color: #fff;\n  font-size: 18px;\n}\n::v-deep .ai-dialog .el-dialog__headerbtn .el-dialog__close:hover {\n  color: #f0f0f0;\n  opacity: 0.8;\n}\n::v-deep .ai-dialog .el-dialog__body {\n  padding: 0;\n  background: #f8f8f8;\n}\n\n/* 对话容器 */\n.chat-container {\n  display: flex;\n  flex-direction: column;\n  height: 500px;\n}\n.chat-header {\n  padding: 12px 16px;\n  background: #fafafa;\n  border-bottom: 1px solid #e8e8e8;\n  display: flex;\n  justify-content: flex-end;\n}\n.message-list {\n  flex: 1;\n  overflow-y: auto;\n  padding: 16px;\n  background: #f8f8f8;\n}\n.message-item {\n  display: flex;\n  margin-bottom: 16px;\n  animation: fadeIn 0.2s ease-out;\n}\n@keyframes fadeIn {\n  from { opacity: 0; transform: translateY(5px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n.message-item.user {\n  flex-direction: row-reverse;\n}\n.message-avatar {\n  width: 34px;\n  height: 34px;\n  border-radius: 50%;\n  background: #1d3557;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: white;\n  font-size: 16px;\n  flex-shrink: 0;\n  overflow: hidden;\n}\n.avatar-img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  border-radius: 50%;\n}\n.message-item.user .message-avatar {\n  background: #67c23a;\n}\n.message-item.system .message-avatar {\n  background: #e6a23c;\n}\n.message-content {\n  max-width: 70%;\n  margin: 0 10px;\n}\n.message-text {\n  padding: 10px 14px;\n  background: white;\n  border: 1px solid #e8e8e8;\n  word-wrap: break-word;\n  line-height: 1.6;\n  font-size: 14px;\n  color: #333;\n  border-radius: 4px;\n}\n.message-item.user .message-text {\n  background: #1d3557;\n  color: white;\n  border-color: #1d3557;\n}\n.message-item.system .message-text {\n  background: #fffbe6;\n  border-left: 2px solid #e6a23c;\n}\n.message-time {\n  font-size: 11px;\n  color: #999;\n  margin-top: 4px;\n  text-align: center;\n}\n.typing-indicator {\n  padding: 10px 14px;\n  background: white;\n  border: 1px solid #e8e8e8;\n  display: inline-flex;\n  gap: 5px;\n  border-radius: 4px;\n}\n.typing-indicator span {\n  width: 6px;\n  height: 6px;\n  border-radius: 50%;\n  background: #1d3557;\n  animation: typing 1.2s infinite;\n}\n.typing-indicator span:nth-child(2) {\n  animation-delay: 0.2s;\n}\n.typing-indicator span:nth-child(3) {\n  animation-delay: 0.4s;\n}\n@keyframes typing {\n  0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }\n  30% { transform: translateY(-6px); opacity: 1; }\n}\n.input-area {\n  padding: 16px;\n  background: white;\n  border-top: 1px solid #e8e8e8;\n}\n\n/* 输入框样式：编辑器零标红 */\n::v-deep .input-area .el-input__inner {\n  border-radius: 4px;\n  border: 1px solid #dcdfe6;\n  padding: 12px 10px;\n}\n::v-deep .input-area .el-input-group__append {\n  background: #1d3557;\n  border-color: #1d3557;\n  color: white;\n  border-radius: 0 4px 4px 0;\n  padding: 0 15px;\n}\n::v-deep .input-area .el-input-group__append:hover