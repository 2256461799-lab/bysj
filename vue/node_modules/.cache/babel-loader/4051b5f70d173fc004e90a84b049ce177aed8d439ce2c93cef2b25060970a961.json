{"ast":null,"code":"export default {\n  name: 'ManagerQuestion',\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\n      quizId: null,\n      content: '',\n      tableData: [],\n      pageNum: 1,\n      pageSize: 10,\n      total: 0,\n      dialogVisible: false,\n      form: {},\n      rules: {\n        quizId: [{\n          required: true,\n          message: '请选择所属关卡',\n          trigger: 'change'\n        }],\n        content: [{\n          required: true,\n          message: '请输入题目内容',\n          trigger: 'blur'\n        }],\n        optionA: [{\n          required: true,\n          message: '请输入选项A',\n          trigger: 'blur'\n        }],\n        optionB: [{\n          required: true,\n          message: '请输入选项B',\n          trigger: 'blur'\n        }],\n        optionC: [{\n          required: true,\n          message: '请输入选项C',\n          trigger: 'blur'\n        }],\n        optionD: [{\n          required: true,\n          message: '请输入选项D',\n          trigger: 'blur'\n        }],\n        correctAnswer: [{\n          required: true,\n          message: '请选择正确答案',\n          trigger: 'change'\n        }],\n        analysis: [{\n          required: true,\n          message: '请输入答案解析',\n          trigger: 'blur'\n        }],\n        score: [{\n          required: true,\n          message: '请输入题目分值',\n          trigger: 'blur'\n        }]\n      },\n      ids: [],\n      quizList: []\n    };\n  },\n  created() {\n    this.loadQuizList();\n    this.load(1);\n  },\n  methods: {\n    loadQuizList() {\n      this.$request.get('/quiz/selectAll').then(res => {\n        if (res.code === '200') {\n          this.quizList = res.data || [];\n        }\n      });\n    },\n    getQuizName(quizId) {\n      const quiz = this.quizList.find(q => q.id === quizId);\n      return quiz ? quiz.title : '未知关卡';\n    },\n    load(pageNum) {\n      if (pageNum) this.pageNum = pageNum;\n      this.$request.get('/question/selectPage', {\n        params: {\n          pageNum: this.pageNum,\n          pageSize: this.pageSize,\n          quizId: this.quizId,\n          content: this.content\n        }\n      }).then(res => {\n        if (res.code === '200') {\n          this.tableData = res.data?.list || [];\n          this.total = res.data?.total || 0;\n        }\n      });\n    },\n    reset() {\n      this.quizId = null;\n      this.content = '';\n      this.load(1);\n    },\n    handleAdd() {\n      this.form = {\n        sortOrder: 0,\n        score: 25\n      };\n      this.dialogVisible = true;\n      this.$nextTick(() => {\n        if (this.$refs.formRef) {\n          this.$refs.formRef.clearValidate();\n        }\n      });\n    },\n    handleEdit(row) {\n      this.form = JSON.parse(JSON.stringify(row));\n      this.dialogVisible = true;\n      this.$nextTick(() => {\n        if (this.$refs.formRef) {\n          this.$refs.formRef.clearValidate();\n        }\n      });\n    },\n    save() {\n      this.$refs.formRef.validate(valid => {\n        if (valid) {\n          this.$request({\n            url: this.form.id ? '/question/update' : '/question/add',\n            method: this.form.id ? 'PUT' : 'POST',\n            data: this.form\n          }).then(res => {\n            if (res.code === '200') {\n              this.$message.success('保存成功');\n              this.dialogVisible = false;\n              this.load(1);\n            } else {\n              this.$message.error(res.msg);\n            }\n          });\n        }\n      });\n    },\n    del(id) {\n      this.$confirm('确认删除该题目吗？', '提示', {\n        type: 'warning'\n      }).then(() => {\n        this.$request.delete('/question/delete/' + id).then(res => {\n          if (res.code === '200') {\n            this.$message.success('删除成功');\n            this.load(1);\n          } else {\n            this.$message.error(res.msg);\n          }\n        });\n      }).catch(() => {});\n    },\n    handleSelectionChange(rows) {\n      this.ids = rows.map(v => v.id);\n    },\n    delBatch() {\n      if (!this.ids.length) {\n        this.$message.warning('请选择要删除的数据');\n        return;\n      }\n      this.$confirm('确认批量删除这些题目吗？', '提示', {\n        type: 'warning'\n      }).then(() => {\n        this.$request.delete('/question/delete/batch', {\n          data: this.ids\n        }).then(res => {\n          if (res.code === '200') {\n            this.$message.success('批量删除成功');\n            this.load(1);\n          } else {\n            this.$message.error(res.msg);\n          }\n        });\n      }).catch(() => {});\n    },\n    handleCurrentChange(pageNum) {\n      this.load(pageNum);\n    }\n  }\n};","map":{"version":3,"names":["name","data","user","JSON","parse","localStorage","getItem","quizId","content","tableData","pageNum","pageSize","total","dialogVisible","form","rules","required","message","trigger","optionA","optionB","optionC","optionD","correctAnswer","analysis","score","ids","quizList","created","loadQuizList","load","methods","$request","get","then","res","code","getQuizName","quiz","find","q","id","title","params","list","reset","handleAdd","sortOrder","$nextTick","$refs","formRef","clearValidate","handleEdit","row","stringify","save","validate","valid","url","method","$message","success","error","msg","del","$confirm","type","delete","catch","handleSelectionChange","rows","map","v","delBatch","length","warning","handleCurrentChange"],"sources":["src/views/manager/Question.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <!-- 搜索区域 -->\r\n    <div style=\"margin: 10px 0\">\r\n      <el-select v-model=\"quizId\" placeholder=\"请选择关卡\" style=\"width: 200px\" clearable @change=\"load(1)\">\r\n        <el-option\r\n          v-for=\"quiz in quizList\"\r\n          :key=\"quiz.id\"\r\n          :label=\"quiz.title\"\r\n          :value=\"quiz.id\">\r\n        </el-option>\r\n      </el-select>\r\n      <el-input v-model=\"content\" placeholder=\"请输入题目内容关键字\" style=\"width: 250px; margin-left: 5px\" clearable></el-input>\r\n      <el-button type=\"primary\" style=\"margin-left: 5px\" @click=\"load(1)\">查询</el-button>\r\n      <el-button type=\"warning\" style=\"margin-left: 5px\" @click=\"reset\">重置</el-button>\r\n    </div>\r\n\r\n    <!-- 操作按钮 -->\r\n    <div style=\"margin: 10px 0\">\r\n      <el-button type=\"primary\" @click=\"handleAdd\">新增 <i class=\"el-icon-circle-plus-outline\"></i></el-button>\r\n      <el-button type=\"danger\" @click=\"delBatch\">批量删除 <i class=\"el-icon-remove-outline\"></i></el-button>\r\n    </div>\r\n\r\n    <!-- 数据表格 -->\r\n    <el-table :data=\"tableData\" stripe @selection-change=\"handleSelectionChange\">\r\n      <el-table-column type=\"selection\" width=\"55\"></el-table-column>\r\n      <el-table-column prop=\"id\" label=\"ID\" width=\"60\"></el-table-column>\r\n      <el-table-column prop=\"quizId\" label=\"所属关卡\" width=\"150\">\r\n        <template slot-scope=\"scope\">\r\n          <el-tag size=\"small\" type=\"warning\">{{ getQuizName(scope.row.quizId) }}</el-tag>\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"content\" label=\"题目内容\" min-width=\"300\" show-overflow-tooltip></el-table-column>\r\n      <el-table-column prop=\"correctAnswer\" label=\"正确答案\" width=\"100\" align=\"center\">\r\n        <template slot-scope=\"scope\">\r\n          <el-tag type=\"success\" size=\"small\">{{ scope.row.correctAnswer }}</el-tag>\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"score\" label=\"分值\" width=\"80\" sortable></el-table-column>\r\n      <el-table-column prop=\"sortOrder\" label=\"排序\" width=\"80\" sortable></el-table-column>\r\n      <el-table-column label=\"操作\" width=\"200\" align=\"center\">\r\n        <template slot-scope=\"scope\">\r\n          <el-button size=\"mini\" type=\"primary\" @click=\"handleEdit(scope.row)\">编辑</el-button>\r\n          <el-button size=\"mini\" type=\"danger\" @click=\"del(scope.row.id)\">删除</el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n\r\n    <!-- 分页 -->\r\n    <div style=\"margin: 10px 0\">\r\n      <el-pagination\r\n        @current-change=\"handleCurrentChange\"\r\n        :current-page=\"pageNum\"\r\n        :page-sizes=\"[5, 10, 20]\"\r\n        :page-size=\"pageSize\"\r\n        layout=\"total, prev, pager, next\"\r\n        :total=\"total\">\r\n      </el-pagination>\r\n    </div>\r\n\r\n    <!-- 新增/编辑弹窗 -->\r\n    <el-dialog title=\"题目管理\" :visible.sync=\"dialogVisible\" width=\"70%\" :close-on-click-modal=\"false\">\r\n      <el-form :model=\"form\" label-width=\"100px\" :rules=\"rules\" ref=\"formRef\">\r\n        <el-form-item label=\"所属关卡\" prop=\"quizId\">\r\n          <el-select v-model=\"form.quizId\" placeholder=\"请选择关卡\" style=\"width: 100%\">\r\n            <el-option\r\n              v-for=\"quiz in quizList\"\r\n              :key=\"quiz.id\"\r\n              :label=\"quiz.title\"\r\n              :value=\"quiz.id\">\r\n            </el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item label=\"题目内容\" prop=\"content\">\r\n          <el-input\r\n            type=\"textarea\"\r\n            v-model=\"form.content\"\r\n            :rows=\"3\"\r\n            placeholder=\"请输入题目内容\"\r\n            maxlength=\"500\"\r\n            show-word-limit>\r\n          </el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"选项A\" prop=\"optionA\">\r\n          <el-input v-model=\"form.optionA\" placeholder=\"请输入选项A的内容\" maxlength=\"200\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"选项B\" prop=\"optionB\">\r\n          <el-input v-model=\"form.optionB\" placeholder=\"请输入选项B的内容\" maxlength=\"200\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"选项C\" prop=\"optionC\">\r\n          <el-input v-model=\"form.optionC\" placeholder=\"请输入选项C的内容\" maxlength=\"200\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"选项D\" prop=\"optionD\">\r\n          <el-input v-model=\"form.optionD\" placeholder=\"请输入选项D的内容\" maxlength=\"200\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"正确答案\" prop=\"correctAnswer\">\r\n          <el-radio-group v-model=\"form.correctAnswer\">\r\n            <el-radio label=\"A\">A</el-radio>\r\n            <el-radio label=\"B\">B</el-radio>\r\n            <el-radio label=\"C\">C</el-radio>\r\n            <el-radio label=\"D\">D</el-radio>\r\n          </el-radio-group>\r\n        </el-form-item>\r\n        <el-form-item label=\"答案解析\" prop=\"analysis\">\r\n          <el-input\r\n            type=\"textarea\"\r\n            v-model=\"form.analysis\"\r\n            :rows=\"4\"\r\n            placeholder=\"请输入答案解析，帮助用户理解为什么选择这个答案\"\r\n            maxlength=\"500\"\r\n            show-word-limit>\r\n          </el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"题目分值\" prop=\"score\">\r\n          <el-input-number v-model=\"form.score\" :min=\"1\" :max=\"100\" placeholder=\"分值\"></el-input-number>\r\n          <span style=\"color: #909399; margin-left: 10px; font-size: 12px\">建议每题25分，确保总分为100分</span>\r\n        </el-form-item>\r\n        <el-form-item label=\"排序\">\r\n          <el-input-number v-model=\"form.sortOrder\" :min=\"0\" :max=\"999\" placeholder=\"排序\"></el-input-number>\r\n          <span style=\"color: #909399; margin-left: 10px; font-size: 12px\">数字越小越靠前</span>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"dialogVisible = false\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"save\">确 定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'ManagerQuestion',\r\n  data() {\r\n    return {\r\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\r\n      quizId: null,\r\n      content: '',\r\n      tableData: [],\r\n      pageNum: 1,\r\n      pageSize: 10,\r\n      total: 0,\r\n      dialogVisible: false,\r\n      form: {},\r\n      rules: {\r\n        quizId: [\r\n          { required: true, message: '请选择所属关卡', trigger: 'change' }\r\n        ],\r\n        content: [\r\n          { required: true, message: '请输入题目内容', trigger: 'blur' }\r\n        ],\r\n        optionA: [\r\n          { required: true, message: '请输入选项A', trigger: 'blur' }\r\n        ],\r\n        optionB: [\r\n          { required: true, message: '请输入选项B', trigger: 'blur' }\r\n        ],\r\n        optionC: [\r\n          { required: true, message: '请输入选项C', trigger: 'blur' }\r\n        ],\r\n        optionD: [\r\n          { required: true, message: '请输入选项D', trigger: 'blur' }\r\n        ],\r\n        correctAnswer: [\r\n          { required: true, message: '请选择正确答案', trigger: 'change' }\r\n        ],\r\n        analysis: [\r\n          { required: true, message: '请输入答案解析', trigger: 'blur' }\r\n        ],\r\n        score: [\r\n          { required: true, message: '请输入题目分值', trigger: 'blur' }\r\n        ]\r\n      },\r\n      ids: [],\r\n      quizList: []\r\n    }\r\n  },\r\n  created() {\r\n    this.loadQuizList()\r\n    this.load(1)\r\n  },\r\n  methods: {\r\n    loadQuizList() {\r\n      this.$request.get('/quiz/selectAll').then(res => {\r\n        if (res.code === '200') {\r\n          this.quizList = res.data || []\r\n        }\r\n      })\r\n    },\r\n    getQuizName(quizId) {\r\n      const quiz = this.quizList.find(q => q.id === quizId)\r\n      return quiz ? quiz.title : '未知关卡'\r\n    },\r\n    load(pageNum) {\r\n      if (pageNum) this.pageNum = pageNum\r\n      this.$request.get('/question/selectPage', {\r\n        params: {\r\n          pageNum: this.pageNum,\r\n          pageSize: this.pageSize,\r\n          quizId: this.quizId,\r\n          content: this.content\r\n        }\r\n      }).then(res => {\r\n        if (res.code === '200') {\r\n          this.tableData = res.data?.list || []\r\n          this.total = res.data?.total || 0\r\n        }\r\n      })\r\n    },\r\n    reset() {\r\n      this.quizId = null\r\n      this.content = ''\r\n      this.load(1)\r\n    },\r\n    handleAdd() {\r\n      this.form = { sortOrder: 0, score: 25 }\r\n      this.dialogVisible = true\r\n      this.$nextTick(() => {\r\n        if (this.$refs.formRef) {\r\n          this.$refs.formRef.clearValidate()\r\n        }\r\n      })\r\n    },\r\n    handleEdit(row) {\r\n      this.form = JSON.parse(JSON.stringify(row))\r\n      this.dialogVisible = true\r\n      this.$nextTick(() => {\r\n        if (this.$refs.formRef) {\r\n          this.$refs.formRef.clearValidate()\r\n        }\r\n      })\r\n    },\r\n    save() {\r\n      this.$refs.formRef.validate((valid) => {\r\n        if (valid) {\r\n          this.$request({\r\n            url: this.form.id ? '/question/update' : '/question/add',\r\n            method: this.form.id ? 'PUT' : 'POST',\r\n            data: this.form\r\n          }).then(res => {\r\n            if (res.code === '200') {\r\n              this.$message.success('保存成功')\r\n              this.dialogVisible = false\r\n              this.load(1)\r\n            } else {\r\n              this.$message.error(res.msg)\r\n            }\r\n          })\r\n        }\r\n      })\r\n    },\r\n    del(id) {\r\n      this.$confirm('确认删除该题目吗？', '提示', { type: 'warning' }).then(() => {\r\n        this.$request.delete('/question/delete/' + id).then(res => {\r\n          if (res.code === '200') {\r\n            this.$message.success('删除成功')\r\n            this.load(1)\r\n          } else {\r\n            this.$message.error(res.msg)\r\n          }\r\n        })\r\n      }).catch(() => {})\r\n    },\r\n    handleSelectionChange(rows) {\r\n      this.ids = rows.map(v => v.id)\r\n    },\r\n    delBatch() {\r\n      if (!this.ids.length) {\r\n        this.$message.warning('请选择要删除的数据')\r\n        return\r\n      }\r\n      this.$confirm('确认批量删除这些题目吗？', '提示', { type: 'warning' }).then(() => {\r\n        this.$request.delete('/question/delete/batch', { data: this.ids }).then(res => {\r\n          if (res.code === '200') {\r\n            this.$message.success('批量删除成功')\r\n            this.load(1)\r\n          } else {\r\n            this.$message.error(res.msg)\r\n          }\r\n        })\r\n      }).catch(() => {})\r\n    },\r\n    handleCurrentChange(pageNum) {\r\n      this.load(pageNum)\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n</style>\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n"],"mappings":"AAmIA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,IAAA,EAAAC,IAAA,CAAAC,KAAA,CAAAC,YAAA,CAAAC,OAAA;MACAC,MAAA;MACAC,OAAA;MACAC,SAAA;MACAC,OAAA;MACAC,QAAA;MACAC,KAAA;MACAC,aAAA;MACAC,IAAA;MACAC,KAAA;QACAR,MAAA,GACA;UAAAS,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAV,OAAA,GACA;UAAAQ,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAC,OAAA,GACA;UAAAH,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAE,OAAA,GACA;UAAAJ,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAG,OAAA,GACA;UAAAL,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAI,OAAA,GACA;UAAAN,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAK,aAAA,GACA;UAAAP,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAM,QAAA,GACA;UAAAR,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAO,KAAA,GACA;UAAAT,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MAEA;MACAQ,GAAA;MACAC,QAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,YAAA;IACA,KAAAC,IAAA;EACA;EACAC,OAAA;IACAF,aAAA;MACA,KAAAG,QAAA,CAAAC,GAAA,oBAAAC,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAC,IAAA;UACA,KAAAT,QAAA,GAAAQ,GAAA,CAAAlC,IAAA;QACA;MACA;IACA;IACAoC,YAAA9B,MAAA;MACA,MAAA+B,IAAA,QAAAX,QAAA,CAAAY,IAAA,CAAAC,CAAA,IAAAA,CAAA,CAAAC,EAAA,KAAAlC,MAAA;MACA,OAAA+B,IAAA,GAAAA,IAAA,CAAAI,KAAA;IACA;IACAZ,KAAApB,OAAA;MACA,IAAAA,OAAA,OAAAA,OAAA,GAAAA,OAAA;MACA,KAAAsB,QAAA,CAAAC,GAAA;QACAU,MAAA;UACAjC,OAAA,OAAAA,OAAA;UACAC,QAAA,OAAAA,QAAA;UACAJ,MAAA,OAAAA,MAAA;UACAC,OAAA,OAAAA;QACA;MACA,GAAA0B,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAC,IAAA;UACA,KAAA3B,SAAA,GAAA0B,GAAA,CAAAlC,IAAA,EAAA2C,IAAA;UACA,KAAAhC,KAAA,GAAAuB,GAAA,CAAAlC,IAAA,EAAAW,KAAA;QACA;MACA;IACA;IACAiC,MAAA;MACA,KAAAtC,MAAA