{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport AiAssistant from '@/components/AiAssistant.vue';\nexport default {\n  name: \"FrontLayout\",\n  components: {\n    AiAssistant\n  },\n  data() {\n    return {\n      // 核心：每次进入页面都重新从缓存读取最新用户信息\n      user: JSON.parse(localStorage.getItem(\"xm-user\") || '{}')\n    };\n  },\n  // 监控路由变化，防止切换账号后数据不更新\n  watch: {\n    '$route'() {\n      this.updateUser();\n    }\n  },\n  methods: {\n    updateUser() {\n      this.user = JSON.parse(localStorage.getItem('xm-user') || '{}');\n    },\n    logout() {\n      localStorage.removeItem(\"xm-user\");\n      this.$router.push(\"/login\");\n    }\n  }\n};","map":{"version":3,"names":["AiAssistant","name","components","data","user","JSON","parse","localStorage","getItem","watch","$route","updateUser","methods","logout","removeItem","$router","push"],"sources":["src/views/Front.vue"],"sourcesContent":["<template>\n  <div>\n    <div class=\"front-header\">\n      <div class=\"front-header-left\">\n        <img src=\"@/assets/imgs/logo.png\" alt=\"\">\n        <div class=\"title\">网格化依法治理平台</div>\n      </div>\n      <div class=\"front-header-center\">\n        <div class=\"front-header-nav\">\n          <el-menu :default-active=\"$route.path\" mode=\"horizontal\" router>\n            <el-menu-item index=\"/front/index\">\n              <i class=\"el-icon-s-home\"></i>\n              <span>首页</span>\n            </el-menu-item>\n            \n            <el-menu-item index=\"/front/law\">\n              <i class=\"el-icon-warning-outline\"></i>\n              <span>法律法规</span>\n            </el-menu-item>\n\n            <el-menu-item index=\"/front/knowledge\">\n              <i class=\"el-icon-reading\"></i>\n              <span>治理案例库</span>\n            </el-menu-item>\n\n            <el-menu-item index=\"/front/home\">\n              <i class=\"el-icon-chat-dot-round\"></i>\n              <span>工作交流</span>\n            </el-menu-item>\n\n            <el-menu-item index=\"/front/activity\">\n              <i class=\"el-icon-trophy\"></i>\n              <span>任务中心</span>\n            </el-menu-item>\n            \n            <el-menu-item index=\"/front/learningClass\">\n              <i class=\"el-icon-video-camera\"></i>\n              <span>法治培训</span>\n            </el-menu-item>\n            \n            <el-menu-item index=\"/front/report\" v-if=\"user.id\">\n              <i class=\"el-icon-phone-outline\"></i>\n              <span>事件上报</span>\n            </el-menu-item>\n\n            <el-menu-item index=\"/front/person\" v-if=\"user.id\">\n              <i class=\"el-icon-user\"></i>\n              <span>个人中心</span>\n            </el-menu-item>\n          </el-menu>\n        </div>\n      </div>\n\n      <div class=\"front-header-right\">\n        <div v-if=\"!user.id\" class=\"header-buttons\">\n          <el-button size=\"small\" @click=\"$router.push('/login')\">登录</el-button>\n          <el-button size=\"small\" type=\"primary\" @click=\"$router.push('/register')\">注册</el-button>\n        </div>\n        <div v-else>\n          <el-dropdown>\n            <div class=\"front-header-dropdown\">\n              <img :src=\"user.avatar || 'https://cube.elemecdn.com/3/7c/3ea6beec64369c2642b92c6726f1epng.png'\" alt=\"\">\n              <div class=\"user-info\">\n                <span>{{ user.name || '用户' }}</span>\n                <i class=\"el-icon-arrow-down\"></i>\n              </div>\n            </div>\n            <el-dropdown-menu slot=\"dropdown\">\n              <el-dropdown-item @click.native=\"$router.push('/front/person')\">个人中心</el-dropdown-item>\n              <el-dropdown-item @click.native=\"logout\">\n                <i class=\"el-icon-switch-button\"></i> 退出登录\n              </el-dropdown-item>\n            </el-dropdown-menu>\n          </el-dropdown>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"main-body\">\n      <router-view ref=\"child\" @update:user=\"updateUser\" />\n    </div>\n\n    <ai-assistant></ai-assistant>\n  </div>\n</template>\n\n<script>\nimport AiAssistant from '@/components/AiAssistant.vue'\n\nexport default {\n  name: \"FrontLayout\",\n  components: {\n    AiAssistant\n  },\n  data () {\n    return {\n      // 核心：每次进入页面都重新从缓存读取最新用户信息\n      user: JSON.parse(localStorage.getItem(\"xm-user\") || '{}'),\n    }\n  },\n  // 监控路由变化，防止切换账号后数据不更新\n  watch: {\n    '$route'() {\n      this.updateUser()\n    }\n  },\n  methods: {\n    updateUser() {\n      this.user = JSON.parse(localStorage.getItem('xm-user') || '{}')\n    },\n    logout() {\n      localStorage.removeItem(\"xm-user\");\n      this.$router.push(\"/login\");\n    },\n  }\n}\n</script>\n\n<style scoped>\n  @import \"../assets/css/front.css\";\n\n  .front-header-center {\n    flex: 1;\n    overflow: hidden;\n  }\n  \n  /* 导航菜单容器样式：强制居中、不换行 */\n  ::v-deep .el-menu--horizontal {\n    display: flex !important;\n    justify-content: center !important; \n    flex-wrap: nowrap !important; \n    border-bottom: none !important;\n    overflow-x: auto; \n  }\n\n  /* 隐藏底部滚动条 */\n  ::v-deep .el-menu--horizontal::-webkit-scrollbar {\n    display: none; \n  }\n\n  /* 每个菜单项的间距 */\n  ::v-deep .el-menu--horizontal > .el-menu-item {\n    padding: 0 15px !important;\n    height: 60px;\n    line-height: 60px;\n  }\n\n  .front-header-dropdown {\n    display: flex;\n    align-items: center;\n    cursor: pointer;\n  }\n\n  .front-header-dropdown img {\n    width: 35px;\n    height: 35px;\n    border-radius: 50%;\n    margin-right: 8px;\n  }\n\n  .user-info {\n    color: #fff;\n  }\n</style>"],"mappings":";AAuFA,OAAAA,WAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IACAF;EACA;EACAG,KAAA;IACA;MACA;MACAC,IAAA,EAAAC,IAAA,CAAAC,KAAA,CAAAC,YAAA,CAAAC,OAAA;IACA;EACA;EACA;EACAC,KAAA;IACA,QAAAC,CAAA;MACA,KAAAC,UAAA;IACA;EACA;EACAC,OAAA;IACAD,WAAA;MACA,KAAAP,IAAA,GAAAC,IAAA,CAAAC,KAAA,CAAAC,YAAA,CAAAC,OAAA;IACA;IACAK,OAAA;MACAN,YAAA,CAAAO,UAAA;MACA,KAAAC,OAAA,CAAAC,IAAA;IACA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}