{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  data() {\n    return {\n      show: false,\n      content: '',\n      msgList: [],\n      tempText: '',\n      // 会话ID（固定即可，无需复杂生成）\n      sessionId: 'default_user'\n    };\n  },\n  methods: {\n    // 发送消息\n    sendMsg() {\n      if (!this.content) return;\n      // 追加用户消息\n      this.msgList.push({\n        role: 'user',\n        content: this.content\n      });\n      let msg = this.content;\n      this.content = '';\n      this.tempText = '';\n\n      // 调用后端AI接口（对接你的 /ai/chat）\n      const es = new EventSource(`/ai/chat?sessionId=${this.sessionId}&message=${encodeURIComponent(msg)}`);\n      es.onmessage = event => {\n        // 开始标记，跳过\n        if (event.data === '[START]') return;\n        // 结束标记，保存完整消息\n        if (event.data === '[DONE]') {\n          this.msgList.push({\n            role: 'ai',\n            content: this.tempText\n          });\n          this.tempText = '';\n          es.close();\n          return;\n        }\n        // 打字机效果拼接文字\n        this.tempText += event.data;\n      };\n\n      // 异常处理\n      es.onerror = () => {\n        this.tempText = 'AI服务连接失败，请检查后端配置';\n        es.close();\n      };\n    }\n  }\n};","map":{"version":3,"names":["data","show","content","msgList","tempText","sessionId","methods","sendMsg","push","role","msg","es","EventSource","encodeURIComponent","onmessage","event","close","onerror"],"sources":["src/components/AiAssistant.vue"],"sourcesContent":["<template>\n  <!-- AI助手悬浮窗口 -->\n  <div class=\"ai-chat\">\n    <!-- 悬浮按钮 -->\n    <div class=\"chat-btn\" @click=\"show = !show\">AI</div>\n\n    <!-- 聊天对话框 -->\n    <div class=\"chat-window\" v-show=\"show\">\n      <div class=\"chat-header\">\n        AI助手\n        <span @click=\"show = false\">×</span>\n      </div>\n\n      <!-- 聊天内容区域 -->\n      <div class=\"chat-content\" ref=\"content\">\n        <div class=\"ai-reply\" v-if=\"msgList.length === 0\">您好，请问有什么可以帮您？</div>\n        <!-- 用户消息 -->\n        <div class=\"user-msg\" v-for=\"(item, index) in msgList\" :key=\"index\" v-if=\"item.role === 'user'\">\n          {{ item.content }}\n        </div>\n        <!-- AI回复 -->\n        <div class=\"ai-reply\" v-for=\"(item, index) in msgList\" :key=\"index\" v-if=\"item.role === 'ai'\">\n          {{ item.content }}\n        </div>\n        <!-- 打字机效果 -->\n        <div class=\"ai-reply\" v-if=\"tempText\">{{ tempText }}</div>\n      </div>\n\n      <!-- 输入框 -->\n      <div class=\"chat-input\">\n        <input v-model=\"content\" @keyup.enter=\"sendMsg\" placeholder=\"输入问题...\"/>\n        <button @click=\"sendMsg\">发送</button>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      show: false,\n      content: '',\n      msgList: [],\n      tempText: '',\n      // 会话ID（固定即可，无需复杂生成）\n      sessionId: 'default_user'\n    }\n  },\n  methods: {\n    // 发送消息\n    sendMsg() {\n      if (!this.content) return\n      // 追加用户消息\n      this.msgList.push({ role: 'user', content: this.content })\n      let msg = this.content\n      this.content = ''\n      this.tempText = ''\n\n      // 调用后端AI接口（对接你的 /ai/chat）\n      const es = new EventSource(`/ai/chat?sessionId=${this.sessionId}&message=${encodeURIComponent(msg)}`)\n      \n      es.onmessage = (event) => {\n        // 开始标记，跳过\n        if (event.data === '[START]') return\n        // 结束标记，保存完整消息\n        if (event.data === '[DONE]') {\n          this.msgList.push({ role: 'ai', content: this.tempText })\n          this.tempText = ''\n          es.close()\n          return\n        }\n        // 打字机效果拼接文字\n        this.tempText += event.data\n      }\n\n      // 异常处理\n      es.onerror = () => {\n        this.tempText = 'AI服务连接失败，请检查后端配置'\n        es.close()\n      }\n    }\n  }\n}\n</script>\n\n<style scoped>\n/* 基础定位 */\n.ai-chat {\n  position: fixed;\n  bottom: 20px;\n  right: 20px;\n  z-index: 9999;\n}\n\n/* 悬浮按钮 */\n.chat-btn {\n  width: 55px;\n  height: 55px;\n  background: #1677ff;\n  color: white;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 16px;\n  cursor: pointer;\n}\n\n/* 聊天窗口 */\n.chat-window {\n  position: absolute;\n  bottom: 70px;\n  right: 0;\n  width: 330px;\n  height: 480px;\n  background: #fff;\n  border-radius: 8px;\n  box-shadow: 0 0 10px rgba(0,0,0,0.1);\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n}\n\n/* 窗口头部 */\n.chat-header {\n  padding: 12px;\n  background: #1677ff;\n  color: white;\n  display: flex;\n  justify-content: space-between;\n}\n.chat-header span {\n  cursor: pointer;\n}\n\n/* 内容区域 */\n.chat-content {\n  flex: 1;\n  padding: 15px;\n  background: #f5f7fa;\n  overflow-y: auto;\n}\n/* 用户消息 */\n.user-msg {\n  text-align: right;\n  margin: 8px 0;\n  color: white;\n  background: #1677ff;\n  display: inline-block;\n  float: right;\n  padding: 6px 12px;\n  border-radius: 15px;\n}\n/* AI消息 */\n.ai-reply {\n  text-align: left;\n  margin: 8px 0;\n  background: white;\n  display: inline-block;\n  padding: 6px 12px;\n  border-radius: 15px;\n  box-shadow: 0 1px 2px rgba(0,0,0,0.1);\n}\n\n/* 输入框区域 */\n.chat-input {\n  display: flex;\n  padding: 10px;\n  border-top: 1px solid #eee;\n}\n.chat-input input {\n  flex: 1;\n  padding: 8px;\n  border: 1px solid #ddd;\n  border-radius: 20px;\n  outline: none;\n}\n.chat-input button {\n  margin-left: 8px;\n  padding: 8px 15px;\n  background: #1677ff;\n  color: white;\n  border: none;\n  border-radius: 20px;\n  cursor: pointer;\n}\n</style>"],"mappings":";AAsCA;EACAA,KAAA;IACA;MACAC,IAAA;MACAC,OAAA;MACAC,OAAA;MACAC,QAAA;MACA;MACAC,SAAA;IACA;EACA;EACAC,OAAA;IACA;IACAC,QAAA;MACA,UAAAL,OAAA;MACA;MACA,KAAAC,OAAA,CAAAK,IAAA;QAAAC,IAAA;QAAAP,OAAA,OAAAA;MAAA;MACA,IAAAQ,GAAA,QAAAR,OAAA;MACA,KAAAA,OAAA;MACA,KAAAE,QAAA;;MAEA;MACA,MAAAO,EAAA,OAAAC,WAAA,4BAAAP,SAAA,YAAAQ,kBAAA,CAAAH,GAAA;MAEAC,EAAA,CAAAG,SAAA,GAAAC,KAAA;QACA;QACA,IAAAA,KAAA,CAAAf,IAAA;QACA;QACA,IAAAe,KAAA,CAAAf,IAAA;UACA,KAAAG,OAAA,CAAAK,IAAA;YAAAC,IAAA;YAAAP,OAAA,OAAAE;UAAA;UACA,KAAAA,QAAA;UACAO,EAAA,CAAAK,KAAA;UACA;QACA;QACA;QACA,KAAAZ,QAAA,IAAAW,KAAA,CAAAf,IAAA;MACA;;MAEA;MACAW,EAAA,CAAAM,OAAA;QACA,KAAAb,QAAA;QACAO,EAAA,CAAAK,KAAA;MACA;IACA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}