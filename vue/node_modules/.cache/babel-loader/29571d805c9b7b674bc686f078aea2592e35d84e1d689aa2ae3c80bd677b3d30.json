{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport Footer from \"@/components/Footer\";\nexport default {\n  name: \"FrontRiskTest\",\n  components: {\n    Footer\n  },\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\n      quizList: [],\n      passedCount: 0,\n      bestRecordMap: {},\n      // { quizId: record }\n      quizStarted: false,\n      currentQuiz: {},\n      questionList: [],\n      currentQuestionIndex: 0,\n      userAnswers: [],\n      totalScore: 0,\n      resultDialogVisible: false,\n      quizResult: {\n        pass: false,\n        score: 0,\n        correctCount: 0\n      }\n    };\n  },\n  computed: {\n    currentQuestion() {\n      return this.questionList[this.currentQuestionIndex] || {};\n    }\n  },\n  created() {\n    this.loadQuizList();\n    if (this.user.id) {\n      this.loadUserProgress();\n    }\n  },\n  methods: {\n    // 加载关卡列表\n    loadQuizList() {\n      this.$request.get('/quiz/selectPublished').then(res => {\n        if (res.code === '200') {\n          this.quizList = res.data || [];\n        }\n      });\n    },\n    // 加载用户进度\n    loadUserProgress() {\n      // 查询已通过的关卡数\n      this.$request.get(`/userQuizRecord/countPassedQuiz/${this.user.id}`).then(res => {\n        if (res.code === '200') {\n          this.passedCount = res.data || 0;\n        }\n      });\n      // 查询每个关卡的最佳记录\n      this.quizList.forEach(quiz => {\n        this.$request.get('/userQuizRecord/selectBestRecord', {\n          params: {\n            userId: this.user.id,\n            quizId: quiz.id\n          }\n        }).then(res => {\n          if (res.code === '200' && res.data) {\n            this.$set(this.bestRecordMap, quiz.id, res.data);\n          }\n        });\n      });\n    },\n    // 开始闯关\n    startQuiz(quiz) {\n      if (!this.user.id) {\n        this.$message.warning('请先登录后再进行考核测试');\n        this.$router.push('/login');\n        return;\n      }\n      this.currentQuiz = quiz;\n      this.quizStarted = true;\n      this.currentQuestionIndex = 0;\n      this.userAnswers = [];\n      this.totalScore = 0;\n      // 加载题目\n      this.loadQuestions(quiz.id);\n    },\n    // 加载题目\n    loadQuestions(quizId) {\n      this.$request.get(`/question/selectByQuizId/${quizId}`).then(res => {\n        if (res.code === '200') {\n          this.questionList = res.data || [];\n          this.userAnswers = new Array(this.questionList.length).fill('');\n        }\n      });\n    },\n    // 上一题\n    prevQuestion() {\n      if (this.currentQuestionIndex > 0) {\n        this.currentQuestionIndex--;\n      }\n    },\n    // 下一题\n    nextQuestion() {\n      if (!this.userAnswers[this.currentQuestionIndex]) {\n        this.$message.warning('请选择答案后再继续');\n        return;\n      }\n      this.currentQuestionIndex++;\n    },\n    // 提交答卷\n    submitQuiz() {\n      // 检查是否所有题目都已作答\n      const unanswered = this.userAnswers.findIndex(answer => !answer);\n      if (unanswered !== -1) {\n        this.$message.warning(`还有第${unanswered + 1}题未作答`);\n        this.currentQuestionIndex = unanswered;\n        return;\n      }\n\n      // 计算得分\n      let correctCount = 0;\n      let score = 0;\n      this.questionList.forEach((question, index) => {\n        if (this.userAnswers[index] === question.correctAnswer) {\n          correctCount++;\n          score += question.score;\n        }\n      });\n      this.totalScore = score;\n      this.quizResult = {\n        pass: score >= this.currentQuiz.passScore,\n        score: score,\n        correctCount: correctCount\n      };\n\n      // 保存记录\n      const record = {\n        userId: this.user.id,\n        quizId: this.currentQuiz.id,\n        score: score,\n        passStatus: this.quizResult.pass ? '已通过' : '未通过',\n        answers: JSON.stringify(this.userAnswers)\n      };\n      this.$request.post('/userQuizRecord/add', record).then(res => {\n        if (res.code === '200') {\n          this.resultDialogVisible = true;\n          if (this.quizResult.pass) {\n            this.loadUserProgress();\n          }\n        }\n      });\n    },\n    // 返回关卡列表\n    backToList() {\n      this.quizStarted = false;\n      this.resultDialogVisible = false;\n      this.loadUserProgress();\n    },\n    // 重新挑战\n    retryQuiz() {\n      this.resultDialogVisible = false;\n      this.startQuiz(this.currentQuiz);\n    },\n    // 查看历史记录\n    viewRecord(quizId) {\n      const record = this.bestRecordMap[quizId];\n      this.$message.info(`最佳成绩：${record.score}分，状态：${record.passStatus}`);\n    }\n  }\n};","map":{"version":3,"names":["Footer","name","components","data","user","JSON","parse","localStorage","getItem","quizList","passedCount","bestRecordMap","quizStarted","currentQuiz","questionList","currentQuestionIndex","userAnswers","totalScore","resultDialogVisible","quizResult","pass","score","correctCount","computed","currentQuestion","created","loadQuizList","id","loadUserProgress","methods","$request","get","then","res","code","forEach","quiz","params","userId","quizId","$set","startQuiz","$message","warning","$router","push","loadQuestions","Array","length","fill","prevQuestion","nextQuestion","submitQuiz","unanswered","findIndex","answer","question","index","correctAnswer","passScore","record","passStatus","answers","stringify","post","backToList","retryQuiz","viewRecord","info"],"sources":["src/views/front/RiskTest.vue"],"sourcesContent":["<template>\n  <div class=\"blog-detail-container\">\n    <!-- 页面头部（对齐博客详情页头部风格） -->\n    <div class=\"article-header\">\n      <div class=\"article-type\">\n        <el-tag type=\"primary\" size=\"medium\">能力测评</el-tag>\n      </div>\n      <h1 class=\"article-title\">\n        <i class=\"el-icon-medal\"></i> 法治考核\n      </h1>\n      <p class=\"article-summary-text\">通过答题闯关，测试你的法治知识水平</p>\n      <div v-if=\"user.id\" class=\"article-meta\">\n        <span class=\"meta-item\">\n          <i class=\"el-icon-trophy\"></i>\n          已通过 {{ passedCount }} 关\n        </span>\n      </div>\n    </div>\n\n    <!-- 关卡列表（对齐博客内容卡片风格） -->\n    <div v-if=\"!quizStarted\" class=\"article-content-card\">\n      <div class=\"quiz-list\">\n        <div\n          v-for=\"(quiz, index) in quizList\"\n          :key=\"quiz.id\"\n          class=\"quiz-card-wrapper\"\n        >\n          <div class=\"quiz-header\">\n            <div class=\"quiz-level\" :class=\"'level-' + quiz.level\">\n              第{{ quiz.level }}关\n            </div>\n            <h3 class=\"quiz-title\">{{ quiz.title }}</h3>\n            <p class=\"quiz-descr\">{{ quiz.descr }}</p>\n            <div class=\"quiz-info\">\n              <span><i class=\"el-icon-document\"></i> 共4题</span>\n              <span><i class=\"el-icon-trophy\"></i> 及格分: {{ quiz.passScore }}分</span>\n            </div>\n          </div>\n          <div class=\"quiz-actions\">\n            <el-button\n              type=\"primary\"\n              size=\"medium\"\n              @click=\"startQuiz(quiz)\"\n              :disabled=\"index > 0 && passedCount < index\"\n            >\n              <i class=\"el-icon-right\"></i>\n              {{ index > 0 && passedCount < index ? '需通过前一关' : '开始闯关' }}\n            </el-button>\n            <div v-if=\"bestRecordMap[quiz.id]\" class=\"best-score\">\n              最佳: {{ bestRecordMap[quiz.id].score }}分\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 答题界面（对齐博客内容卡片风格） -->\n    <div v-else class=\"article-content-card\">\n      <div class=\"quiz-test-header\">\n        <h2 class=\"article-title\" style=\"font-size: 24px;\">{{ currentQuiz.title }}</h2>\n        <p class=\"article-summary-text\">{{ currentQuiz.descr }}</p>\n        <div class=\"article-meta\">\n          <span class=\"meta-item\">\n            <i class=\"el-icon-s-order\"></i>\n            进度: {{ currentQuestionIndex + 1 }} / {{ questionList.length }}\n          </span>\n          <span class=\"meta-item\">\n            <i class=\"el-icon-star-on\"></i>\n            得分: {{ totalScore }} / 100\n          </span>\n        </div>\n      </div>\n\n      <div v-if=\"currentQuestionIndex < questionList.length\" class=\"question-container\">\n        <div class=\"question-number\">第 {{ currentQuestionIndex + 1 }} 题</div>\n        <div class=\"question-content\">{{ currentQuestion.content }}</div>\n        <el-radio-group v-model=\"userAnswers[currentQuestionIndex]\" class=\"option-group\">\n          <el-radio label=\"A\" class=\"option-item\">\n            <span class=\"option-label\">A.</span>\n            <span class=\"option-text\">{{ currentQuestion.optionA }}</span>\n          </el-radio>\n          <el-radio label=\"B\" class=\"option-item\">\n            <span class=\"option-label\">B.</span>\n            <span class=\"option-text\">{{ currentQuestion.optionB }}</span>\n          </el-radio>\n          <el-radio label=\"C\" class=\"option-item\">\n            <span class=\"option-label\">C.</span>\n            <span class=\"option-text\">{{ currentQuestion.optionC }}</span>\n          </el-radio>\n          <el-radio label=\"D\" class=\"option-item\">\n            <span class=\"option-label\">D.</span>\n            <span class=\"option-text\">{{ currentQuestion.optionD }}</span>\n          </el-radio>\n        </el-radio-group>\n\n        <div class=\"question-actions\">\n          <el-button @click=\"prevQuestion\" :disabled=\"currentQuestionIndex === 0\">\n            <i class=\"el-icon-back\"></i> 上一题\n          </el-button>\n          <el-button type=\"primary\" @click=\"nextQuestion\" v-if=\"currentQuestionIndex < questionList.length - 1\">\n            下一题 <i class=\"el-icon-right\"></i>\n          </el-button>\n          <el-button type=\"primary\" @click=\"submitQuiz\" v-else>\n            <i class=\"el-icon-check\"></i> 提交答卷\n          </el-button>\n        </div>\n      </div>\n    </div>\n\n    <!-- 结果展示对话框 -->\n    <el-dialog title=\"闯关结果\" :visible.sync=\"resultDialogVisible\" width=\"50%\" :close-on-click-modal=\"false\">\n      <div style=\"text-align: center\">\n        <div v-if=\"quizResult.pass\" style=\"color: #67C23A\">\n          <i class=\"el-icon-success\" style=\"font-size: 80px\"></i>\n          <h2>恭喜通过！</h2>\n        </div>\n        <div v-else style=\"color: #F56C6C\">\n          <i class=\"el-icon-error\" style=\"font-size: 80px\"></i>\n          <h2>未通过，再接再厉！</h2>\n        </div>\n        <div style=\"margin: 30px 0; font-size: 24px\">\n          得分: <span :style=\"{color: quizResult.pass ? '#67C23A' : '#F56C6C'}\">{{ quizResult.score }}</span> / 100\n        </div>\n        <div style=\"margin: 20px 0\">\n          <p style=\"color: #909399\">及格分数: {{ currentQuiz.passScore }}分</p>\n          <p style=\"color: #909399\">正确题数: {{ quizResult.correctCount }} / {{ questionList.length }}</p>\n        </div>\n      </div>\n      <div slot=\"footer\">\n        <el-button @click=\"backToList\">返回关卡列表</el-button>\n        <el-button type=\"primary\" @click=\"retryQuiz\">重新挑战</el-button>\n      </div>\n    </el-dialog>\n\n    <Footer />\n  </div>\n</template>\n\n<script>\nimport Footer from \"@/components/Footer\";\n\nexport default {\n  name: \"FrontRiskTest\",\n  components: {\n    Footer\n  },\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\n      quizList: [],\n      passedCount: 0,\n      bestRecordMap: {},  // { quizId: record }\n      quizStarted: false,\n      currentQuiz: {},\n      questionList: [],\n      currentQuestionIndex: 0,\n      userAnswers: [],\n      totalScore: 0,\n      resultDialogVisible: false,\n      quizResult: {\n        pass: false,\n        score: 0,\n        correctCount: 0\n      }\n    }\n  },\n  computed: {\n    currentQuestion() {\n      return this.questionList[this.currentQuestionIndex] || {}\n    }\n  },\n  created() {\n    this.loadQuizList()\n    if (this.user.id) {\n      this.loadUserProgress()\n    }\n  },\n  methods: {\n    // 加载关卡列表\n    loadQuizList() {\n      this.$request.get('/quiz/selectPublished').then(res => {\n        if (res.code === '200') {\n          this.quizList = res.data || []\n        }\n      })\n    },\n    // 加载用户进度\n    loadUserProgress() {\n      // 查询已通过的关卡数\n      this.$request.get(`/userQuizRecord/countPassedQuiz/${this.user.id}`).then(res => {\n        if (res.code === '200') {\n          this.passedCount = res.data || 0\n        }\n      })\n      // 查询每个关卡的最佳记录\n      this.quizList.forEach(quiz => {\n        this.$request.get('/userQuizRecord/selectBestRecord', {\n          params: {\n            userId: this.user.id,\n            quizId: quiz.id\n          }\n        }).then(res => {\n          if (res.code === '200' && res.data) {\n            this.$set(this.bestRecordMap, quiz.id, res.data)\n          }\n        })\n      })\n    },\n    // 开始闯关\n    startQuiz(quiz) {\n      if (!this.user.id) {\n        this.$message.warning('请先登录后再进行考核测试')\n        this.$router.push('/login')\n        return\n      }\n      this.currentQuiz = quiz\n      this.quizStarted = true\n      this.currentQuestionIndex = 0\n      this.userAnswers = []\n      this.totalScore = 0\n      // 加载题目\n      this.loadQuestions(quiz.id)\n    },\n    // 加载题目\n    loadQuestions(quizId) {\n      this.$request.get(`/question/selectByQuizId/${quizId}`).then(res => {\n        if (res.code === '200') {\n          this.questionList = res.data || []\n          this.userAnswers = new Array(this.questionList.length).fill('')\n        }\n      })\n    },\n    // 上一题\n    prevQuestion() {\n      if (this.currentQuestionIndex > 0) {\n        this.currentQuestionIndex--\n      }\n    },\n    // 下一题\n    nextQuestion() {\n      if (!this.userAnswers[this.currentQuestionIndex]) {\n        this.$message.warning('请选择答案后再继续')\n        return\n      }\n      this.currentQuestionIndex++\n    },\n    // 提交答卷\n    submitQuiz() {\n      // 检查是否所有题目都已作答\n      const unanswered = this.userAnswers.findIndex(answer => !answer)\n      if (unanswered !== -1) {\n        this.$message.warning(`还有第${unanswered + 1}题未作答`)\n        this.currentQuestionIndex = unanswered\n        return\n      }\n\n      // 计算得分\n      let correctCount = 0\n      let score = 0\n      this.questionList.forEach((question, index) => {\n        if (this.userAnswers[index] === question.correctAnswer) {\n          correctCount++\n          score += question.score\n        }\n      })\n\n      this.totalScore = score\n      this.quizResult = {\n        pass: score >= this.currentQuiz.passScore,\n        score: score,\n        correctCount: correctCount\n      }\n\n      // 保存记录\n      const record = {\n        userId: this.user.id,\n        quizId: this.currentQuiz.id,\n        score: score,\n        passStatus: this.quizResult.pass ? '已通过' : '未通过',\n        answers: JSON.stringify(this.userAnswers)\n      }\n\n      this.$request.post('/userQuizRecord/add', record).then(res => {\n        if (res.code === '200') {\n          this.resultDialogVisible = true\n          if (this.quizResult.pass) {\n            this.loadUserProgress()\n          }\n        }\n      })\n    },\n    // 返回关卡列表\n    backToList() {\n      this.quizStarted = false\n      this.resultDialogVisible = false\n      this.loadUserProgress()\n    },\n    // 重新挑战\n    retryQuiz() {\n      this.resultDialogVisible = false\n      this.startQuiz(this.currentQuiz)\n    },\n    // 查看历史记录\n    viewRecord(quizId) {\n      const record = this.bestRecordMap[quizId]\n      this.$message.info(`最佳成绩：${record.score}分，状态：${record.passStatus}`)\n    }\n  }\n}\n</script>\n\n<style scoped>\n/* 复用博客详情页的容器与基础布局 */\n.blog-detail-container {\n  width: 75%;\n  max-width: 960px;\n  margin: 20px auto;\n}\n\n/* 复用博客详情页的头部样式 */\n.article-header {\n  background: #fff;\n  border-radius: 4px;\n  padding: 35px 40px;\n  margin-bottom: 15px;\n  text-align: center;\n  border: 1px solid #e8e8e8;\n  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);\n}\n\n.article-type {\n  margin-bottom: 18px;\n}\n\n.article-title {\n  font-size: 28px;\n  font-weight: 600;\n  color: #1a1a1a;\n  line-height: 1.5;\n  margin: 0 0 20px 0;\n}\n\n.article-title i {\n  margin-right: 8px;\n  color: #1d3557;\n}\n\n.article-summary-text {\n  color: #666;\n  font-size: 15px;\n  line-height: 1.8;\n  margin: 0;\n}\n\n.article-meta {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 20px;\n  padding-top: 18px;\n  border-top: 1px solid #e8e8e8;\n}\n\n.meta-item {\n  display: flex;\n  align-items: center;\n  gap: 5px;\n  color: #999;\n  font-size: 14px;\n}\n\n.meta-item i {\n  font-size: 14px;\n}\n\n/* 复用博客详情页的内容卡片样式 */\n.article-content-card {\n  background: #fff;\n  border-radius: 4px;\n  padding: 35px 40px;\n  border: 1px solid #e8e8e8;\n  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);\n  margin-bottom: 15px;\n}\n\n/* 关卡列表网格布局 */\n.quiz-list {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));\n  gap: 20px;\n}\n\n.quiz-card-wrapper {\n  padding: 20px;\n  border: 1px solid #e8e8e8;\n  border-radius: 4px;\n  transition: box-shadow 0.2s;\n}\n\n.quiz-card-wrapper:hover {\n  box-shadow: 0 2px 8px rgba(0,0,0,.1);\n}\n\n.quiz-header {\n  text-align: center;\n}\n\n.quiz-level {\n  display: inline-block;\n  padding: 4px 12px;\n  font-weight: 500;\n  margin-bottom: 10px;\n  font-size: 13px;\n}\n\n.level-1 { background: #e8f0f8; color: #1d3557; }\n.level-2 { background: #e8f5e9; color: #388e3c; }\n.level-3 { background: #fff3e0; color: #f57c00; }\n.level-4 { background: #fce4ec; color: #c2185b; }\n\n.quiz-title {\n  margin: 10px 0;\n  color: #333;\n  font-size: 18px;\n  font-weight: 600;\n}\n\n.quiz-descr {\n  color: #666;\n  margin: 10px 0;\n  font-size: 14px;\n}\n\n.quiz-info {\n  display: flex;\n  justify-content: center;\n  gap: 20px;\n  margin: 12px 0;\n  color: #999;\n  font-size: 13px;\n}\n\n.quiz-info i {\n  margin-right: 4px;\n}\n\n.quiz-actions {\n  text-align: center;\n  margin-top: 15px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 10px;\n}\n\n.best-score {\n  font-size: 13px;\n  color: #999;\n}\n\n/* 答题界面样式 */\n.quiz-test-header {\n  text-align: center;\n  padding-bottom: 18px;\n  border-bottom: 1px solid #f0f0f0;\n  margin-bottom: 28px;\n}\n\n.question-container {\n  max-width: 800px;\n  margin: 0 auto;\n}\n\n.question-number {\n  font-size: 16px;\n  font-weight: 600;\n  color: #1d3557;\n  margin-bottom: 12px;\n}\n\n.question-content {\n  font-size: 16px;\n  color: #333;\n  line-height: 1.8;\n  margin-bottom: 24px;\n  padding: 18px;\n  background: #f9f9f9;\n  border-left: 3px solid #1d3557;\n}\n\n.option-group {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n\n/deep/ .option-item {\n  margin: 0 !important;\n  padding: 14px;\n  border: 1px solid #e8e8e8;\n  transition: all 0.2s;\n  display: flex;\n  align-items: flex-start;\n}\n\n/deep/ .option-item:hover {\n  border-color: #1d3557;\n  background: #e8f0f8;\n}\n\n/deep/ .option-item.is-checked {\n  border-color: #1d3557;\n  background: #e8f0f8;\n}\n\n.option-label {\n  font-weight: 600;\n  color: #1d3557;\n  margin-right: 10px;\n}\n\n.option-text {\n  flex: 1;\n  color: #666;\n  line-height: 1.6;\n}\n\n.question-actions {\n  margin-top: 32px;\n  text-align: center;\n  display: flex;\n  justify-content: center;\n  gap: 12px;\n}\n\n/* 响应式设计（复用博客详情页逻辑） */\n@media (max-width: 1024px) {\n  .blog-detail-container {\n    width: 90%;\n  }\n}\n\n@media (max-width: 768px) {\n  .blog-detail-container {\n    width: 100%;\n    padding: 0 10px;\n    margin: 10px auto;\n  }\n  \n  .article-header,\n  .article-content-card {\n    padding: 24px 20px;\n  }\n  \n  .article-title {\n    font-size: 22px;\n  }\n  \n  .article-meta {\n    flex-wrap: wrap;\n    gap: 15px;\n  }\n  \n  .quiz-list {\n    grid-template-columns: 1fr;\n  }\n  \n  .question-actions {\n    flex-direction: column;\n  }\n}\n</style>"],"mappings":";AA2IA,OAAAA,MAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IACAF;EACA;EACAG,KAAA;IACA;MACAC,IAAA,EAAAC,IAAA,CAAAC,KAAA,CAAAC,YAAA,CAAAC,OAAA