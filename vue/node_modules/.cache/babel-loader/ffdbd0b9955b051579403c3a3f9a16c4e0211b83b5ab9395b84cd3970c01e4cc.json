{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: \"Manager\",\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}')\n    };\n  },\n  created() {\n    if (!this.user.id && this.user.role !== \"ADMIN\") {\n      this.$router.push('/login');\n    }\n  },\n  methods: {\n    updateUser() {\n      this.user = JSON.parse(localStorage.getItem('xm-user') || '{}');\n    },\n    goToPerson() {\n      if (this.user.role === 'ADMIN') {\n        this.$router.push('/adminPerson');\n      }\n    },\n    logout() {\n      localStorage.removeItem('xm-user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["name","data","user","JSON","parse","localStorage","getItem","created","id","role","$router","push","methods","updateUser","goToPerson","logout","removeItem"],"sources":["src/views/Manager.vue"],"sourcesContent":["<template>\n  <div class=\"manager-container\">\n    <!-- 头部 -->\n    <div class=\"manager-header\">\n      <div class=\"manager-header-left\">\n        <img src=\"../assets/imgs/logo.png\" />\n        <div class=\"title\">网格化依法治理管理平台</div>\n      </div>\n\n      <div class=\"manager-header-center\">\n        <el-breadcrumb separator-class=\"el-icon-arrow-right\">\n          <el-breadcrumb-item :to=\"{ path: '/' }\">首页</el-breadcrumb>\n          <el-breadcrumb-item :to=\"{ path: $route.path }\">{{ $route.meta.name }}</el-breadcrumb>\n        </el-breadcrumb>\n      </div>\n\n      <div class=\"manager-header-right\">\n        <el-dropdown placement=\"bottom\">\n          <div class=\"avatar\">\n            <img :src=\"user.avatar || 'https://cube.elemecdn.com/3/7c/3ea6beec64369c2642b92c6726f1epng.png'\" />\n            <div>{{ user.name ||  '管理员' }}</div>\n          </div>\n          <el-dropdown-menu slot=\"dropdown\">\n            <el-dropdown-item @click.native=\"goToPerson\">个人信息</el-dropdown-item>\n            <el-dropdown-item @click.native=\"$router.push('/password')\">修改密码</el-dropdown-item>\n            <el-dropdown-item @click.native=\"logout\">退出登录</el-dropdown-item>\n          </el-dropdown-menu>\n        </el-dropdown>\n      </div>\n    </div>\n\n    <!-- 主体 -->\n    <div class=\"manager-main\">\n      <!-- 侧边栏（关键修复：加theme=\"light\" + 强制文字颜色） -->\n      <div class=\"manager-main-left\">\n        <el-menu \n          :default-openeds=\"['info', 'user', 'learning']\" \n          router \n          style=\"border: none\" \n          :default-active=\"$route.path\"\n          theme=\"light\"  <!-- 强制浅色主题，文字默认深灰色 -->\n        >\n          <el-menu-item index=\"/home\">\n            <span slot=\"title\">系统首页</span>\n          </el-menu-item>\n\n          <!-- 信息管理 -->\n          <el-submenu index=\"info\">\n            <template slot=\"title\">\n              <span>信息管理</span>\n            </template>\n            <el-menu-item index=\"/category\">事件分类</el-menu-item>\n            <el-menu-item index=\"/blog\">工作日志</el-menu-item>\n            <el-menu-item index=\"/activity\">治理任务</el-menu-item>\n            <el-menu-item index=\"/comment\">评论信息</el-menu-item>\n            <el-menu-item index=\"/activitySign\">签到信息</el-menu-item>\n            <el-menu-item index=\"/law\">法律法规</el-menu-item>\n            <el-menu-item index=\"/knowledge\">治理案例库</el-menu-item>\n            <el-menu-item index=\"/report\">事件上报</el-menu-item>\n          </el-submenu>\n\n          <!-- 法治培训 -->\n          <el-submenu index=\"learning\">\n            <template slot=\"title\">\n              <span>法治培训</span>\n            </template>\n            <el-menu-item index=\"/chapter\">章节管理</el-menu-item>\n            <el-menu-item index=\"/lesson\">课时管理</el-menu-item>\n          </el-submenu>\n\n          <!-- 用户管理 -->\n          <el-submenu index=\"user\">\n            <template slot=\"title\">\n              <span>用户管理</span>\n            </template>\n            <el-menu-item index=\"/admin\">管理员信息</el-menu-item>\n            <el-menu-item index=\"/user\">网格员/社区居民信息</el-menu-item>\n          </el-submenu>\n\n          <!-- 公告信息 -->\n          <el-menu-item index=\"/notice\">\n            <span slot=\"title\">公告信息</span>\n          </el-menu-item>\n        </el-menu>\n      </div>\n\n      <!-- 数据表格 -->\n      <div class=\"manager-main-right\">\n        <router-view @update:user=\"updateUser\" />\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"Manager\",\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\n    }\n  },\n  created() {\n    if (!this.user.id&&this.user.role!==\"ADMIN\") {\n      this.$router.push('/login')\n    }\n  },\n  methods: {\n    updateUser() {\n      this.user = JSON.parse(localStorage.getItem('xm-user') || '{}')\n    },\n    goToPerson() {\n      if (this.user.role === 'ADMIN') {\n        this.$router.push('/adminPerson')\n      }\n    },\n    logout() {\n      localStorage.removeItem('xm-user')\n      this.$router.push('/login')\n    }\n  }\n}\n</script>\n\n<style scoped>\n/* 基础布局 */\n.manager-container {\n  height: 100vh;\n  display: flex;\n  flex-direction: column;\n}\n.manager-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  height: 60px;\n  background: #2a60c9;\n  color: white;\n  padding: 0 20px;\n}\n.manager-header-left {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n}\n.manager-main {\n  display: flex;\n  flex: 1;\n  overflow: hidden;\n}\n.manager-main-left {\n  width: 220px;\n  background: #fff;\n  border-right: 1px solid #eee;\n}\n.manager-main-right {\n  flex: 1;\n  padding: 20px;\n  overflow-y: auto;\n  background: #f5f7fa;\n}\n.avatar {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  cursor: pointer;\n}\n.avatar img {\n  width: 32px;\n  height: 32px;\n  border-radius: 50%;\n}\n\n/* 关键修复：强制所有菜单文字为深灰色，再也不会隐身 */\n:deep(.el-menu) {\n  background-color: #fff !important;\n}\n:deep(.el-menu-item) {\n  color: #303133 !important;\n}\n:deep(.el-submenu__title) {\n  color: #303133 !important;\n}\n:deep(.el-menu-item.is-active) {\n  background-color: #ecf5ff !important;\n  color: #409eff !important;\n}\n</style>"],"mappings":";AA+FA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,IAAA,EAAAC,IAAA,CAAAC,KAAA,CAAAC,YAAA,CAAAC,OAAA;IACA;EACA;EACAC,QAAA;IACA,UAAAL,IAAA,CAAAM,EAAA,SAAAN,IAAA,CAAAO,IAAA;MACA,KAAAC,OAAA,CAAAC,IAAA;IACA;EACA;EACAC,OAAA;IACAC,WAAA;MACA,KAAAX,IAAA,GAAAC,IAAA,CAAAC,KAAA,CAAAC,YAAA,CAAAC,OAAA;IACA;IACAQ,WAAA;MACA,SAAAZ,IAAA,CAAAO,IAAA;QACA,KAAAC,OAAA,CAAAC,IAAA;MACA;IACA;IACAI,OAAA;MACAV,YAAA,CAAAW,UAAA;MACA,KAAAN,OAAA,CAAAC,IAAA;IACA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}