{"ast":null,"code":"export default {\n  name: 'ManagerQuiz',\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\n      title: '',\n      level: null,\n      status: '',\n      tableData: [],\n      pageNum: 1,\n      pageSize: 10,\n      total: 0,\n      dialogVisible: false,\n      form: {},\n      rules: {\n        title: [{\n          required: true,\n          message: '请输入关卡标题',\n          trigger: 'blur'\n        }],\n        descr: [{\n          required: true,\n          message: '请输入关卡简介',\n          trigger: 'blur'\n        }],\n        level: [{\n          required: true,\n          message: '请选择关卡等级',\n          trigger: 'change'\n        }],\n        passScore: [{\n          required: true,\n          message: '请输入及格分数',\n          trigger: 'blur'\n        }],\n        status: [{\n          required: true,\n          message: '请选择状态',\n          trigger: 'change'\n        }]\n      },\n      ids: [],\n      maxLevel: 0 // 当前最大关卡等级\n    };\n  },\n\n  created() {\n    this.load(1);\n    this.loadMaxLevel();\n  },\n  methods: {\n    load(pageNum) {\n      if (pageNum) this.pageNum = pageNum;\n      this.$request.get('/quiz/selectPage', {\n        params: {\n          pageNum: this.pageNum,\n          pageSize: this.pageSize,\n          title: this.title,\n          level: this.level,\n          status: this.status\n        }\n      }).then(res => {\n        if (res.code === '200') {\n          this.tableData = res.data?.list || [];\n          this.total = res.data?.total || 0;\n        }\n      });\n    },\n    reset() {\n      this.title = '';\n      this.level = null;\n      this.status = '';\n      this.load(1);\n    },\n    handleAdd() {\n      // 获取最新的最大关卡等级\n      this.loadMaxLevel().then(() => {\n        // 自动设置为下一关\n        const nextLevel = this.maxLevel + 1;\n        this.form = {\n          sortOrder: nextLevel,\n          status: '已发布',\n          passScore: 60,\n          level: nextLevel\n        };\n        this.dialogVisible = true;\n        this.$nextTick(() => {\n          if (this.$refs.formRef) {\n            this.$refs.formRef.clearValidate();\n          }\n        });\n      });\n    },\n    handleEdit(row) {\n      this.form = JSON.parse(JSON.stringify(row));\n      this.dialogVisible = true;\n      this.$nextTick(() => {\n        if (this.$refs.formRef) {\n          this.$refs.formRef.clearValidate();\n        }\n      });\n    },\n    save() {\n      this.$refs.formRef.validate(valid => {\n        if (valid) {\n          this.$request({\n            url: this.form.id ? '/quiz/update' : '/quiz/add',\n            method: this.form.id ? 'PUT' : 'POST',\n            data: this.form\n          }).then(res => {\n            if (res.code === '200') {\n              this.$message.success('保存成功');\n              this.dialogVisible = false;\n              this.load(1);\n              // 重新加载最大等级\n              this.loadMaxLevel();\n            } else {\n              this.$message.error(res.msg);\n            }\n          });\n        }\n      });\n    },\n    del(id) {\n      this.$confirm('确认删除该关卡吗？删除后相关题目也会失效！', '提示', {\n        type: 'warning'\n      }).then(() => {\n        this.$request.delete('/quiz/delete/' + id).then(res => {\n          if (res.code === '200') {\n            this.$message.success('删除成功');\n            this.load(1);\n            // 重新加载最大等级\n            this.loadMaxLevel();\n          } else {\n            this.$message.error(res.msg);\n          }\n        });\n      }).catch(() => {});\n    },\n    handleSelectionChange(rows) {\n      this.ids = rows.map(v => v.id);\n    },\n    delBatch() {\n      if (!this.ids.length) {\n        this.$message.warning('请选择要删除的数据');\n        return;\n      }\n      this.$confirm('确认批量删除这些关卡吗？删除后相关题目也会失效！', '提示', {\n        type: 'warning'\n      }).then(() => {\n        this.$request.delete('/quiz/delete/batch', {\n          data: this.ids\n        }).then(res => {\n          if (res.code === '200') {\n            this.$message.success('批量删除成功');\n            this.load(1);\n            // 重新加载最大等级\n            this.loadMaxLevel();\n          } else {\n            this.$message.error(res.msg);\n          }\n        });\n      }).catch(() => {});\n    },\n    handleCurrentChange(pageNum) {\n      this.load(pageNum);\n    },\n    // 获取当前最大关卡等级\n    loadMaxLevel() {\n      return this.$request.get('/quiz/selectPage', {\n        params: {\n          pageNum: 1,\n          pageSize: 999\n        }\n      }).then(res => {\n        if (res.code === '200') {\n          const quizzes = res.data?.list || [];\n          if (quizzes.length > 0) {\n            // 找出最大的关卡等级\n            this.maxLevel = Math.max(...quizzes.map(q => q.level || 0));\n          } else {\n            this.maxLevel = 0;\n          }\n        }\n      }).catch(() => {\n        this.maxLevel = 0;\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","user","JSON","parse","localStorage","getItem","title","level","status","tableData","pageNum","pageSize","total","dialogVisible","form","rules","required","message","trigger","descr","passScore","ids","maxLevel","created","load","loadMaxLevel","methods","$request","get","params","then","res","code","list","reset","handleAdd","nextLevel","sortOrder","$nextTick","$refs","formRef","clearValidate","handleEdit","row","stringify","save","validate","valid","url","id","method","$message","success","error","msg","del","$confirm","type","delete","catch","handleSelectionChange","rows","map","v","delBatch","length","warning","handleCurrentChange","quizzes","Math","max","q"],"sources":["src/views/manager/Quiz.vue"],"sourcesContent":["<template>\n  <div>\n    <!-- 搜索区域 -->\n    <div style=\"margin: 10px 0\">\n      <el-input v-model=\"title\" placeholder=\"请输入关卡标题\" style=\"width: 200px\" clearable></el-input>\n      <el-select v-model=\"level\" placeholder=\"请选择关卡等级\" style=\"width: 150px; margin-left: 5px\" clearable>\n        <el-option label=\"第1关\" :value=\"1\"></el-option>\n        <el-option label=\"第2关\" :value=\"2\"></el-option>\n        <el-option label=\"第3关\" :value=\"3\"></el-option>\n        <el-option label=\"第4关\" :value=\"4\"></el-option>\n      </el-select>\n      <el-select v-model=\"status\" placeholder=\"请选择状态\" style=\"width: 150px; margin-left: 5px\" clearable>\n        <el-option label=\"已发布\" value=\"已发布\"></el-option>\n        <el-option label=\"草稿\" value=\"草稿\"></el-option>\n      </el-select>\n      <el-button type=\"primary\" style=\"margin-left: 5px\" @click=\"load(1)\">查询</el-button>\n      <el-button type=\"warning\" style=\"margin-left: 5px\" @click=\"reset\">重置</el-button>\n    </div>\n\n    <!-- 操作按钮 -->\n    <div style=\"margin: 10px 0\">\n      <el-button type=\"primary\" @click=\"handleAdd\">新增 <i class=\"el-icon-circle-plus-outline\"></i></el-button>\n      <el-button type=\"danger\" @click=\"delBatch\">批量删除 <i class=\"el-icon-remove-outline\"></i></el-button>\n    </div>\n\n    <!-- 数据表格 -->\n    <el-table :data=\"tableData\" stripe @selection-change=\"handleSelectionChange\">\n      <el-table-column type=\"selection\" width=\"55\"></el-table-column>\n      <el-table-column prop=\"id\" label=\"ID\" width=\"60\"></el-table-column>\n      <el-table-column prop=\"title\" label=\"关卡标题\" min-width=\"200\"></el-table-column>\n      <el-table-column prop=\"descr\" label=\"简介\" min-width=\"250\" show-overflow-tooltip></el-table-column>\n      <el-table-column prop=\"level\" label=\"关卡等级\" width=\"100\">\n        <template slot-scope=\"scope\">\n          <el-tag v-if=\"scope.row.level === 1\" type=\"primary\" size=\"small\">第{{ scope.row.level }}关</el-tag>\n          <el-tag v-else-if=\"scope.row.level === 2\" type=\"success\" size=\"small\">第{{ scope.row.level }}关</el-tag>\n          <el-tag v-else-if=\"scope.row.level === 3\" type=\"warning\" size=\"small\">第{{ scope.row.level }}关</el-tag>\n          <el-tag v-else type=\"danger\" size=\"small\">第{{ scope.row.level }}关</el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column prop=\"passScore\" label=\"及格分数\" width=\"100\"></el-table-column>\n      <el-table-column prop=\"sortOrder\" label=\"排序\" width=\"80\" sortable></el-table-column>\n      <el-table-column prop=\"createTime\" label=\"创建时间\" width=\"150\"></el-table-column>\n      <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\n        <template slot-scope=\"scope\">\n          <el-tag v-if=\"scope.row.status === '已发布'\" type=\"success\" size=\"small\">{{ scope.row.status }}</el-tag>\n          <el-tag v-else type=\"info\" size=\"small\">{{ scope.row.status }}</el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"操作\" width=\"200\" align=\"center\">\n        <template slot-scope=\"scope\">\n          <el-button size=\"mini\" type=\"primary\" @click=\"handleEdit(scope.row)\">编辑</el-button>\n          <el-button size=\"mini\" type=\"danger\" @click=\"del(scope.row.id)\">删除</el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n\n    <!-- 分页 -->\n    <div style=\"margin: 10px 0\">\n      <el-pagination\n        @current-change=\"handleCurrentChange\"\n        :current-page=\"pageNum\"\n        :page-sizes=\"[5, 10, 20]\"\n        :page-size=\"pageSize\"\n        layout=\"total, prev, pager, next\"\n        :total=\"total\">\n      </el-pagination>\n    </div>\n\n    <!-- 新增/编辑弹窗 -->\n    <el-dialog title=\"关卡管理\" :visible.sync=\"dialogVisible\" width=\"60%\" :close-on-click-modal=\"false\">\n      <el-form :model=\"form\" label-width=\"100px\" :rules=\"rules\" ref=\"formRef\">\n        <el-form-item label=\"关卡标题\" prop=\"title\">\n          <el-input v-model=\"form.title\" placeholder=\"请输入关卡标题\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"关卡简介\" prop=\"descr\">\n          <el-input type=\"textarea\" v-model=\"form.descr\" :rows=\"3\" placeholder=\"请输入关卡简介\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"关卡等级\" prop=\"level\">\n          <el-input-number \n            v-model=\"form.level\" \n            :min=\"1\" \n            :max=\"99\" \n            placeholder=\"关卡等级\"\n            style=\"width: 200px\">\n          </el-input-number>\n          <span style=\"margin-left: 10px; font-size: 14px; color: #333;\">关</span>\n          \n        </el-form-item>\n        <el-form-item label=\"及格分数\" prop=\"passScore\">\n          <el-input-number v-model=\"form.passScore\" :min=\"0\" :max=\"100\" placeholder=\"及格分数\"></el-input-number>\n          <span style=\"color: #909399; margin-left: 10px; font-size: 12px\">满分100分</span>\n        </el-form-item>\n        <el-form-item label=\"排序\">\n          <el-input-number v-model=\"form.sortOrder\" :min=\"0\" :max=\"999\" placeholder=\"排序\"></el-input-number>\n          <span style=\"color: #909399; margin-left: 10px; font-size: 12px\">数字越小越靠前</span>\n        </el-form-item>\n        <el-form-item label=\"状态\" prop=\"status\">\n          <el-radio-group v-model=\"form.status\">\n            <el-radio label=\"已发布\">已发布</el-radio>\n            <el-radio label=\"草稿\">草稿</el-radio>\n          </el-radio-group>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"dialogVisible = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"save\">确 定</el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'ManagerQuiz',\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\n      title: '',\n      level: null,\n      status: '',\n      tableData: [],\n      pageNum: 1,\n      pageSize: 10,\n      total: 0,\n      dialogVisible: false,\n      form: {},\n      rules: {\n        title: [\n          { required: true, message: '请输入关卡标题', trigger: 'blur' }\n        ],\n        descr: [\n          { required: true, message: '请输入关卡简介', trigger: 'blur' }\n        ],\n        level: [\n          { required: true, message: '请选择关卡等级', trigger: 'change' }\n        ],\n        passScore: [\n          { required: true, message: '请输入及格分数', trigger: 'blur' }\n        ],\n        status: [\n          { required: true, message: '请选择状态', trigger: 'change' }\n        ]\n      },\n      ids: [],\n      maxLevel: 0 // 当前最大关卡等级\n    }\n  },\n  created() {\n    this.load(1)\n    this.loadMaxLevel()\n  },\n  methods: {\n    load(pageNum) {\n      if (pageNum) this.pageNum = pageNum\n      this.$request.get('/quiz/selectPage', {\n        params: {\n          pageNum: this.pageNum,\n          pageSize: this.pageSize,\n          title: this.title,\n          level: this.level,\n          status: this.status\n        }\n      }).then(res => {\n        if (res.code === '200') {\n          this.tableData = res.data?.list || []\n          this.total = res.data?.total || 0\n        }\n      })\n    },\n    reset() {\n      this.title = ''\n      this.level = null\n      this.status = ''\n      this.load(1)\n    },\n    handleAdd() {\n      // 获取最新的最大关卡等级\n      this.loadMaxLevel().then(() => {\n        // 自动设置为下一关\n        const nextLevel = this.maxLevel + 1\n        this.form = { \n          sortOrder: nextLevel, \n          status: '已发布', \n          passScore: 60,\n          level: nextLevel\n        }\n        this.dialogVisible = true\n        this.$nextTick(() => {\n          if (this.$refs.formRef) {\n            this.$refs.formRef.clearValidate()\n          }\n        })\n      })\n    },\n    handleEdit(row) {\n      this.form = JSON.parse(JSON.stringify(row))\n      this.dialogVisible = true\n      this.$nextTick(() => {\n        if (this.$refs.formRef) {\n          this.$refs.formRef.clearValidate()\n        }\n      })\n    },\n    save() {\n      this.$refs.formRef.validate((valid) => {\n        if (valid) {\n          this.$request({\n            url: this.form.id ? '/quiz/update' : '/quiz/add',\n            method: this.form.id ? 'PUT' : 'POST',\n            data: this.form\n          }).then(res => {\n            if (res.code === '200') {\n              this.$message.success('保存成功')\n              this.dialogVisible = false\n              this.load(1)\n              // 重新加载最大等级\n              this.loadMaxLevel()\n            } else {\n              this.$message.error(res.msg)\n            }\n          })\n        }\n      })\n    },\n    del(id) {\n      this.$confirm('确认删除该关卡吗？删除后相关题目也会失效！', '提示', { type: 'warning' }).then(() => {\n        this.$request.delete('/quiz/delete/' + id).then(res => {\n          if (res.code === '200') {\n            this.$message.success('删除成功')\n            this.load(1)\n            // 重新加载最大等级\n            this.loadMaxLevel()\n          } else {\n            this.$message.error(res.msg)\n          }\n        })\n      }).catch(() => {})\n    },\n    handleSelectionChange(rows) {\n      this.ids = rows.map(v => v.id)\n    },\n    delBatch() {\n      if (!this.ids.length) {\n        this.$message.warning('请选择要删除的数据')\n        return\n      }\n      this.$confirm('确认批量删除这些关卡吗？删除后相关题目也会失效！', '提示', { type: 'warning' }).then(() => {\n        this.$request.delete('/quiz/delete/batch', { data: this.ids }).then(res => {\n          if (res.code === '200') {\n            this.$message.success('批量删除成功')\n            this.load(1)\n            // 重新加载最大等级\n            this.loadMaxLevel()\n          } else {\n            this.$message.error(res.msg)\n          }\n        })\n      }).catch(() => {})\n    },\n    handleCurrentChange(pageNum) {\n      this.load(pageNum)\n    },\n    // 获取当前最大关卡等级\n    loadMaxLevel() {\n      return this.$request.get('/quiz/selectPage', {\n        params: {\n          pageNum: 1,\n          pageSize: 999\n        }\n      }).then(res => {\n        if (res.code === '200') {\n          const quizzes = res.data?.list || []\n          if (quizzes.length > 0) {\n            // 找出最大的关卡等级\n            this.maxLevel = Math.max(...quizzes.map(q => q.level || 0))\n          } else {\n            this.maxLevel = 0\n          }\n        }\n      }).catch(() => {\n        this.maxLevel = 0\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n</style>\n\n\n\n\n\n\n\n"],"mappings":"AAgHA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,IAAA,EAAAC,IAAA,CAAAC,KAAA,CAAAC,YAAA,CAAAC,OAAA;MACAC,KAAA;MACAC,KAAA;MACAC,MAAA;MACAC,SAAA;MACAC,OAAA;MACAC,QAAA;MACAC,KAAA;MACAC,aAAA;MACAC,IAAA;MACAC,KAAA;QACAT,KAAA,GACA;UAAAU,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAC,KAAA,GACA;UAAAH,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAX,KAAA,GACA;UAAAS,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAE,SAAA,GACA;UAAAJ,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAV,MAAA,GACA;UAAAQ,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MAEA;MACAG,GAAA;MACAC,QAAA;IACA;EACA;;EACAC,QAAA;IACA,KAAAC,IAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACAF,KAAAd,OAAA;MACA,IAAAA,OAAA,OAAAA,OAAA,GAAAA,OAAA;MACA,KAAAiB,QAAA,CAAAC,GAAA;QACAC,MAAA;UACAnB,OAAA,OAAAA,OAAA;UACAC,QAAA,OAAAA,QAAA;UACAL,KAAA,OAAAA,KAAA;UACAC,KAAA,OAAAA,KAAA;UACAC,MAAA,OAAAA;QACA;MACA,GAAAsB,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAC,IAAA;UACA,KAAAvB,SAAA,GAAAsB,GAAA,CAAA/B,IAAA,EAAAiC,IAAA;UACA,KAAArB,KAAA,GAAAmB,GAAA,CAAA/B,IAAA,EAAAY,KAAA;QACA;MACA;IACA;IACAsB,MAAA;MACA,KAAA5B,KAAA;MACA,KAAAC,KAAA;MACA,KAAAC,MAAA;MACA,KAAAgB,IAAA;IACA;IACAW,UAAA;MACA;MACA,KAAAV,YAAA,GAAAK,IAAA;QACA;QACA,MAAAM,SAAA,QAAAd,QAAA;QACA,KAAAR,IAAA;UACAuB,SAAA,EAAAD,SAAA;UACA5B,MAAA;UACAY,SAAA;UACAb,KAAA,EAAA6B;QACA;QACA,KAAAvB,aAAA;QACA,KAAAyB,SAAA;UACA,SAAAC,KAAA,CAAAC,OAAA;YACA,KAAAD,KAAA,CAAAC,OAAA,CAAAC,aAAA;UACA;QACA;MACA;IACA;IACAC,WAAAC,GAAA;MACA,KAAA7B,IAAA,GAAAZ,IAAA,CAAAC,KAAA,CAAAD,IAAA,CAAA0C,SAAA,CAAAD,GAAA;MACA,KAAA9B,aAAA;MACA,KAAAyB,SAAA;QACA,SAAAC,KAAA,CAAAC,OAAA;UACA,KAAAD,KAAA,CAAAC,OAAA,CAAAC,aAAA;QACA;MACA;IACA;IACAI,KAAA;MACA,KAAAN,KAAA,CAAAC,OAAA,CAAAM,QAAA,CAAAC,KAAA;QACA,IAAAA,KAAA;UACA,KAAApB,QAAA;YACAqB,GAAA,OAAAlC,IAAA,CAAAmC,EAAA;YACAC,MAAA,OAAApC,IAAA,CAAAmC,EAAA;YACAjD,IAAA,OAAAc;UACA,GAAAgB,IAAA,CAAAC,GAAA;YACA,IAAAA,GAAA,CAAAC,IAAA;cACA,KAAAmB,QAAA,C