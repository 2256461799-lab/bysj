{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'AiAssistant',\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\n      dialogVisible: false,\n      messages: [],\n      userInput: '',\n      isTyping: false,\n      isShaking: false,\n      chatSessionId: null,\n      // 拖拽核心\n      isDragging: false,\n      ballLeft: 0,\n      ballTop: 0,\n      startPageX: 0,\n      startPageY: 0,\n      startLeft: 0,\n      startTop: 0,\n      ballSize: 64\n    };\n  },\n  mounted() {\n    // 初始位置：右下角\n    this.ballLeft = window.innerWidth - this.ballSize - 20;\n    this.ballTop = window.innerHeight - this.ballSize - 20;\n    setTimeout(() => {\n      this.isShaking = true;\n    }, 5000);\n  },\n  methods: {\n    generateSessionId(prefix = 'session') {\n      return prefix + '_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);\n    },\n    openDialog() {\n      this.dialogVisible = true;\n      this.isShaking = false;\n      if (!this.chatSessionId) {\n        this.chatSessionId = this.generateSessionId('chat');\n        this.addSystemMessage('您好！我是AI治理助手，您可以向我咨询任何基层治理相关的问题。');\n      }\n    },\n    addSystemMessage(content) {\n      this.messages.push({\n        role: 'system',\n        content: content,\n        time: this.getCurrentTime()\n      });\n      this.$nextTick(() => this.scrollToBottom());\n    },\n    sendMessage() {\n      if (!this.userInput.trim() || this.isTyping) return;\n      const userMessage = this.userInput.trim();\n      this.messages.push({\n        role: 'user',\n        content: userMessage,\n        time: this.getCurrentTime()\n      });\n      this.userInput = '';\n      this.isTyping = true;\n      this.$nextTick(() => this.scrollToBottom());\n      this.callChatAPI(userMessage);\n    },\n    callChatAPI(message) {\n      const url = `${this.$baseUrl}/ai/chat?sessionId=${this.chatSessionId}&message=${encodeURIComponent(message)}`;\n      this.handleSSE(url);\n    },\n    handleSSE(url) {\n      const eventSource = new EventSource(url);\n      let aiMessage = '';\n      eventSource.onmessage = event => {\n        const data = event.data;\n        if (data === '[START]') return;\n        if (data === '[DONE]') {\n          eventSource.close();\n          this.isTyping = false;\n          return;\n        }\n        aiMessage += data;\n        const last = this.messages[this.messages.length - 1];\n        if (last && last.role === 'assistant') {\n          last.content = aiMessage;\n        } else {\n          this.messages.push({\n            role: 'assistant',\n            content: aiMessage,\n            time: this.getCurrentTime()\n          });\n        }\n        this.$nextTick(() => this.scrollToBottom());\n      };\n      eventSource.onerror = err => {\n        console.error('SSE 异常', err);\n        eventSource.close();\n        this.isTyping = false;\n        this.$message.error('连接出错，请重试');\n      };\n    },\n    clearChat() {\n      this.$confirm('确定清空对话？', '提示', {\n        type: 'warning'\n      }).then(() => {\n        this.messages = [];\n        this.$request.delete('/ai/clear', {\n          params: {\n            sessionId: this.chatSessionId\n          }\n        });\n        this.addSystemMessage('对话已清空');\n      }).catch(() => {});\n    },\n    scrollToBottom() {\n      if (this.$refs.messageList) {\n        this.$refs.messageList.scrollTop = this.$refs.messageList.scrollHeight;\n      }\n    },\n    getCurrentTime() {\n      const now = new Date();\n      return `${now.getHours().toString().padStart(2, '0')}:${now.getMinutes().toString().padStart(2, '0')}`;\n    },\n    // 拖拽开始\n    startDrag(e) {\n      this.isDragging = true;\n      this.isShaking = false;\n      const touch = e.touches ? e.touches[0] : e;\n      this.startPageX = touch.pageX;\n      this.startPageY = touch.pageY;\n      this.startLeft = this.ballLeft;\n      this.startTop = this.ballTop;\n\n      // 拖拽时无动画，更流畅\n      this.$refs.floatBall.style.transition = 'none';\n    },\n    // 拖拽中\n    handleDrag(e) {\n      if (!this.isDragging) return;\n      const touch = e.touches ? e.touches[0] : e;\n      let dx = touch.pageX - this.startPageX;\n      let dy = touch.pageY - this.startPageY;\n      let newLeft = this.startLeft + dx;\n      let newTop = this.startTop + dy;\n\n      // 边界限制：不超出屏幕\n      const maxX = window.innerWidth - this.ballSize;\n      const maxY = window.innerHeight - this.ballSize;\n      newLeft = Math.max(0, Math.min(newLeft, maxX));\n      newTop = Math.max(0, Math.min(newTop, maxY));\n      this.ballLeft = newLeft;\n      this.ballTop = newTop;\n    },\n    // 拖拽结束\n    stopDrag() {\n      this.isDragging = false;\n      // 恢复轻微过渡，更顺滑\n      this.$refs.floatBall.style.transition = 'all 0.1s ease';\n    },\n    // 点击：只有没拖拽时才打开弹窗\n    handleClick() {\n      if (!this.isDragging) {\n        this.openDialog();\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","user","JSON","parse","localStorage","getItem","dialogVisible","messages","userInput","isTyping","isShaking","chatSessionId","isDragging","ballLeft","ballTop","startPageX","startPageY","startLeft","startTop","ballSize","mounted","window","innerWidth","innerHeight","setTimeout","methods","generateSessionId","prefix","Date","now","Math","random","toString","substr","openDialog","addSystemMessage","content","push","role","time","getCurrentTime","$nextTick","scrollToBottom","sendMessage","trim","userMessage","callChatAPI","message","url","$baseUrl","encodeURIComponent","handleSSE","eventSource","EventSource","aiMessage","onmessage","event","close","last","length","onerror","err","console","error","$message","clearChat","$confirm","type","then","$request","delete","params","sessionId","catch","$refs","messageList","scrollTop","scrollHeight","getHours","padStart","getMinutes","startDrag","e","touch","touches","pageX","pageY","floatBall","style","transition","handleDrag","dx","dy","newLeft","newTop","maxX","maxY","max","min","stopDrag","handleClick"],"sources":["src/components/AiAssistant.vue"],"sourcesContent":["<template>\n  <div class=\"ai-assistant\">\n    <!-- 自由拖拽悬浮球 -->\n    <div\n      ref=\"floatBall\"\n      class=\"float-ball\"\n      :class=\"{ shake: isShaking }\"\n      :style=\"{ left: ballLeft + 'px', top: ballTop + 'px' }\"\n      @mousedown.prevent=\"startDrag\"\n      @touchstart.prevent=\"startDrag\"\n      @mousemove=\"handleDrag\"\n      @touchmove.prevent=\"handleDrag\"\n      @mouseup=\"stopDrag\"\n      @touchend=\"stopDrag\"\n      @click=\"handleClick\"\n      @mouseenter=\"isShaking = false\"\n    >\n      <div class=\"ball-icon\">\n        <i class=\"el-icon-chat-dot-round\"></i>\n      </div>\n      <div class=\"ball-text\">治理助手</div>\n    </div>\n\n    <!-- 对话窗口 -->\n    <el-dialog\n      title=\"AI智能问答\"\n      :visible.sync=\"dialogVisible\"\n      width=\"40%\"\n      :close-on-click-modal=\"false\"\n      custom-class=\"ai-dialog\"\n      :append-to-body=\"true\"\n    >\n      <div class=\"chat-container\">\n        <div class=\"chat-header\">\n          <el-button @click=\"clearChat\" size=\"small\" icon=\"el-icon-delete\">清空</el-button>\n        </div>\n\n        <div class=\"message-list\" ref=\"messageList\">\n          <div v-for=\"(msg, index) in messages\" :key=\"index\" :class=\"['message-item', msg.role]\">\n            <div class=\"message-avatar\">\n              <img v-if=\"msg.role === 'user' && user.avatar\" :src=\"user.avatar\" class=\"avatar-img\" />\n              <i v-else-if=\"msg.role === 'user'\" class=\"el-icon-user-solid\"></i>\n              <i v-else class=\"el-icon-service\"></i>\n            </div>\n            <div class=\"message-content\">\n              <div class=\"message-text\">{{ msg.content }}</div>\n              <div class=\"message-time\">{{ msg.time }}</div>\n            </div>\n          </div>\n          <div v-if=\"isTyping\" class=\"message-item assistant\">\n            <div class=\"message-avatar\">\n              <i class=\"el-icon-service\"></i>\n            </div>\n            <div class=\"message-content\">\n              <div class=\"typing-indicator\">\n                <span></span>\n                <span></span>\n                <span></span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"input-area\">\n          <el-input\n            v-model=\"userInput\"\n            placeholder=\"输入消息...\"\n            @keyup.enter.native=\"sendMessage\"\n            :disabled=\"isTyping\"\n          >\n            <el-button\n              slot=\"append\"\n              icon=\"el-icon-s-promotion\"\n              @click=\"sendMessage\"\n              :disabled=\"isTyping || !userInput.trim()\"\n            ></el-button>\n          </el-input>\n        </div>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'AiAssistant',\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\n      dialogVisible: false,\n      messages: [],\n      userInput: '',\n      isTyping: false,\n      isShaking: false,\n      chatSessionId: null,\n\n      // 拖拽核心\n      isDragging: false,\n      ballLeft: 0,\n      ballTop: 0,\n      startPageX: 0,\n      startPageY: 0,\n      startLeft: 0,\n      startTop: 0,\n      ballSize: 64\n    }\n  },\n  mounted() {\n    // 初始位置：右下角\n    this.ballLeft = window.innerWidth - this.ballSize - 20\n    this.ballTop = window.innerHeight - this.ballSize - 20\n\n    setTimeout(() => {\n      this.isShaking = true\n    }, 5000)\n  },\n  methods: {\n    generateSessionId(prefix = 'session') {\n      return prefix + '_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9)\n    },\n    openDialog() {\n      this.dialogVisible = true\n      this.isShaking = false\n      if (!this.chatSessionId) {\n        this.chatSessionId = this.generateSessionId('chat')\n        this.addSystemMessage('您好！我是AI治理助手，您可以向我咨询任何基层治理相关的问题。')\n      }\n    },\n    addSystemMessage(content) {\n      this.messages.push({\n        role: 'system',\n        content: content,\n        time: this.getCurrentTime()\n      })\n      this.$nextTick(() => this.scrollToBottom())\n    },\n    sendMessage() {\n      if (!this.userInput.trim() || this.isTyping) return\n      const userMessage = this.userInput.trim()\n      this.messages.push({\n        role: 'user',\n        content: userMessage,\n        time: this.getCurrentTime()\n      })\n      this.userInput = ''\n      this.isTyping = true\n      this.$nextTick(() => this.scrollToBottom())\n      this.callChatAPI(userMessage)\n    },\n    callChatAPI(message) {\n      const url = `${this.$baseUrl}/ai/chat?sessionId=${this.chatSessionId}&message=${encodeURIComponent(message)}`\n      this.handleSSE(url)\n    },\n    handleSSE(url) {\n      const eventSource = new EventSource(url)\n      let aiMessage = ''\n      eventSource.onmessage = (event) => {\n        const data = event.data\n        if (data === '[START]') return\n        if (data === '[DONE]') {\n          eventSource.close()\n          this.isTyping = false\n          return\n        }\n        aiMessage += data\n        const last = this.messages[this.messages.length - 1]\n        if (last && last.role === 'assistant') {\n          last.content = aiMessage\n        } else {\n          this.messages.push({\n            role: 'assistant',\n            content: aiMessage,\n            time: this.getCurrentTime()\n          })\n        }\n        this.$nextTick(() => this.scrollToBottom())\n      }\n      eventSource.onerror = (err) => {\n        console.error('SSE 异常', err)\n        eventSource.close()\n        this.isTyping = false\n        this.$message.error('连接出错，请重试')\n      }\n    },\n    clearChat() {\n      this.$confirm('确定清空对话？', '提示', { type: 'warning' }).then(() => {\n        this.messages = []\n        this.$request.delete('/ai/clear', { params: { sessionId: this.chatSessionId } })\n        this.addSystemMessage('对话已清空')\n      }).catch(() => {})\n    },\n    scrollToBottom() {\n      if (this.$refs.messageList) {\n        this.$refs.messageList.scrollTop = this.$refs.messageList.scrollHeight\n      }\n    },\n    getCurrentTime() {\n      const now = new Date()\n      return `${now.getHours().toString().padStart(2, '0')}:${now.getMinutes().toString().padStart(2, '0')}`\n    },\n\n    // 拖拽开始\n    startDrag(e) {\n      this.isDragging = true\n      this.isShaking = false\n\n      const touch = e.touches ? e.touches[0] : e\n      this.startPageX = touch.pageX\n      this.startPageY = touch.pageY\n      this.startLeft = this.ballLeft\n      this.startTop = this.ballTop\n\n      // 拖拽时无动画，更流畅\n      this.$refs.floatBall.style.transition = 'none'\n    },\n\n    // 拖拽中\n    handleDrag(e) {\n      if (!this.isDragging) return\n      const touch = e.touches ? e.touches[0] : e\n\n      let dx = touch.pageX - this.startPageX\n      let dy = touch.pageY - this.startPageY\n\n      let newLeft = this.startLeft + dx\n      let newTop = this.startTop + dy\n\n      // 边界限制：不超出屏幕\n      const maxX = window.innerWidth - this.ballSize\n      const maxY = window.innerHeight - this.ballSize\n      newLeft = Math.max(0, Math.min(newLeft, maxX))\n      newTop = Math.max(0, Math.min(newTop, maxY))\n\n      this.ballLeft = newLeft\n      this.ballTop = newTop\n    },\n\n    // 拖拽结束\n    stopDrag() {\n      this.isDragging = false\n      // 恢复轻微过渡，更顺滑\n      this.$refs.floatBall.style.transition = 'all 0.1s ease'\n    },\n\n    // 点击：只有没拖拽时才打开弹窗\n    handleClick() {\n      if (!this.isDragging) {\n        this.openDialog()\n      }\n    }\n  }\n}\n</script>\n\n<style scoped>\n.float-ball {\n  position: fixed;\n  width: 64px;\n  height: 64px;\n  background: #1d3557;\n  border-radius: 50%;\n  box-shadow: 0 2px 12px rgba(29, 53, 87, 0.4);\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  z-index: 999999;\n  cursor: move;\n  user-select: none;\n  transition: all 0.1s ease;\n}\n.float-ball:hover {\n  background: #264e78;\n}\n.float-ball.shake {\n  animation: shake 0.5s infinite;\n}\n@keyframes shake {\n  0%,100%{transform:rotate(0deg);}25%{transform:rotate(-8deg);}75%{transform:rotate(8deg);}\n}\n.ball-icon {\n  font-size: 28px;\n  color: #fff;\n}\n.ball-text {\n  font-size: 11px;\n  color: #fff;\n  margin-top: 2px;\n}\n\n::v-deep .ai-dialog {\n  border-radius: 8px;\n  overflow: hidden;\n}\n::v-deep .ai-dialog .el-dialog__header {\n  background: #1d3557;\n  padding: 16px 20px;\n}\n::v-deep .ai-dialog .el-dialog__title {\n  color: #fff;\n  font-weight: 600;\n}\n::v-deep .ai-dialog .el-dialog__headerbtn .el-dialog__close {\n  color: #fff;\n}\n::v-deep .ai-dialog .el-dialog__body {\n  padding: 0;\n}\n\n.chat-container {\n  display: flex;\n  flex-direction: column;\n  height: 500px;\n}\n.chat-header {\n  padding: 12px 16px;\n  background: #fafafa;\n  border-bottom: 1px solid #e8e8e8;\n  display: flex;\n  justify-content: flex-end;\n}\n.message-list {\n  flex: 1;\n  overflow-y: auto;\n  padding: 16px;\n  background: #f8f8f8;\n}\n.message-item {\n  display: flex;\n  margin-bottom: 16px;\n}\n.message-item.user {\n  flex-direction: row-reverse;\n}\n.message-avatar {\n  width: 34px;\n  height: 34px;\n  border-radius: 50%;\n  background: #1d3557;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: white;\n  flex-shrink: 0;\n}\n.avatar-img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  border-radius: 50%;\n}\n.message-item.user .message-avatar {\n  background: #67c23a;\n}\n.message-item.system .message-avatar {\n  background: #e6a23c;\n}\n.message-content {\n  max-width: 70%;\n  margin: 0 10px;\n}\n.message-text {\n  padding: 10px 14px;\n  background: white;\n  border: 1px solid #e8e8e8;\n  border-radius: 4px;\n  font-size: 14px;\n}\n.message-item.user .message-text {\n  background: #1d3557;\n  color: white;\n}\n.message-item.system .message-text {\n  background: #fffbe6;\n  border-left: 2px solid #e6a23c;\n}\n.message-time {\n  font-size: 11px;\n  color: #999;\n  text-align: center;\n  margin-top: 4px;\n}\n.typing-indicator {\n  padding: 10px 14px;\n  background: white;\n  border: 1px solid #e8e8e8;\n  display: inline-flex;\n  gap: 5px;\n}\n.typing-indicator span {\n  width: 6px;\n  height: 6px;\n  border-radius: 50%;\n  background: #1d3557;\n  animation: typing 1.2s infinite;\n}\n.typing-indicator span:nth-child(2) {\n  animation-delay: 0.2s;\n}\n.typing-indicator span:nth-child(3) {\n  animation-delay: 0.4s;\n}\n@keyframes typing {\n  0%,60%,100%{transform:translateY(0);opacity:.5;}30%{transform:translateY(-6px);opacity:1;}\n}\n.input-area {\n  padding: 16px;\n  background: white;\n  border-top: 1px solid #e8e8e8;\n}\n::v-deep .input-area .el-input-group__append {\n  background: #1d3557;\n  border-color: #1d3557;\n  color: white;\n}\n</style>"],"mappings":";AAoFA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,IAAA,EAAAC,IAAA,CAAAC,KAAA,CAAAC,YAAA,CAAAC,OAAA;MACAC,aAAA;MACAC,QAAA;MACAC,SAAA;MACAC,QAAA;MACAC,SAAA;MACAC,aAAA;MAEA;MACAC,UAAA;MACAC,QAAA;MACAC,OAAA;MACAC,UAAA;MACAC,UAAA;MACAC,SAAA;MACAC,QAAA;MACAC,QAAA;IACA;EACA;EACAC,QAAA;IACA;IACA,KAAAP,QAAA,GAAAQ,MAAA,CAAAC,UAAA,QAAAH,QAAA;IACA,KAAAL,OAAA,GAAAO,MAAA,CAAAE,WAAA,QAAAJ,QAAA;IAEAK,UAAA;MACA,KAAAd,SAAA;IACA;EACA;EACAe,OAAA;IACAC,kBAAAC,MAAA;MACA,OAAAA,MAAA,SAAAC,IAAA,CAAAC,GAAA,WAAAC,IAAA,CAAAC,MAAA,GAAAC,QAAA,KAAAC,MAAA;IACA;IACAC,WAAA;MACA,KAAA5B,aAAA;MACA,KAAAI,SAAA;MACA,UAAAC,aAAA;QACA,KAAAA,aAAA,QAAAe,iBAAA;QACA,KAAAS,gBAAA;MACA;IACA;IACAA,iBAAAC,OAAA;MACA,KAAA7B,QAAA,CAAA8B,IAAA;QACAC,IAAA;QACAF,OAAA,EAAAA,OAAA;QACAG,IAAA,OAAAC,cAAA;MACA;MACA,KAAAC,SAAA,YAAAC,cAAA;IACA;IACAC,YAAA;MACA,UAAAnC,SAAA,CAAAoC,IAAA,WAAAnC,QAAA;MACA,MAAAoC,WAAA,QAAArC,SAAA,CAAAoC,IAAA;MACA,KAAArC,QAAA,CAAA8B,IAAA;QACAC,IAAA;QACAF,OAAA,EAAAS,WAAA;QACAN,IAAA,OAAAC,cAAA;MACA;MACA,KAAAhC,SAAA;MACA,KAAAC,QAAA;MACA,KAAAgC,SAAA,YAAAC,cAAA;MACA,KAAAI,WAAA,CAAAD,WAAA;IACA;IACAC,YAAAC,OAAA;MACA,MAAA