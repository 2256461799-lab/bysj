{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: \"Front\",\n  data() {\n    return {\n      user: {}\n    };\n  },\n  created() {\n    this.user = JSON.parse(localStorage.getItem(\"xm-user\") || \"{}\");\n  },\n  methods: {\n    logout() {\n      this.$router.push(\"/login\");\n      localStorage.clear();\n      this.$message.success(\"退出成功\");\n    }\n  }\n};","map":{"version":3,"names":["name","data","user","created","JSON","parse","localStorage","getItem","methods","logout","$router","push","clear","$message","success"],"sources":["src/views/Front.vue"],"sourcesContent":["<template>\n  <div class=\"front\">\n    <div class=\"front-header\">\n      <div class=\"front-header-left\">\n        <div class=\"title\">网格化社会治理系统</div>\n      </div>\n      <div class=\"front-header-right\">\n        <el-menu\n          background-color=\"#1f51ff\"\n          text-color=\"#fff\"\n          active-text-color=\"#ffd04b\"\n          mode=\"horizontal\"\n          router\n        >\n          <!-- 只改这里：index → home -->\n          <el-menu-item index=\"/front/home\">首页</el-menu-item>\n          <el-menu-item index=\"/front/blog\">工作交流</el-menu-item>\n          <el-menu-item index=\"/front/activity\">任务中心</el-menu-item>\n          <el-menu-item index=\"/front/law\">法律法规</el-menu-item>\n          <el-menu-item index=\"/front/knowledge\">治理案例库</el-menu-item>\n          <el-menu-item index=\"/front/report\">事件上报</el-menu-item>\n          <el-menu-item index=\"/front/learningClass\">法治培训</el-menu-item>\n\n          <div style=\"flex: 1\"></div>\n\n          <el-menu-item\n            v-if=\"!user.id\"\n            index=\"/login\"\n            class=\"login-btn\"\n          >\n            登录\n          </el-menu-item>\n          <el-sub-menu v-else index=\"/user\">\n            <template #title>\n              <i class=\"el-icon-user\"></i>\n              <span>{{ user.name }}</span>\n            </template>\n            <el-menu-item index=\"/front/person\">个人中心</el-menu-item>\n            <el-menu-item @click=\"logout\">退出登录</el-menu-item>\n          </el-sub-menu>\n        </el-menu>\n      </div>\n    </div>\n\n    <div class=\"front-body\">\n      <router-view />\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"Front\",\n  data() {\n    return {\n      user: {},\n    };\n  },\n  created() {\n    this.user = JSON.parse(localStorage.getItem(\"xm-user\") || \"{}\");\n  },\n  methods: {\n    logout() {\n      this.$router.push(\"/login\");\n      localStorage.clear();\n      this.$message.success(\"退出成功\");\n    },\n  },\n};\n</script>\n\n<style scoped>\n/* 你原来的样式，一行都没动！ */\n.front {\n  width: 100%;\n  height: 100vh;\n}\n.front-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 0 40px;\n  background-color: #1f51ff;\n  color: #fff;\n  height: 60px;\n}\n.front-header-left {\n  display: flex;\n  align-items: center;\n}\n.title {\n  font-size: 20px;\n  font-weight: bold;\n}\n.front-header-right {\n  flex: 1;\n  display: flex;\n  justify-content: flex-end;\n}\n.el-menu {\n  border-bottom: none !important;\n}\n.front-body {\n  height: calc(100vh - 60px);\n  overflow-y: auto;\n}\n</style>"],"mappings":";AAmDA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,IAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAD,IAAA,GAAAE,IAAA,CAAAC,KAAA,CAAAC,YAAA,CAAAC,OAAA;EACA;EACAC,OAAA;IACAC,OAAA;MACA,KAAAC,OAAA,CAAAC,IAAA;MACAL,YAAA,CAAAM,KAAA;MACA,KAAAC,QAAA,CAAAC,OAAA;IACA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}