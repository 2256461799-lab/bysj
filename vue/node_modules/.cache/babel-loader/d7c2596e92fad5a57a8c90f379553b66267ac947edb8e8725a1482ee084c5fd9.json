{"ast":null,"code":"import E from \"wangeditor\";\nimport hljs from 'highlight.js';\nexport default {\n  name: \"Blog\",\n  data() {\n    return {\n      blogId: this.$route.query.blogId,\n      title: null,\n      categoryName: null,\n      userName: null,\n      fromVisible: false,\n      form: {},\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\n      rules: {},\n      ids: [],\n      content: '',\n      categoryList: [],\n      tagsArr: [],\n      editor: null\n    };\n  },\n  mounted() {\n    this.$request.get('/category/selectAll').then(res => {\n      this.categoryList = res.data || [];\n    });\n    this.$request.get('/blog/selectById/' + this.blogId).then(res => {\n      this.form = res.data || {};\n      this.tagsArr = JSON.parse(this.form.tags || '[]');\n      if (this.form.id) {\n        setTimeout(() => {\n          this.editor.txt.html(this.form.content);\n        }, 0);\n      }\n    });\n    this.setRichText();\n  },\n  methods: {\n    handleAdd() {\n      // 新增数据\n      this.form = {}; // 新增数据的时候清空数据\n      this.tagsArr = [];\n      this.setRichText();\n      this.fromVisible = true; // 打开弹窗\n    },\n\n    handleEdit(row) {\n      // 编辑数据\n      this.form = JSON.parse(JSON.stringify(row)); // 给form对象赋值  注意要深拷贝数据\n      this.tagsArr = JSON.parse(this.form.tags || '[]');\n      this.fromVisible = true; // 打开弹窗\n      this.setRichText();\n      setTimeout(() => {\n        this.editor.txt.html(this.form.content);\n      }, 0);\n    },\n    save() {\n      // 保存按钮触发的逻辑  它会触发新增或者更新\n      this.$refs.formRef.validate(valid => {\n        if (valid) {\n          this.form.tags = JSON.stringify(this.tagsArr); // 把json数组转换成json字符串存到数据库\n          this.form.content = this.editor.txt.html();\n          this.$request({\n            url: this.form.id ? '/blog/update' : '/blog/add',\n            method: this.form.id ? 'PUT' : 'POST',\n            data: this.form\n          }).then(res => {\n            if (res.code === '200') {\n              // 表示成功保存\n              this.$message.success('保存成功');\n            } else {\n              this.$message.error(res.msg); // 弹出错误的信息\n            }\n          });\n        }\n      });\n    },\n\n    del(id) {\n      // 单个删除\n      this.$confirm('您确定删除吗？', '确认删除', {\n        type: \"warning\"\n      }).then(response => {\n        this.$request.delete('/blog/delete/' + id).then(res => {\n          if (res.code === '200') {\n            // 表示操作成功\n            this.$message.success('操作成功');\n            this.load(1);\n          } else {\n            this.$message.error(res.msg); // 弹出错误的信息\n          }\n        });\n      }).catch(() => {});\n    },\n    handleSelectionChange(rows) {\n      // 当前选中的所有的行数据\n      this.ids = rows.map(v => v.id); //  [1,2]\n    },\n\n    delBatch() {\n      // 批量删除\n      if (!this.ids.length) {\n        this.$message.warning('请选择数据');\n        return;\n      }\n      this.$confirm('您确定批量删除这些数据吗？', '确认删除', {\n        type: \"warning\"\n      }).then(response => {\n        this.$request.delete('/blog/delete/batch', {\n          data: this.ids\n        }).then(res => {\n          if (res.code === '200') {\n            // 表示操作成功\n            this.$message.success('操作成功');\n            this.load(1);\n          } else {\n            this.$message.error(res.msg); // 弹出错误的信息\n          }\n        });\n      }).catch(() => {});\n    },\n    reset() {\n      this.title = null;\n      this.categoryName = null;\n      this.userName = null;\n      this.load(1);\n    },\n    handleCurrentChange(pageNum) {\n      this.load(pageNum);\n    },\n    handleCoverSuccess(res) {\n      this.form.cover = res.data;\n    },\n    setRichText() {\n      this.$nextTick(() => {\n        this.editor = new E(`#editor`);\n        this.editor.highlight = hljs;\n        this.editor.config.uploadImgServer = this.$baseUrl + '/files/editor/upload';\n        this.editor.config.uploadFileName = 'file';\n        this.editor.config.uploadImgHeaders = {\n          token: this.user.token\n        };\n        this.editor.config.uploadImgParams = {\n          type: 'img'\n        };\n        this.editor.config.zIndex = 0;\n        this.editor.create(); // 创建\n      });\n    }\n  }\n};","map":{"version":3,"names":["E","hljs","name","data","blogId","$route","query","title","categoryName","userName","fromVisible","form","user","JSON","parse","localStorage","getItem","rules","ids","content","categoryList","tagsArr","editor","mounted","$request","get","then","res","tags","id","setTimeout","txt","html","setRichText","methods","handleAdd","handleEdit","row","stringify","save","$refs","formRef","validate","valid","url","method","code","$message","success","error","msg","del","$confirm","type","response","delete","load","catch","handleSelectionChange","rows","map","v","delBatch","length","warning","reset","handleCurrentChange","pageNum","handleCoverSuccess","cover","$nextTick","highlight","config","uploadImgServer","$baseUrl","uploadFileName","uploadImgHeaders","token","uploadImgParams","zIndex","create"],"sources":["src/views/front/NewBlog.vue"],"sourcesContent":["<template>\n  <div class=\"newblog-container\">\n    <!-- 页面头部 -->\n    <div class=\"page-header\">\n      <h1 class=\"page-title\">{{ form.id ? '编辑日志' : '发表新日志' }}</h1>\n    </div>\n\n    <!-- 表单卡片 -->\n    <div class=\"form-card\">\n      <el-form :model=\"form\" label-width=\"100px\" :rules=\"rules\" ref=\"formRef\">\n        <el-form-item label=\"标题\" prop=\"title\">\n          <el-input v-model=\"form.title\" placeholder=\"标题\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"简介\" prop=\"descr\">\n          <el-input type=\"textarea\" v-model=\"form.descr\" placeholder=\"简介\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"封面\" prop=\"cover\">\n          <el-upload\n              :action=\"$baseUrl + '/files/upload'\"\n              :headers=\"{ token: user.token }\"\n              list-type=\"picture\"\n              :on-success=\"handleCoverSuccess\"\n          >\n            <el-button type=\"primary\">上传封面</el-button>\n          </el-upload>\n        </el-form-item>\n        <el-form-item label=\"分类\" prop=\"categoryId\">\n          <el-select v-model=\"form.categoryId\" style=\"width: 100%\">\n            <el-option v-for=\"item in categoryList\" :key=\"item.id\" :value=\"item.id\" :label=\"item.name\"></el-option>\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"标签\" prop=\"tags\">\n          <el-select v-model=\"tagsArr\" multiple filterable allow-create default-first-option style=\"width: 100%\" placeholder=\"选择或输入标签\">\n            <el-option value=\"安全隐患\"></el-option>\n            <el-option value=\"矛盾纠纷\"></el-option>\n            <el-option value=\"环境问题\"></el-option>\n            <el-option value=\"民生诉求\"></el-option>\n            <el-option value=\"治理经验\"></el-option>\n            <el-option value=\"巡查记录\"></el-option>\n            <el-option value=\"政策宣传\"></el-option>\n            <el-option value=\"法律咨询\"></el-option>\n            <el-option value=\"工作心得\"></el-option>\n            <el-option value=\"案例分享\"></el-option>\n            <el-option value=\"问题反馈\"></el-option>\n            <el-option value=\"治理知识\"></el-option>\n            <el-option value=\"工作建议\"></el-option>\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"内容\" prop=\"content\">\n          <div id=\"editor\"></div>\n        </el-form-item>\n      </el-form>\n      \n      <!-- 操作按钮 -->\n      <div class=\"form-actions\">\n        <el-button @click=\"$router.back()\" size=\"medium\">\n          <i class=\"el-icon-back\"></i>\n          返回\n        </el-button>\n        <el-button type=\"primary\" size=\"medium\" @click=\"save\">\n          <i class=\"el-icon-check\"></i>\n          {{ form.id ? '保存修改' : '确认发布' }}\n        </el-button>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport E from \"wangeditor\"\nimport hljs from 'highlight.js'\nexport default {\n  name: \"Blog\",\n  data() {\n    return {\n      blogId:this.$route.query.blogId,\n      title: null,\n      categoryName: null,\n      userName: null,\n      fromVisible: false,\n      form: {},\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\n      rules: {},\n      ids: [],\n      content: '',\n      categoryList: [],\n      tagsArr: [],\n      editor: null\n    }\n  },\n  mounted() {\n    this.$request.get('/category/selectAll').then(res => {\n      this.categoryList = res.data || []\n    })\n    this.$request.get('/blog/selectById/' + this.blogId).then(res => {\n      this.form = res.data || {}\n      this.tagsArr = JSON.parse(this.form.tags || '[]')\n      if(this.form.id){\n        setTimeout(() => {\n          this.editor.txt.html(this.form.content)\n        }, 0)\n      }\n    })\n    this.setRichText()\n  },\n  methods: {\n    handleAdd() {   // 新增数据\n      this.form = {}  // 新增数据的时候清空数据\n      this.tagsArr = []\n      this.setRichText()\n      this.fromVisible = true   // 打开弹窗\n    },\n    handleEdit(row) {   // 编辑数据\n      this.form = JSON.parse(JSON.stringify(row))  // 给form对象赋值  注意要深拷贝数据\n      this.tagsArr = JSON.parse(this.form.tags || '[]')\n      this.fromVisible = true   // 打开弹窗\n      this.setRichText()\n      setTimeout(() => {\n        this.editor.txt.html(this.form.content)\n      }, 0)\n    },\n    save() {   // 保存按钮触发的逻辑  它会触发新增或者更新\n      this.$refs.formRef.validate((valid) => {\n        if (valid) {\n          this.form.tags = JSON.stringify(this.tagsArr)  // 把json数组转换成json字符串存到数据库\n          this.form.content = this.editor.txt.html()\n          this.$request({\n            url: this.form.id ? '/blog/update' : '/blog/add',\n            method: this.form.id ? 'PUT' : 'POST',\n            data: this.form\n          }).then(res => {\n            if (res.code === '200') {  // 表示成功保存\n              this.$message.success('保存成功')\n\n            } else {\n              this.$message.error(res.msg)  // 弹出错误的信息\n            }\n          })\n        }\n      })\n    },\n    del(id) {   // 单个删除\n      this.$confirm('您确定删除吗？', '确认删除', {type: \"warning\"}).then(response => {\n        this.$request.delete('/blog/delete/' + id).then(res => {\n          if (res.code === '200') {   // 表示操作成功\n            this.$message.success('操作成功')\n            this.load(1)\n          } else {\n            this.$message.error(res.msg)  // 弹出错误的信息\n          }\n        })\n      }).catch(() => {\n      })\n    },\n    handleSelectionChange(rows) {   // 当前选中的所有的行数据\n      this.ids = rows.map(v => v.id)   //  [1,2]\n    },\n    delBatch() {   // 批量删除\n      if (!this.ids.length) {\n        this.$message.warning('请选择数据')\n        return\n      }\n      this.$confirm('您确定批量删除这些数据吗？', '确认删除', {type: \"warning\"}).then(response => {\n        this.$request.delete('/blog/delete/batch', {data: this.ids}).then(res => {\n          if (res.code === '200') {   // 表示操作成功\n            this.$message.success('操作成功')\n            this.load(1)\n          } else {\n            this.$message.error(res.msg)  // 弹出错误的信息\n          }\n        })\n      }).catch(() => {\n      })\n    },\n\n    reset() {\n      this.title = null\n      this.categoryName = null\n      this.userName = null\n      this.load(1)\n    },\n    handleCurrentChange(pageNum) {\n      this.load(pageNum)\n    },\n    handleCoverSuccess(res) {\n      this.form.cover = res.data\n    },\n    setRichText() {\n      this.$nextTick(() => {\n        this.editor = new E(`#editor`)\n        this.editor.highlight = hljs\n        this.editor.config.uploadImgServer = this.$baseUrl + '/files/editor/upload'\n        this.editor.config.uploadFileName = 'file'\n        this.editor.config.uploadImgHeaders = {\n          token: this.user.token\n        }\n        this.editor.config.uploadImgParams = {\n          type: 'img',\n        }\n        this.editor.config.zIndex=0\n        this.editor.create()  // 创建\n      })\n    },\n  }\n}\n</script>\n\n<style scoped>\n.newblog-container {\n  width: 75%;\n  max-width: 960px;\n  margin: 20px auto;\n}\n\n/* 页面头部 */\n.page-header {\n  background: #fff;\n  border-radius: 4px;\n  padding: 35px 40px;\n  margin-bottom: 15px;\n  text-align: center;\n  border: 1px solid #e8e8e8;\n  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);\n}\n\n.page-title {\n  font-size: 28px;\n  font-weight: 600;\n  color: #1a1a1a;\n  margin: 0;\n  line-height: 1.5;\n}\n\n/* 表单卡片 */\n.form-card {\n  background: #fff;\n  border-radius: 4px;\n  padding: 35px 40px;\n  border: 1px solid #e8e8e8;\n  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);\n  margin-bottom: 15px;\n}\n\n/* 表单样式优化 */\n.form-card >>> .el-form-item {\n  margin-bottom: 24px;\n}\n\n.form-card >>> .el-form-item__label {\n  font-weight: 500;\n  color: #606266;\n  font-size: 14px;\n}\n\n.form-card >>> .el-input__inner,\n.form-card >>> .el-textarea__inner {\n  border-radius: 4px;\n  border-color: #dcdfe6;\n}\n\n.form-card >>> .el-input__inner:focus,\n.form-card >>> .el-textarea__inner:focus {\n  border-color: #1d3557;\n}\n\n/* 富文本编辑器 */\n.form-card >>> #editor {\n  border: 1px solid #dcdfe6;\n  border-radius: 4px;\n}\n\n.form-card >>> .w-e-toolbar {\n  border-bottom: 1px solid #dcdfe6 !important;\n  background: #f5f7fa;\n  border-radius: 4px 4px 0 0;\n}\n\n.form-card >>> .w-e-text-container {\n  border-radius: 0 0 4px 4px;\n}\n\n/* 操作按钮区 */\n.form-actions {\n  display: flex;\n  justify-content: center;\n  gap: 15px;\n  padding-top: 30px;\n  border-top: 1px solid #f0f0f0;\n  margin-top: 10px;\n}\n\n/* 上传按钮样式 */\n.form-card >>> .el-upload {\n  display: inline-block;\n}\n\n/* 响应式设计 */\n@media (max-width: 1024px) {\n  .newblog-container {\n    width: 90%;\n  }\n}\n\n@media (max-width: 768px) {\n  .newblog-container {\n    width: 100%;\n    padding: 0 10px;\n    margin: 10px auto;\n  }\n  \n  .page-header,\n  .form-card {\n    padding: 24px 20px;\n    border-radius: 4px;\n    margin-bottom: 15px;\n  }\n  \n  .page-title {\n    font-size: 22px;\n  }\n  \n  .form-card >>> .el-form-item__label {\n    text-align: left;\n  }\n  \n  .form-actions {\n    flex-direction: column;\n  }\n  \n  .form-actions .el-button {\n    width: 100%;\n  }\n}\n</style>\n"],"mappings":"AAqEA,OAAAA,CAAA;AACA,OAAAC,IAAA;AACA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,MAAA,OAAAC,MAAA,CAAAC,KAAA,CAAAF,MAAA;MACAG,KAAA;MACAC,YAAA;MACAC,QAAA;MACAC,WAAA;MACAC,IAAA;MACAC,IAAA,EAAAC,IAAA,CAAAC,KAAA,CAAAC,YAAA,CAAAC,OAAA;MACAC,KAAA;MACAC,GAAA;MACAC,OAAA;MACAC,YAAA;MACAC,OAAA;MACAC,MAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,QAAA,CAAAC,GAAA,wBAAAC,IAAA,CAAAC,GAAA;MACA,KAAAP,YAAA,GAAAO,GAAA,CAAAxB,IAAA;IACA;IACA,KAAAqB,QAAA,CAAAC,GAAA,4BAAArB,MAAA,EAAAsB,IAAA,CAAAC,GAAA;MACA,KAAAhB,IAAA,GAAAgB,GAAA,CAAAxB,IAAA;MACA,KAAAkB,OAAA,GAAAR,IAAA,CAAAC,KAAA,MAAAH,IAAA,CAAAiB,IAAA;MACA,SAAAjB,IAAA,CAAAkB,EAAA;QACAC,UAAA;UACA,KAAAR,MAAA,CAAAS,GAAA,CAAAC,IAAA,MAAArB,IAAA,CAAAQ,OAAA;QACA;MACA;IACA;IACA,KAAAc,WAAA;EACA;EACAC,OAAA;IACAC,UAAA;MAAA;MACA,KAAAxB,IAAA;MACA,KAAAU,OAAA;MACA,KAAAY,WAAA;MACA,KAAAvB,WAAA;IACA;;IACA0B,WAAAC,GAAA;MAAA;MACA,KAAA1B,IAAA,GAAAE,IAAA,CAAAC,KAAA,CAAAD,IAAA,CAAAyB,SAAA,CAAAD,GAAA;MACA,KAAAhB,OAAA,GAAAR,IAAA,CAAAC,KAAA,MAAAH,IAAA,CAAAiB,IAAA;MACA,KAAAlB,WAAA;MACA,KAAAuB,WAAA;MACAH,UAAA;QACA,KAAAR,MAAA,CAAAS,GAAA,CAAAC,IAAA,MAAArB,IAAA,CAAAQ,OAAA;MACA;IACA;IACAoB,KAAA;MAAA;MACA,KAAAC,KAAA,CAAAC,OAAA,CAAAC,QAAA,CAAAC,KAAA;QACA,IAAAA,KAAA;UACA,KAAAhC,IAAA,CAAAiB,IAAA,GAAAf,IAAA,CAAAyB,SAAA,MAAAjB,OAAA;UACA,KAAAV,IAAA,CAAAQ,OAAA,QAAAG,MAAA,CAAAS,GAAA,CAAAC,IAAA;UACA,KAAAR,QAAA;YACAoB,GAAA,OAAAjC,IAAA,CAAAkB,EAAA;YACAgB,MAAA,OAAAlC,IAAA,CAAAkB,EAAA;YACA1B,IAAA,OAAAQ;UACA,GAAAe,IAAA,CAAAC,GAAA;YACA,IAAAA,GAAA,CAAAmB,IAAA;cAAA;cACA,KAAAC,QAAA,CAAAC,OAAA;YAEA;cACA,KAAAD,QAAA,CAAAE,KAAA,CAAAtB,GAAA,CAAAuB,GAAA;YACA;UACA;QACA;MACA;IACA;;IACAC,IAAAtB,EAAA;MAAA;MACA,KAAAuB,QAAA;QAAAC,IAAA;MAAA,GAAA3B,IAAA,CAAA4B,QAAA;QACA,KAAA9B,QAAA,CAAA+B,MAAA,mBAAA1B,EAAA,EAAAH,IAAA,CAAAC,GAAA;UACA,IAAAA,GAAA,CAAAmB,IAAA;YAAA;YACA,KAAAC,QAAA,CAAAC,OAAA;YACA,KAAAQ,IAAA;UACA;YACA,KAAAT,QAAA,CAAAE,KAAA,CAAAtB,GAAA,CAAAuB,GAAA;UACA;QACA;MACA,GAAAO,KAAA,QACA;IACA;IACAC,sBAAAC,IAAA;MAAA;MACA,KAAAzC,GAAA,GAAAyC,IAAA,CAAAC,GAAA,CAAAC,CAAA,IAAAA,CAAA,CAAAhC,EAAA;IACA;;IACAiC,SAAA;MAAA;MACA,UAAA5C,GAAA,CAAA6C,MAAA;QACA,KAAAhB,QAAA,CAAAiB,OAAA;QACA;MACA;MACA,KAAAZ,QAAA;QAAAC,IAAA;MAAA,GAAA3B,IAAA,CAAA4B,QAAA;QACA,KAAA9B,QAAA,CAAA+B,MAAA;UAAApD,IAAA,OAAAe;QAAA,GAAAQ,IAAA,CAAAC,GAAA;UACA,IAAAA,GAAA,CAAAmB,IAAA;YAAA;YACA,KAAAC,QAAA,CAAAC,OAAA;YACA,KAAAQ,IAAA;UACA;YACA,KAAAT,QAAA,CAAAE,KAAA,CAAAtB,GAAA,CAAAuB,GAAA;UACA;QACA;MACA,GAAAO,KAAA,QACA;IACA;IAEAQ,MAAA;MACA,KAAA1D,KAAA;MACA,KAAAC,YAAA;MACA,KAAAC,QAAA;MACA,KAAA+C,IAAA;IACA;IACAU,oBAAAC,OAAA;MACA,KAAAX,IAAA,CAAAW,OAAA;IACA;IACAC,mBAAAzC,GAAA;MACA,KAAAhB,IAAA,CAAA0D,KAAA,GAAA1C,GAAA,CAAAxB,IAAA;IACA;IACA8B,YAAA;MACA,KAAAqC,SAAA;QACA,KAAAhD,MAAA,OAAAtB,CAAA;QACA,KAAAsB,MAAA,CAAAiD,SAAA,GAAAtE,IAAA;QACA,KAAAqB,MAAA,CAAAkD,MAAA,CAAAC,eAAA,QAAAC,QAAA;QACA,KAAApD,MAAA,CAAAkD,MAAA,CAAAG,cAAA;QACA,KAAArD,MAAA,CAAAkD,MAAA,CAAAI,gBAAA;UACAC,KAAA,OAAAjE,IAAA,CAAAiE;QACA;QACA,KAAAvD,MAAA,CAAAkD,MAAA,CAAAM,eAAA;UACAzB,IAAA;QACA;QACA,KAAA/B,MAAA,CAAAkD,MAAA,CAAAO,MAAA;QACA,KAAAzD,MAAA,CAAA0D,MAAA;MACA;IACA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}