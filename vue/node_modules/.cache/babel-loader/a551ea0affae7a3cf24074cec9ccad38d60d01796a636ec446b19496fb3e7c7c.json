{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport AiAssistant from '@/components/AiAssistant.vue';\nexport default {\n  name: \"FrontLayout\",\n  components: {\n    AiAssistant\n  },\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem(\"xm-user\") || '{}'),\n      title: ''\n    };\n  },\n  methods: {\n    updateUser() {\n      this.user = JSON.parse(localStorage.getItem('xm-user') || '{}'); // 重新获取下用户的最新信息\n    },\n\n    // 退出登录\n    logout() {\n      localStorage.removeItem(\"xm-user\");\n      this.$router.push(\"/login\");\n    }\n  }\n};","map":{"version":3,"names":["AiAssistant","name","components","data","user","JSON","parse","localStorage","getItem","title","methods","updateUser","logout","removeItem","$router","push"],"sources":["src/views/front/Home.vue"],"sourcesContent":["<template>\n  <div>\n  <div class=\"front-header\">\n      <div class=\"front-header-left\">\n        <img src=\"@/assets/imgs/logo.png\" alt=\"\">\n        <div class=\"title\">网格化依法治理平台</div>\n      </div>\n      <div class=\"front-header-center\">\n        <div class=\"front-header-nav\">\n          <el-menu :default-active=\"$route.path\" mode=\"horizontal\" router>\n            <el-menu-item index=\"/front/index\">\n              <i class=\"el-icon-s-home\"></i>\n              <span>首页</span>\n            </el-menu-item>\n            \n            <el-menu-item index=\"/front/law\">\n              <i class=\"el-icon-warning-outline\"></i>\n              <span>法律法规</span>\n            </el-menu-item>\n            <el-menu-item index=\"/front/knowledge\">\n              <i class=\"el-icon-reading\"></i>\n              <span>治理案例库</span>\n            </el-menu-item>\n            <el-menu-item index=\"/front/home\">\n              <i class=\"el-icon-chat-dot-round\"></i>\n              <span>工作交流</span>\n            </el-menu-item>\n            <el-menu-item index=\"/front/activity\">\n              <i class=\"el-icon-trophy\"></i>\n              <span>任务中心</span>\n            </el-menu-item>\n            \n            <el-menu-item index=\"/front/learningClass\">\n              <i class=\"el-icon-video-camera\"></i>\n              <span>法治培训</span>\n            </el-menu-item>\n            \n            <el-menu-item index=\"/front/report\">\n              <i class=\"el-icon-phone-outline\"></i>\n              <span>事件上报</span>\n            </el-menu-item>\n            <el-menu-item index=\"/front/person\">\n              <i class=\"el-icon-user\"></i>\n              <span>个人中心</span>\n            </el-menu-item>\n          </el-menu>\n        </div>\n      </div>\n      <div class=\"front-header-right\">\n        <div v-if=\"!user.username\" class=\"header-buttons\">\n          <el-button size=\"small\" @click=\"$router.push('/login')\">登录</el-button>\n          <el-button size=\"small\" type=\"primary\" @click=\"$router.push('/register')\">注册</el-button>\n        </div>\n        <div v-else>\n          <el-dropdown>\n            <div class=\"front-header-dropdown\">\n              <img :src=\"user.avatar\" alt=\"\">\n              <div class=\"user-info\">\n                <span>{{ user.name }}</span>\n                <i class=\"el-icon-arrow-down\"></i>\n              </div>\n            </div>\n            <el-dropdown-menu slot=\"dropdown\">\n              <el-dropdown-item>\n                <div style=\"text-decoration: none\" @click=\"logout\">\n                  <i class=\"el-icon-switch-button\"></i> 退出登录\n                </div>\n              </el-dropdown-item>\n            </el-dropdown-menu>\n          </el-dropdown>\n        </div>\n      </div>\n    </div>\n    <div class=\"main-body\">\n      <router-view ref=\"child\" @update:user=\"updateUser\" />\n    </div>\n\n    <ai-assistant></ai-assistant>\n  </div>\n</template>\n\n<script>\nimport AiAssistant from '@/components/AiAssistant.vue'\n\nexport default {\n  name: \"FrontLayout\",\n  components: {\n    AiAssistant\n  },\n  data () {\n    return {\n      user: JSON.parse(localStorage.getItem(\"xm-user\") || '{}'),\n      title:'',\n    }\n  },\n  methods: {\n    updateUser() {\n      this.user = JSON.parse(localStorage.getItem('xm-user') || '{}')   // 重新获取下用户的最新信息\n    },\n    // 退出登录\n    logout() {\n      localStorage.removeItem(\"xm-user\");\n      this.$router.push(\"/login\");\n    },\n  }\n}\n</script>\n\n<style scoped>\n  /* 注意这里，Front.vue 和 assets 只隔了一层 views，所以一个 ../ 就够了 */\n  @import \"../assets/css/front.css\";\n\n  .front-header-center {\n    flex: 1;\n    overflow: hidden;\n  }\n  \n  /* 导航菜单容器样式：强制居中、不换行 */\n  ::v-deep .el-menu--horizontal {\n    display: flex !important;\n    justify-content: center !important; \n    flex-wrap: nowrap !important; \n    border-bottom: none !important;\n    overflow-x: auto; \n  }\n\n  /* 隐藏丑陋的滚动条 */\n  ::v-deep .el-menu--horizontal::-webkit-scrollbar {\n    display: none; \n  }\n\n  /* 每个单独菜单项的间距 */\n  ::v-deep .el-menu--horizontal > .el-menu-item {\n    padding: 0 15px !important;\n    height: 60px;\n    line-height: 60px;\n  }\n</style>"],"mappings":";AAkFA,OAAAA,WAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IACAF;EACA;EACAG,KAAA;IACA;MACAC,IAAA,EAAAC,IAAA,CAAAC,KAAA,CAAAC,YAAA,CAAAC,OAAA;MACAC,KAAA;IACA;EACA;EACAC,OAAA;IACAC,WAAA;MACA,KAAAP,IAAA,GAAAC,IAAA,CAAAC,KAAA,CAAAC,YAAA,CAAAC,OAAA;IACA;;IACA;IACAI,OAAA;MACAL,YAAA,CAAAM,UAAA;MACA,KAAAC,OAAA,CAAAC,IAAA;IACA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}