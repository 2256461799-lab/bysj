{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'AiAssistant',\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\n      dialogVisible: false,\n      currentMode: null,\n      // 'chat' 或 'simulation'\n      scenarioType: null,\n      // 'phone', 'brushing', 'love', 'loan'\n      messages: [],\n      userInput: '',\n      isTyping: false,\n      isShaking: false,\n      chatSessionId: null,\n      // 智能问答的会话ID\n      simulationSessionId: null // 情景模拟的会话ID\n    };\n  },\n\n  computed: {\n    dialogTitle() {\n      if (!this.currentMode) return 'AI治理助手';\n      if (this.currentMode === 'chat') return 'AI智能问答';\n      if (this.currentMode === 'simulation') {\n        if (!this.scenarioType) return '选择情景';\n        const names = {\n          phone: '矛盾调解模拟',\n          brushing: '隐患排查模拟',\n          love: '环境治理模拟',\n          loan: '民生诉求模拟'\n        };\n        return names[this.scenarioType] || 'AI情景模拟';\n      }\n      return 'AI治理助手';\n    }\n  },\n  mounted() {\n    // 5秒后开始抖动提示\n    setTimeout(() => {\n      this.isShaking = true;\n    }, 5000);\n  },\n  methods: {\n    generateSessionId(prefix = 'session') {\n      return prefix + '_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);\n    },\n    openDialog() {\n      this.dialogVisible = true;\n      this.isShaking = false;\n    },\n    selectMode(mode) {\n      this.currentMode = mode;\n      if (mode === 'chat') {\n        // 为智能问答创建独立的会话ID\n        if (!this.chatSessionId) {\n          this.chatSessionId = this.generateSessionId('chat');\n        }\n        this.addSystemMessage('您好！我是AI治理助手，您可以向我咨询任何基层治理相关的问题。');\n      }\n    },\n    selectScenario(type) {\n      this.scenarioType = type;\n      // 为每个情景模拟创建独立的会话ID\n      this.simulationSessionId = this.generateSessionId('simulation_' + type);\n      const tips = {\n        phone: '⚠️ 模拟开始：你接到一起邻里矛盾纠纷的调解任务...',\n        brushing: '⚠️ 模拟开始：你在巡查中发现一处安全隐患...',\n        love: '⚠️ 模拟开始：你负责的网格区域有环境问题需要处理...',\n        loan: '⚠️ 模拟开始：一位居民向你反映民生诉求...'\n      };\n      this.addSystemMessage(tips[type]);\n      this.addSystemMessage('请开始对话，随时可以结束模拟。');\n    },\n    backToModeSelection() {\n      this.currentMode = null;\n      this.scenarioType = null;\n      this.messages = [];\n      // 不清空 sessionId，保持历史记录\n    },\n\n    backToSelection() {\n      if (this.currentMode === 'simulation' && this.scenarioType) {\n        // 返回情景选择，重置情景类型和会话\n        this.scenarioType = null;\n        this.simulationSessionId = null;\n      } else {\n        // 返回模式选择\n        this.currentMode = null;\n      }\n      this.messages = [];\n    },\n    addSystemMessage(content) {\n      this.messages.push({\n        role: 'system',\n        content: content,\n        time: this.getCurrentTime()\n      });\n      this.$nextTick(() => {\n        this.scrollToBottom();\n      });\n    },\n    sendMessage() {\n      if (!this.userInput.trim() || this.isTyping) return;\n      const userMessage = this.userInput.trim();\n      this.messages.push({\n        role: 'user',\n        content: userMessage,\n        time: this.getCurrentTime()\n      });\n      this.userInput = '';\n      this.isTyping = true;\n      this.$nextTick(() => {\n        this.scrollToBottom();\n      });\n\n      // 调用后端API\n      if (this.currentMode === 'chat') {\n        this.callChatAPI(userMessage);\n      } else if (this.currentMode === 'simulation') {\n        this.callSimulationAPI(userMessage);\n      }\n    },\n    callChatAPI(message) {\n      const url = `${this.$baseUrl}/ai/chat?sessionId=${this.chatSessionId}&message=${encodeURIComponent(message)}`;\n      this.handleSSE(url);\n    },\n    callSimulationAPI(message) {\n      const url = `${this.$baseUrl}/ai/simulation?sessionId=${this.simulationSessionId}&message=${encodeURIComponent(message)}&scenarioType=${this.scenarioType}`;\n      this.handleSSE(url);\n    },\n    handleSSE(url) {\n      const eventSource = new EventSource(url);\n      let aiMessage = '';\n      eventSource.onmessage = event => {\n        const data = event.data;\n        if (data === '[START]') {\n          // 开始接收\n          return;\n        }\n        if (data === '[DONE]') {\n          // 完成\n          eventSource.close();\n          this.isTyping = false;\n          return;\n        }\n\n        // 追加内容\n        aiMessage += data;\n\n        // 更新或添加AI消息\n        const lastMessage = this.messages[this.messages.length - 1];\n        if (lastMessage && lastMessage.role === 'assistant') {\n          lastMessage.content = aiMessage;\n        } else {\n          this.messages.push({\n            role: 'assistant',\n            content: aiMessage,\n            time: this.getCurrentTime()\n          });\n        }\n        this.$nextTick(() => {\n          this.scrollToBottom();\n        });\n      };\n      eventSource.onerror = error => {\n        console.error('SSE Error:', error);\n        eventSource.close();\n        this.isTyping = false;\n        this.$message.error('连接出错，请重试');\n      };\n    },\n    clearChat() {\n      this.$confirm('确定要清空对话吗？', '提示', {\n        type: 'warning'\n      }).then(() => {\n        this.messages = [];\n        // 根据当前模式清空对应的会话历史\n        const sessionId = this.currentMode === 'chat' ? this.chatSessionId : this.simulationSessionId;\n        this.$request.delete('/ai/clear', {\n          params: {\n            sessionId: sessionId\n          }\n        });\n        if (this.currentMode === 'chat') {\n          this.addSystemMessage('对话已清空，您可以重新开始提问。');\n        } else {\n          // 重新生成情景模拟的会话ID\n          this.simulationSessionId = this.generateSessionId('simulation_' + this.scenarioType);\n        }\n      }).catch(() => {});\n    },\n    scrollToBottom() {\n      if (this.$refs.messageList) {\n        this.$refs.messageList.scrollTop = this.$refs.messageList.scrollHeight;\n      }\n    },\n    getCurrentTime() {\n      const now = new Date();\n      return `${now.getHours().toString().padStart(2, '0')}:${now.getMinutes().toString().padStart(2, '0')}`;\n    }\n  }\n};","map":{"version":3,"names":["name","data","user","JSON","parse","localStorage","getItem","dialogVisible","currentMode","scenarioType","messages","userInput","isTyping","isShaking","chatSessionId","simulationSessionId","computed","dialogTitle","names","phone","brushing","love","loan","mounted","setTimeout","methods","generateSessionId","prefix","Date","now","Math","random","toString","substr","openDialog","selectMode","mode","addSystemMessage","selectScenario","type","tips","backToModeSelection","backToSelection","content","push","role","time","getCurrentTime","$nextTick","scrollToBottom","sendMessage","trim","userMessage","callChatAPI","callSimulationAPI","message","url","$baseUrl","encodeURIComponent","handleSSE","eventSource","EventSource","aiMessage","onmessage","event","close","lastMessage","length","onerror","error","console","$message","clearChat","$confirm","then","sessionId","$request","delete","params","catch","$refs","messageList","scrollTop","scrollHeight","getHours","padStart","getMinutes"],"sources":["src/components/AiAssistant.vue"],"sourcesContent":["<template>\n  <div class=\"ai-assistant\">\n    <!-- 悬浮球 -->\n    <div\n      v-show=\"!dialogVisible\"\n      class=\"float-ball\"\n      :class=\"{ shake: isShaking }\"\n      @click=\"openDialog\"\n      @mouseenter=\"isShaking = false\"\n    >\n      <div class=\"ball-icon\">\n        <i class=\"el-icon-chat-dot-round\"></i>\n      </div>\n      <div class=\"ball-text\">治理助手</div>\n    </div>\n\n    <!-- 对话窗口 -->\n    <el-dialog\n      :title=\"dialogTitle\"\n      :visible.sync=\"dialogVisible\"\n      width=\"40%\"\n      :close-on-click-modal=\"false\"\n      custom-class=\"ai-dialog\"\n      :append-to-body=\"true\"\n    >\n      <!-- 功能选择 -->\n      <div v-if=\"!currentMode\" class=\"mode-selection\">\n        <div class=\"mode-card\" @click=\"selectMode('chat')\">\n          <div class=\"mode-icon chat-icon\">\n            <i class=\"el-icon-chat-line-square\"></i>\n          </div>\n          <h3>AI智能问答</h3>\n          <p>咨询治理知识、了解法律法规</p>\n        </div>\n        <div class=\"mode-card\" @click=\"selectMode('simulation')\">\n          <div class=\"mode-icon sim-icon\">\n            <i class=\"el-icon-user\"></i>\n          </div>\n          <h3>AI情景模拟</h3>\n          <p>与AI模拟治理场景，提升处置能力</p>\n        </div>\n      </div>\n\n      <!-- 情景选择 -->\n      <div v-if=\"currentMode === 'simulation' && !scenarioType\" class=\"scenario-selection\">\n        <el-button @click=\"backToModeSelection\" size=\"small\" icon=\"el-icon-back\">返回</el-button>\n        <div style=\"margin-top: 15px\">\n          <div class=\"scenario-item\" @click=\"selectScenario('phone')\">\n            <i class=\"el-icon-phone\"></i>\n            <span>矛盾调解</span>\n          </div>\n          <div class=\"scenario-item\" @click=\"selectScenario('brushing')\">\n            <i class=\"el-icon-money\"></i>\n            <span>隐患排查</span>\n          </div>\n          <div class=\"scenario-item\" @click=\"selectScenario('love')\">\n            <i class=\"el-icon-star-off\"></i>\n            <span>环境治理</span>\n          </div>\n          <div class=\"scenario-item\" @click=\"selectScenario('loan')\">\n            <i class=\"el-icon-wallet\"></i>\n            <span>民生诉求</span>\n          </div>\n        </div>\n      </div>\n\n      <!-- 对话区域 -->\n      <div v-if=\"(currentMode === 'chat') || (currentMode === 'simulation' && scenarioType)\" class=\"chat-container\">\n        <div class=\"chat-header\">\n          <el-button @click=\"backToSelection\" size=\"small\" icon=\"el-icon-back\">返回</el-button>\n          <el-button @click=\"clearChat\" size=\"small\" icon=\"el-icon-delete\">清空</el-button>\n        </div>\n\n        <!-- 消息列表 -->\n        <div class=\"message-list\" ref=\"messageList\">\n          <div v-for=\"(msg, index) in messages\" :key=\"index\" :class=\"['message-item', msg.role]\">\n            <div class=\"message-avatar\">\n              <img v-if=\"msg.role === 'user' && user.avatar\" :src=\"user.avatar\" class=\"avatar-img\" />\n              <i v-else-if=\"msg.role === 'user'\" class=\"el-icon-user-solid\"></i>\n              <i v-else class=\"el-icon-service\"></i>\n            </div>\n            <div class=\"message-content\">\n              <div class=\"message-text\">{{ msg.content }}</div>\n              <div class=\"message-time\">{{ msg.time }}</div>\n            </div>\n          </div>\n          <div v-if=\"isTyping\" class=\"message-item assistant\">\n            <div class=\"message-avatar\">\n              <i class=\"el-icon-service\"></i>\n            </div>\n            <div class=\"message-content\">\n              <div class=\"typing-indicator\">\n                <span></span>\n                <span></span>\n                <span></span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- 输入区域 -->\n        <div class=\"input-area\">\n          <el-input\n            v-model=\"userInput\"\n            placeholder=\"输入消息...\"\n            @keyup.enter.native=\"sendMessage\"\n            :disabled=\"isTyping\"\n          >\n            <el-button\n              slot=\"append\"\n              icon=\"el-icon-s-promotion\"\n              @click=\"sendMessage\"\n              :disabled=\"isTyping || !userInput.trim()\"\n            ></el-button>\n          </el-input>\n        </div>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'AiAssistant',\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem('xm-user') || '{}'),\n      dialogVisible: false,\n      currentMode: null, // 'chat' 或 'simulation'\n      scenarioType: null, // 'phone', 'brushing', 'love', 'loan'\n      messages: [],\n      userInput: '',\n      isTyping: false,\n      isShaking: false,\n      chatSessionId: null, // 智能问答的会话ID\n      simulationSessionId: null // 情景模拟的会话ID\n    }\n  },\n  computed: {\n    dialogTitle() {\n      if (!this.currentMode) return 'AI治理助手'\n      if (this.currentMode === 'chat') return 'AI智能问答'\n      if (this.currentMode === 'simulation') {\n        if (!this.scenarioType) return '选择情景'\n        const names = {\n          phone: '矛盾调解模拟',\n          brushing: '隐患排查模拟',\n          love: '环境治理模拟',\n          loan: '民生诉求模拟'\n        }\n        return names[this.scenarioType] || 'AI情景模拟'\n      }\n      return 'AI治理助手'\n    }\n  },\n  mounted() {\n    // 5秒后开始抖动提示\n    setTimeout(() => {\n      this.isShaking = true\n    }, 5000)\n  },\n  methods: {\n    generateSessionId(prefix = 'session') {\n      return prefix + '_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9)\n    },\n    openDialog() {\n      this.dialogVisible = true\n      this.isShaking = false\n    },\n    selectMode(mode) {\n      this.currentMode = mode\n      if (mode === 'chat') {\n        // 为智能问答创建独立的会话ID\n        if (!this.chatSessionId) {\n          this.chatSessionId = this.generateSessionId('chat')\n        }\n        this.addSystemMessage('您好！我是AI治理助手，您可以向我咨询任何基层治理相关的问题。')\n      }\n    },\n    selectScenario(type) {\n      this.scenarioType = type\n      // 为每个情景模拟创建独立的会话ID\n      this.simulationSessionId = this.generateSessionId('simulation_' + type)\n      \n      const tips = {\n        phone: '⚠️ 模拟开始：你接到一起邻里矛盾纠纷的调解任务...',\n        brushing: '⚠️ 模拟开始：你在巡查中发现一处安全隐患...',\n        love: '⚠️ 模拟开始：你负责的网格区域有环境问题需要处理...',\n        loan: '⚠️ 模拟开始：一位居民向你反映民生诉求...'\n      }\n      this.addSystemMessage(tips[type])\n      this.addSystemMessage('请开始对话，随时可以结束模拟。')\n    },\n    backToModeSelection() {\n      this.currentMode = null\n      this.scenarioType = null\n      this.messages = []\n      // 不清空 sessionId，保持历史记录\n    },\n    backToSelection() {\n      if (this.currentMode === 'simulation' && this.scenarioType) {\n        // 返回情景选择，重置情景类型和会话\n        this.scenarioType = null\n        this.simulationSessionId = null\n      } else {\n        // 返回模式选择\n        this.currentMode = null\n      }\n      this.messages = []\n    },\n    addSystemMessage(content) {\n      this.messages.push({\n        role: 'system',\n        content: content,\n        time: this.getCurrentTime()\n      })\n      this.$nextTick(() => {\n        this.scrollToBottom()\n      })\n    },\n    sendMessage() {\n      if (!this.userInput.trim() || this.isTyping) return\n\n      const userMessage = this.userInput.trim()\n      this.messages.push({\n        role: 'user',\n        content: userMessage,\n        time: this.getCurrentTime()\n      })\n      this.userInput = ''\n      this.isTyping = true\n\n      this.$nextTick(() => {\n        this.scrollToBottom()\n      })\n\n      // 调用后端API\n      if (this.currentMode === 'chat') {\n        this.callChatAPI(userMessage)\n      } else if (this.currentMode === 'simulation') {\n        this.callSimulationAPI(userMessage)\n      }\n    },\n    callChatAPI(message) {\n      const url = `${this.$baseUrl}/ai/chat?sessionId=${this.chatSessionId}&message=${encodeURIComponent(message)}`\n      this.handleSSE(url)\n    },\n    callSimulationAPI(message) {\n      const url = `${this.$baseUrl}/ai/simulation?sessionId=${this.simulationSessionId}&message=${encodeURIComponent(message)}&scenarioType=${this.scenarioType}`\n      this.handleSSE(url)\n    },\n    handleSSE(url) {\n      const eventSource = new EventSource(url)\n      let aiMessage = ''\n\n      eventSource.onmessage = (event) => {\n        const data = event.data\n        \n        if (data === '[START]') {\n          // 开始接收\n          return\n        }\n        \n        if (data === '[DONE]') {\n          // 完成\n          eventSource.close()\n          this.isTyping = false\n          return\n        }\n\n        // 追加内容\n        aiMessage += data\n        \n        // 更新或添加AI消息\n        const lastMessage = this.messages[this.messages.length - 1]\n        if (lastMessage && lastMessage.role === 'assistant') {\n          lastMessage.content = aiMessage\n        } else {\n          this.messages.push({\n            role: 'assistant',\n            content: aiMessage,\n            time: this.getCurrentTime()\n          })\n        }\n\n        this.$nextTick(() => {\n          this.scrollToBottom()\n        })\n      }\n\n      eventSource.onerror = (error) => {\n        console.error('SSE Error:', error)\n        eventSource.close()\n        this.isTyping = false\n        this.$message.error('连接出错，请重试')\n      }\n    },\n    clearChat() {\n      this.$confirm('确定要清空对话吗？', '提示', {\n        type: 'warning'\n      }).then(() => {\n        this.messages = []\n        // 根据当前模式清空对应的会话历史\n        const sessionId = this.currentMode === 'chat' ? this.chatSessionId : this.simulationSessionId\n        this.$request.delete('/ai/clear', {\n          params: { sessionId: sessionId }\n        })\n        if (this.currentMode === 'chat') {\n          this.addSystemMessage('对话已清空，您可以重新开始提问。')\n        } else {\n          // 重新生成情景模拟的会话ID\n          this.simulationSessionId = this.generateSessionId('simulation_' + this.scenarioType)\n        }\n      }).catch(() => {})\n    },\n    scrollToBottom() {\n      if (this.$refs.messageList) {\n        this.$refs.messageList.scrollTop = this.$refs.messageList.scrollHeight\n      }\n    },\n    getCurrentTime() {\n      const now = new Date()\n      return `${now.getHours().toString().padStart(2, '0')}:${now.getMinutes().toString().padStart(2, '0')}`\n    }\n  }\n}\n</script>\n\n<style scoped>\n/* 悬浮球样式 */\n.float-ball {\n  position: fixed;\n  right: 30px;\n  bottom: 30px;\n  width: 64px;\n  height: 64px;\n  background: #1d3557;\n  border-radius: 50%;\n  box-shadow: 0 2px 12px rgba(29, 53, 87, 0.4);\n  cursor: pointer;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  z-index: 9999;\n  transition: all 0.2s;\n}\n\n.float-ball:hover {\n  background: #264e78;\n  box-shadow: 0 2px 16px rgba(29, 53, 87, 0.5);\n}\n\n.float-ball.shake {\n  animation: shake 0.5s infinite;\n}\n\n@keyframes shake {\n  0%, 100% { transform: rotate(0deg); }\n  25% { transform: rotate(-8deg); }\n  75% { transform: rotate(8deg); }\n}\n\n.ball-icon {\n  font-size: 28px;\n  color: white;\n}\n\n.ball-text {\n  font-size: 11px;\n  color: white;\n  margin-top: 2px;\n}\n\n/* 对话窗口样式 */\n/deep/ .ai-dialog {\n  border-radius: 4px;\n  overflow: hidden;\n}\n\n/deep/ .ai-dialog .el-dialog__header {\n  background: #1d3557;\n  padding: 16px 20px;\n  border-bottom: 1px solid #e8e8e8;\n}\n\n/deep/ .ai-dialog .el-dialog__title {\n  color: white;\n  font-weight: 600;\n  font-size: 16px;\n}\n\n/deep/ .ai-dialog .el-dialog__headerbtn .el-dialog__close {\n  color: white;\n  font-size: 18px;\n}\n\n/deep/ .ai-dialog .el-dialog__body {\n  padding: 0;\n}\n\n/* 功能选择 */\n.mode-selection {\n  display: flex;\n  gap: 16px;\n  padding: 24px;\n  background: #fafafa;\n}\n\n.mode-card {\n  flex: 1;\n  padding: 24px 16px;\n  background: white;\n  border: 1px solid #e8e8e8;\n  text-align: center;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.mode-card:hover {\n  border-color: #1d3557;\n  box-shadow: 0 2px 8px rgba(0,0,0,0.08);\n}\n\n.mode-icon {\n  width: 56px;\n  height: 56px;\n  margin: 0 auto 12px;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 26px;\n  color: white;\n  background: #1d3557;\n}\n\n.sim-icon {\n  background: #457b9d;\n}\n\n.mode-card h3 {\n  margin: 0 0 8px 0;\n  font-size: 15px;\n  font-weight: 600;\n  color: #333;\n}\n\n.mode-card p {\n  margin: 0;\n  font-size: 13px;\n  color: #999;\n  line-height: 1.5;\n}\n\n/* 情景选择 */\n.scenario-selection {\n  padding: 20px;\n  background: #fafafa;\n}\n\n.scenario-item {\n  padding: 14px 16px;\n  margin-top: 10px;\n  background: white;\n  border: 1px solid #e8e8e8;\n  cursor: pointer;\n  transition: all 0.2s;\n  display: flex;\n  align-items: center;\n  gap: 10px;\n}\n\n.scenario-item:hover {\n  border-color: #1d3557;\n  background: #e8f0f8;\n}\n\n.scenario-item i {\n  font-size: 18px;\n  color: #1d3557;\n}\n\n.scenario-item span {\n  font-size: 14px;\n  color: #333;\n}\n\n/* 对话容器 */\n.chat-container {\n  display: flex;\n  flex-direction: column;\n  height: 500px;\n}\n\n.chat-header {\n  padding: 12px 16px;\n  background: #fafafa;\n  border-bottom: 1px solid #e8e8e8;\n  display: flex;\n  justify-content: space-between;\n}\n\n.message-list {\n  flex: 1;\n  overflow-y: auto;\n  padding: 16px;\n  background: #f8f8f8;\n}\n\n.message-item {\n  display: flex;\n  margin-bottom: 16px;\n  animation: fadeIn 0.2s;\n}\n\n@keyframes fadeIn {\n  from { opacity: 0; }\n  to { opacity: 1; }\n}\n\n.message-item.user {\n  flex-direction: row-reverse;\n}\n\n.message-avatar {\n  width: 34px;\n  height: 34px;\n  border-radius: 50%;\n  background: #1d3557;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: white;\n  font-size: 16px;\n  flex-shrink: 0;\n  overflow: hidden;\n}\n\n.avatar-img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  border-radius: 50%;\n}\n\n.message-item.user .message-avatar {\n  background: #67c23a;\n}\n\n.message-item.system .message-avatar {\n  background: #e6a23c;\n}\n\n.message-content {\n  max-width: 70%;\n  margin: 0 10px;\n}\n\n.message-text {\n  padding: 10px 14px;\n  background: white;\n  border: 1px solid #e8e8e8;\n  word-wrap: break-word;\n  line-height: 1.6;\n  font-size: 14px;\n  color: #333;\n}\n\n.message-item.user .message-text {\n  background: #1d3557;\n  color: white;\n  border-color: #1d3557;\n}\n\n.message-item.system .message-text {\n  background: #fffbe6;\n  border-left: 2px solid #e6a23c;\n}\n\n.message-time {\n  font-size: 11px;\n  color: #999;\n  margin-top: 4px;\n  text-align: center;\n}\n\n.typing-indicator {\n  padding: 10px 14px;\n  background: white;\n  border: 1px solid #e8e8e8;\n  display: inline-flex;\n  gap: 5px;\n}\n\n.typing-indicator span {\n  width: 6px;\n  height: 6px;\n  border-radius: 50%;\n  